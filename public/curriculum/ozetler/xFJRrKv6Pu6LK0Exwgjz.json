{
  "title": "2.Oruç İbadeti",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Oruç İbadeti ve Ramazan</title>\n    <!-- Tailwind CSS CDN -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Google Fonts: Inter -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f7f3ff; /* Hafif mor/lavanta arka plan */\n        }\n        \n        .infographic-card {\n            background-color: white;\n            border-radius: 16px;\n            padding: 24px 28px;\n            margin-bottom: 24px;\n            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.07);\n            border: 1px solid #e9d5ff; /* Mor-200 kenarlık */\n            transition: all 0.3s ease;\n        }\n        \n        .infographic-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 25px -5px rgba(76, 29, 149, 0.1);\n        }\n\n        .card-title {\n            font-size: 1.5rem; /* 24px */\n            font-weight: 700;\n            color: #5b21b6; /* Mor-700 */\n            margin-bottom: 16px;\n            display: flex;\n            align-items: center;\n        }\n        \n        .card-title svg {\n            width: 28px;\n            height: 28px;\n            margin-right: 12px;\n            stroke-width: 2;\n        }\n        \n        /* Liste elemanları için özel stil */\n        .custom-list li {\n            position: relative;\n            padding-left: 32px;\n            margin-bottom: 12px;\n            font-size: 1.05rem; /* Biraz daha büyük font */\n            color: #374151; /* gray-700 */\n        }\n        \n        .custom-list li::before {\n            content: '✓';\n            position: absolute;\n            left: 0;\n            top: 1px;\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            background-color: #e9d5ff; /* Mor-200 */\n            color: #5b21b6; /* Mor-700 */\n            font-weight: bold;\n            text-align: center;\n            line-height: 24px;\n            font-size: 14px;\n        }\n    </style>\n</head>\n<body class=\"p-4 md:p-10\">\n    <div class=\"max-w-4xl mx-auto\">\n\n        <!-- Ana Başlık -->\n        <h1 class=\"text-4xl md:text-5xl font-extrabold text-center text-purple-900 mb-4\">\n            Oruç İbadeti ve Ramazan\n        </h1>\n        <p class=\"text-xl text-center text-gray-600 mb-12\">\n            Ramazan ayı ve oruçla ilgili bilmemiz gerekenler.\n        </p>\n\n        <!-- İnfografik Kartları -->\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n\n            <!-- BÖLÜM 1: Temel Kavramlar -->\n            <div class=\"infographic-card md:col-span-2\">\n                <h2 class=\"card-title\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z\" />\n                    </svg>\n                    Ramazan ve Oruçla İlgili Temel Kavramlar\n                </h2>\n                <div class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4\">\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">Sahur</h3>\n                        <p class=\"text-gray-700\">Oruç tutmak için imsaktan önce yenilen yemek.</p>\n                    </div>\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">İmsak</h3>\n                        <p class=\"text-gray-700\">Oruca başlama vaktidir. Sabah namazının da vaktidir.</p>\n                    </div>\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">İftar</h3>\n                        <p class=\"text-gray-700\">Akşam ezanıyla birlikte orucu açma vaktidir.</p>\n                    </div>\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">Teravih</h3>\n                        <p class=\"text-gray-700\">Ramazan ayında yatsıdan sonra kılınan sünnet namazdır.</p>\n                    </div>\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">Mukabele</h3>\n                        <p class=\"text-gray-700\">Birinin Kur'an okuması, diğerlerinin takip etmesidir.</p>\n                    </div>\n                    <div class=\"bg-purple-50 p-4 rounded-lg border border-purple-200\">\n                        <h3 class=\"font-bold text-lg text-purple-800\">Fitre (Fıtır Sadakası)</h3>\n                        <p class=\"text-gray-700\">Sağlığın şükrü için verilen vacip bir sadakadır.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- BÖLÜM 2: Oruçlunun Sorumlulukları -->\n            <div class=\"infographic-card\">\n                <h2 class=\"card-title text-emerald-700\" style=\"color: #047857;\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                    </svg>\n                    Oruçlunun Dikkat Etmesi Gerekenler\n                </h2>\n                <ul class=\"custom-list\">\n                    <style>\n                        .card-2 li::before { background-color: #d1fae5; color: #047857; } /* Emerald */\n                    </style>\n                    <div class=\"card-2\">\n                        <li><b>Niyet Etmek:</b> \"Niyet ettim Allah rızası için...\" diyerek oruca niyetlenmek gerekir.</li>\n                        <li><b>Güzel Ahlak:</b> Yalandan, kötü sözden ve kavgadan kaçınmak gerekir.</li>\n                        <li><b>Sabırlı Olmak:</b> Oruç bir kalkan gibidir, sahibini korur. Öfkeye kapılmamalıdır.</li>\n                        <li><b>Orucu Bozanlar:</b> Bilerek yiyip içmek orucu bozar.</li>\n                        <li><b>Orucu Bozmayanlar:</b> Unutarak yiyip içmek, banyo yapmak, koku sürmek orucu bozmaz.</li>\n                    </div>\n                </ul>\n            </div>\n\n            <!-- BÖLÜM 3: Özel Durumlar ve Kolaylıklar -->\n            <div class=\"infographic-card\">\n                <h2 class=\"card-title text-amber-700\" style=\"color: #b45309;\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z\" />\n                    </svg>\n                    Özel Durumlar ve Kolaylıklar\n                </h2>\n                <ul class=\"custom-list\">\n                    <style>\n                        .card-3 li::before { background-color: #fef3c7; color: #b45309; } /* Amber */\n                    </style>\n                    <div class=\"card-3\">\n                        <li><b>Hastalık ve Yolculuk:</b> Bu durumlarda oruç tutulamayabilir.</li>\n                        <li><b>Kaza Orucu:</b> Ramazan'da tutulamayan oruçların daha sonra gününe gün tutulmasıdır.</li>\n                        <li><b>Fidye:</b> Sürekli hasta olup iyileşemeyecek olanların, tutamadığı her gün için bir fakiri doyurmasıdır.</li>\n                    </div>\n                </ul>\n            </div>\n            \n            <!-- BÖLÜM 4: Oruç Çeşitleri (Kullanıcının isteğini vurgulayan bölüm) -->\n            <div class=\"infographic-card md:col-span-2\">\n                <h2 class=\"card-title text-blue-700\" style=\"color: #1d4ed8;\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6.75 3v2.25m10.5-2.25v2.25m-10.5 0H17.25m-10.5 0H17.25m-10.5 0H17.25m-10.5 0H17.25M6.75 8.25h10.5v8.25a2.25 2.25 0 01-2.25 2.25H9a2.25 2.25 0 01-2.25-2.25V8.25z\" />\n                    </svg>\n                    Oruç Çeşitleri Nelerdir?\n                </h2>\n                \n                <div class=\"space-y-5 mt-4\">\n                    <!-- Farz Oruç -->\n                    <div class=\"border-l-4 border-red-500 bg-red-50 p-5 rounded-r-lg\">\n                        <h3 class=\"font-bold text-xl text-red-800 mb-2\">1. Farz Oruç (Zorunlu)</h3>\n                        <p class=\"text-gray-700\">Allah'ın (cc) kesinlikle tutulmasını emrettiği oruçtur.</p>\n                        <ul class=\"list-disc pl-5 mt-2 text-red-700\">\n                            <li><b>Ramazan Orucu:</b> Ramazan ayında tutulur.</li>\n                            <li><b>Kaza Orucu:</b> Ramazan'da tutulamayanların kazasıdır.</li>\n                            <li><b>Kefaret Orucu:</b> Ramazan'da bilerek bozulan orucun cezasıdır.</li>\n                        </ul>\n                    </div>\n                    \n                    <!-- Vacip Oruç -->\n                    <div class=\"border-l-4 border-orange-500 bg-orange-50 p-5 rounded-r-lg\">\n                        <h3 class=\"font-bold text-xl text-orange-800 mb-2\">2. Vacip Oruç (Gerekli)</h3>\n                        <p class=\"text-gray-700\">Farz kadar kesin olmasa da tutulması gereken oruçtur.</p>\n                        <ul class=\"list-disc pl-5 mt-2 text-orange-700\">\n                            <li><b>Adak (Nezir) Orucu:</b> Bir dileğin gerçekleşmesi şartıyla tutmaya söz verilen oruçtur.</li>\n                        </ul>\n                    </div>\n                    \n                    <!-- Sünnet Oruç (Kullanıcının vurguladığı) -->\n                    <div class=\"border-l-4 border-green-500 bg-green-50 p-5 rounded-r-lg\">\n                        <h3 class=\"font-bold text-xl text-green-800 mb-2\">3. Sünnet Oruç (Gönüllü)</h3>\n                        <p class=\"text-gray-700\">Peygamber Efendimizin (sav) tuttuğu ve tavsiye ettiği oruçlardır.</p>\n                        <ul class=\"list-disc pl-5 mt-2 text-green-700\">\n                            <li><b>Muharrem Orucu:</b> Muharrem ayının 9, 10 ve 11. günlerinde tutulur.</li>\n                            <li><b>Şevval Orucu:</b> Ramazan ayından sonra, Şevval ayında tutulan 6 gün oruçtur. (Peygamberimiz bunu \"bütün yılı oruçlu geçirmiş gibi\" müjdelemiştir.)</li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n\n        </div> <!-- grid sonu -->\n    </div>\n</body>\n</html>\n"
}