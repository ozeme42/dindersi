{
  "title": "3.Umre ve Önemi",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Umre ve Önemi - İnteraktif Ders Materyali</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        body { font-family: 'Inter', sans-serif; }\n        .font-arabic { font-family: 'Amiri', serif; }\n        \n        /* Animasyonlar */\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-fade-in-up {\n            animation: fadeInUp 0.5s ease-out forwards;\n        }\n\n        /* Sekme Gizleme/Gösterme */\n        .tab-content { display: none; }\n        .tab-content.active { display: block; }\n        \n        /* Custom Scrollbar Hide */\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n</head>\n<body class=\"min-h-screen bg-slate-50 text-slate-800 selection:bg-teal-200\">\n\n    <!-- Header Section -->\n    <header class=\"bg-gradient-to-br from-teal-900 to-emerald-800 text-white py-10 px-4 shadow-xl relative overflow-hidden\">\n        <div class=\"absolute top-0 right-0 p-8 opacity-5\">\n            <i data-lucide=\"moon\" width=\"200\" height=\"200\"></i>\n        </div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <div class=\"inline-block bg-white/20 px-3 py-1 rounded-full text-xs font-semibold mb-3 tracking-wide\">\n                2. ÜNİTE: HAC VE KURBAN\n            </div>\n            <h1 class=\"text-4xl md:text-6xl font-bold mb-4 tracking-tight\">UMRE VE ÖNEMİ</h1>\n            <div class=\"bg-white/10 backdrop-blur-sm p-4 rounded-xl border border-white/20 max-w-2xl mx-auto mt-4\">\n                <p class=\"text-lg italic font-serif\">\"Haccı ve umreyi Allah için eksiksiz yerine getirin...\"</p>\n                <p class=\"text-xs text-emerald-200 mt-2 text-right opacity-80\">(Bakara suresi, 196. ayet)</p>\n            </div>\n        </div>\n    </header>\n\n    <!-- Navigation Tabs -->\n    <div class=\"sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm border-b border-slate-200\">\n        <div class=\"max-w-5xl mx-auto flex overflow-x-auto justify-center p-2 gap-2 md:gap-4 no-scrollbar\">\n            <button onclick=\"openTab('nedir', this)\" class=\"tab-btn active flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold bg-teal-600 text-white shadow-lg transform scale-105 transition-all whitespace-nowrap\">\n                <i data-lucide=\"info\"></i> Umre Nedir?\n            </button>\n            <button onclick=\"openTab('yapilis', this)\" class=\"tab-btn flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"list-checks\"></i> Adım Adım Yapılış\n            </button>\n            <button onclick=\"openTab('farklar', this)\" class=\"tab-btn flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"git-compare\"></i> Hac vs Umre\n            </button>\n        </div>\n    </div>\n\n    <main class=\"max-w-5xl mx-auto p-4 md:p-8 min-h-[500px]\">\n\n        <!-- TAB 1: UMRE NEDİR? -->\n        <div id=\"nedir\" class=\"tab-content active animate-fade-in-up\">\n            <div class=\"grid md:grid-cols-2 gap-8 items-center\">\n                \n                <!-- Tanım Kartı -->\n                <div class=\"bg-white p-8 rounded-3xl shadow-xl border-l-8 border-teal-500\">\n                    <h2 class=\"text-2xl font-bold text-teal-800 mb-4 flex items-center gap-2\">\n                        <i data-lucide=\"book-open\" class=\"text-teal-600\"></i> Tanım\n                    </h2>\n                    <p class=\"text-slate-600 text-lg leading-relaxed\">\n                        <span class=\"font-bold text-slate-800\">Umre;</span> hac mevsimi dışında sırasıyla Kâbe’yi tavaf etme, say yapma, tıraş olduktan sonra ihramdan çıkma şeklinde yapılan ibadettir.\n                    </p>\n                    <div class=\"mt-6 flex gap-3\">\n                        <span class=\"bg-teal-100 text-teal-800 px-3 py-1 rounded-full text-sm font-bold\">Sünnettir</span>\n                        <span class=\"bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-sm font-bold\">Her zaman yapılabilir</span>\n                    </div>\n                </div>\n\n                <!-- Fazilet Kartı -->\n                <div class=\"bg-gradient-to-br from-amber-50 to-orange-50 p-8 rounded-3xl shadow-lg border border-amber-100 relative overflow-hidden\">\n                    <i data-lucide=\"quote\" class=\"absolute top-4 right-4 text-amber-200 opacity-50\" width=\"80\" height=\"80\"></i>\n                    <h3 class=\"text-xl font-bold text-amber-800 mb-4\">Peygamber Müjdesidir</h3>\n                    <p class=\"text-slate-700 italic font-medium text-lg mb-4\">\n                        “İki umre, aralarında işlenen günahlara kefarettir...”\n                    </p>\n                    <div class=\"flex items-center gap-2 text-sm text-amber-700 font-bold border-t border-amber-200 pt-4\">\n                        <i data-lucide=\"book\"></i> (Buhari, Umre, 1.)\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 2: ADIM ADIM YAPILIŞ -->\n        <div id=\"yapilis\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"text-center mb-8\">\n                <h2 class=\"text-2xl font-bold text-slate-800\">Umre Nasıl Yapılır?</h2>\n                <p class=\"text-slate-500\">4 Temel Adımda Umre İbadeti</p>\n            </div>\n\n            <div class=\"space-y-6 max-w-3xl mx-auto\">\n                \n                <!-- Step 1 -->\n                <div class=\"flex gap-4 group\">\n                    <div class=\"flex flex-col items-center\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 text-white flex items-center justify-center font-bold shadow-lg z-10\">1</div>\n                        <div class=\"h-full w-1 bg-slate-200 group-hover:bg-teal-200 transition-colors\"></div>\n                    </div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 flex-1 hover:shadow-xl transition-all pb-8\">\n                        <h3 class=\"text-xl font-bold text-teal-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"shirt\"></i> İhram ve Niyet\n                        </h3>\n                        <p class=\"text-slate-600 mb-3\">Mikat sınırında gusledip temizlenilir ve ihrama girilir. İki rekat namaz kılınır.</p>\n                        <div class=\"bg-teal-50 p-3 rounded-lg border-l-4 border-teal-500 text-sm italic text-teal-900\">\n                            \"Allah’ım umre yapmak istiyorum, onu bana kolay kıl ve benden kabul eyle.\"\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Step 2 -->\n                <div class=\"flex gap-4 group\">\n                    <div class=\"flex flex-col items-center\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 text-white flex items-center justify-center font-bold shadow-lg z-10\">2</div>\n                        <div class=\"h-full w-1 bg-slate-200 group-hover:bg-teal-200 transition-colors\"></div>\n                    </div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 flex-1 hover:shadow-xl transition-all pb-8\">\n                        <h3 class=\"text-xl font-bold text-teal-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"rotate-ccw\"></i> Tavaf\n                        </h3>\n                        <p class=\"text-slate-600 mb-3\">Kabe'ye gelinir ve umre tavafı yapılır.</p>\n                        <div class=\"bg-teal-50 p-3 rounded-lg border-l-4 border-teal-500 text-sm italic text-teal-900\">\n                            \"Allah’ım, senin rızan için umre tavafı yapmak istiyorum. Onu bana kolaylaştır ve kabul eyle.\"\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Step 3 -->\n                <div class=\"flex gap-4 group\">\n                    <div class=\"flex flex-col items-center\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 text-white flex items-center justify-center font-bold shadow-lg z-10\">3</div>\n                        <div class=\"h-full w-1 bg-slate-200 group-hover:bg-teal-200 transition-colors\"></div>\n                    </div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 flex-1 hover:shadow-xl transition-all pb-8\">\n                        <h3 class=\"text-xl font-bold text-teal-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"footprints\"></i> Say\n                        </h3>\n                        <p class=\"text-slate-600 mb-3\">Safa ve Merve tepeleri arasında 7 kez yürünür.</p>\n                        <div class=\"bg-teal-50 p-3 rounded-lg border-l-4 border-teal-500 text-sm italic text-teal-900\">\n                            \"Allah’ım senin rızan için Safa ile Merve arasında umre sayi yapmak istiyorum. Onu bana kolaylaştır ve kabul eyle.\"\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Step 4 -->\n                <div class=\"flex gap-4 group\">\n                    <div class=\"flex flex-col items-center\">\n                        <div class=\"w-10 h-10 rounded-full bg-slate-800 text-white flex items-center justify-center font-bold shadow-lg z-10\">4</div>\n                    </div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 flex-1 hover:shadow-xl transition-all\">\n                        <h3 class=\"text-xl font-bold text-slate-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"scissors\"></i> Tıraş ve Çıkış\n                        </h3>\n                        <p class=\"text-slate-600\">Saçlar tıraş edilir veya kısaltılır. Böylece ihramdan çıkılmış ve umre tamamlanmış olur.</p>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n\n        <!-- TAB 3: HAC VE UMRE FARKLARI -->\n        <div id=\"farklar\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"text-center mb-8\">\n                <h2 class=\"text-2xl font-bold text-slate-800\">Hac ve Umre Arasındaki Farklar</h2>\n                <p class=\"text-slate-500\">Grafik Bilgi 2.6</p>\n            </div>\n\n            <div class=\"grid md:grid-cols-2 gap-0 md:gap-8 max-w-4xl mx-auto\">\n                \n                <!-- HAC KISMI -->\n                <div class=\"bg-emerald-50 p-6 rounded-t-3xl md:rounded-3xl border-2 border-emerald-200 relative\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-emerald-600 text-white px-6 py-1 rounded-full font-bold shadow-lg\">HAC</div>\n                    \n                    <ul class=\"space-y-6 mt-4\">\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-emerald-200 p-2 rounded-lg text-emerald-800\"><i data-lucide=\"scale\"></i></div>\n                            <div>\n                                <strong class=\"block text-emerald-900\">Hükmü: FARZ</strong>\n                                <span class=\"text-sm text-slate-600\">Gücü yeten her Müslümana farzdır.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-emerald-200 p-2 rounded-lg text-emerald-800\"><i data-lucide=\"calendar\"></i></div>\n                            <div>\n                                <strong class=\"block text-emerald-900\">Zamanı: BELİRLİ</strong>\n                                <span class=\"text-sm text-slate-600\">Sadece Zilhicce ayında yapılır.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-emerald-200 p-2 rounded-lg text-emerald-800\"><i data-lucide=\"history\"></i></div>\n                            <div>\n                                <strong class=\"block text-emerald-900\">Tekrar: YILDA 1 DEFA</strong>\n                                <span class=\"text-sm text-slate-600\">Senede sadece bir kez yapılabilir.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-emerald-200 p-2 rounded-lg text-emerald-800\"><i data-lucide=\"list\"></i></div>\n                            <div>\n                                <strong class=\"block text-emerald-900\">İçerik: KAPSAMLI</strong>\n                                <span class=\"text-sm text-slate-600\">Vakfe, Şeytan Taşlama ve Kurban Kesme vardır.</span>\n                            </div>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- VS Badge for Desktop -->\n                <div class=\"hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-white rounded-full items-center justify-center font-black text-slate-300 shadow-xl border-4 border-slate-50 z-20\">VS</div>\n\n                <!-- UMRE KISMI -->\n                <div class=\"bg-blue-50 p-6 rounded-b-3xl md:rounded-3xl border-2 border-blue-200 relative mt-4 md:mt-0\">\n                    <div class=\"absolute -top-4 md:-top-4 left-1/2 -translate-x-1/2 bg-blue-500 text-white px-6 py-1 rounded-full font-bold shadow-lg z-10\">UMRE</div>\n                    \n                    <ul class=\"space-y-6 mt-4\">\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-blue-200 p-2 rounded-lg text-blue-800\"><i data-lucide=\"heart\"></i></div>\n                            <div>\n                                <strong class=\"block text-blue-900\">Hükmü: SÜNNET</strong>\n                                <span class=\"text-sm text-slate-600\">Ömürde bir kere yapmak sünnettir.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-blue-200 p-2 rounded-lg text-blue-800\"><i data-lucide=\"clock\"></i></div>\n                            <div>\n                                <strong class=\"block text-blue-900\">Zamanı: HER ZAMAN</strong>\n                                <span class=\"text-sm text-slate-600\">Hac zamanı dışında her vakit yapılabilir.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-blue-200 p-2 rounded-lg text-blue-800\"><i data-lucide=\"repeat\"></i></div>\n                            <div>\n                                <strong class=\"block text-blue-900\">Tekrar: ÇOK DEFA</strong>\n                                <span class=\"text-sm text-slate-600\">Yıl içinde birden fazla yapılabilir.</span>\n                            </div>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <div class=\"bg-blue-200 p-2 rounded-lg text-blue-800\"><i data-lucide=\"minus-circle\"></i></div>\n                            <div>\n                                <strong class=\"block text-blue-900\">İçerik: DAHA SADE</strong>\n                                <span class=\"text-sm text-slate-600\">Vakfe, Şeytan Taşlama ve Kurban Kesme <u>YOKTUR</u>.</span>\n                            </div>\n                        </li>\n                    </ul>\n                </div>\n\n            </div>\n        </div>\n\n    </main>\n\n    <footer class=\"py-8 text-center text-slate-400 text-sm mt-12 border-t border-slate-200\">\n        <p>2. Ünite: Hac ve Kurban | Grafik Bilgi 2.6 referans alınmıştır.</p>\n    </footer>\n\n    <script>\n        // İkonları oluştur\n        lucide.createIcons();\n\n        function openTab(tabName, btnElement) {\n            // İçerikleri gizle\n            const contents = document.getElementsByClassName(\"tab-content\");\n            for (let i = 0; i < contents.length; i++) {\n                contents[i].classList.remove(\"active\");\n            }\n            \n            // Buton stillerini sıfırla\n            const buttons = document.getElementsByClassName(\"tab-btn\");\n            for (let i = 0; i < buttons.length; i++) {\n                buttons[i].classList.remove(\"active\", \"bg-teal-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n                buttons[i].classList.add(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-teal-50\");\n            }\n\n            // Seçileni aç ve stillendir\n            document.getElementById(tabName).classList.add(\"active\");\n            \n            // Animasyon reflow\n            const activeContent = document.getElementById(tabName);\n            activeContent.classList.remove('animate-fade-in-up');\n            void activeContent.offsetWidth; \n            activeContent.classList.add('animate-fade-in-up');\n\n            // Aktif buton stili\n            btnElement.classList.remove(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-teal-50\");\n            btnElement.classList.add(\"active\", \"bg-teal-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n        }\n    </script>\n</body>\n</html>"
}