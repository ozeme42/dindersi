{
  "title": "1. Ahlaki Özellikleri",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Gençlik Yıllarında Peygamberimiz</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Amiri:wght@400;700&display=swap');\n        \n        body { font-family: 'Inter', sans-serif; }\n        h1, h2, h3 { font-family: 'Amiri', serif; }\n        \n        .pattern-bg {\n            background-color: #f8fafc;\n            background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23059669' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n        }\n\n        .card-hover {\n            transition: all 0.3s ease;\n        }\n        .card-hover:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);\n        }\n    </style>\n</head>\n<body class=\"pattern-bg text-slate-800 min-h-screen\">\n\n    <!-- Hero Section -->\n    <header class=\"bg-emerald-800 text-white relative overflow-hidden\">\n        <div class=\"absolute inset-0 opacity-10\">\n            <i data-lucide=\"moon\" class=\"absolute -right-10 -top-10 w-64 h-64\"></i>\n            <i data-lucide=\"stars\" class=\"absolute left-10 bottom-10 w-32 h-32\"></i>\n        </div>\n        <div class=\"max-w-5xl mx-auto px-6 py-16 relative z-10 text-center\">\n            <span class=\"bg-emerald-700 text-emerald-100 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-4 inline-block\">1. Ünite Özeti</span>\n            <h1 class=\"text-4xl md:text-6xl font-bold mb-4\">Gençlik Yıllarında Peygamberimiz</h1>\n            <p class=\"text-xl text-emerald-100 max-w-2xl mx-auto\">\n                \"Ve sen, elbette yüce bir ahlak üzeresin.\" (Kalem, 4)\n            </p>\n        </div>\n    </header>\n\n    <main class=\"max-w-5xl mx-auto px-4 py-10 space-y-12\">\n\n        <!-- 1. El-Emin Bölümü -->\n        <section class=\"grid grid-cols-1 md:grid-cols-2 gap-8 items-center\">\n            <div class=\"space-y-4\">\n                <div class=\"flex items-center gap-2 text-emerald-700 font-bold uppercase tracking-wider text-sm\">\n                    <i data-lucide=\"shield-check\" class=\"w-5 h-5\"></i>\n                    Güvenilir Muhammed\n                </div>\n                <h2 class=\"text-3xl font-bold text-slate-800\">Muhammedülemin</h2>\n                <p class=\"text-slate-600 leading-relaxed\">\n                    Mekke'de insanlar birbirlerine güvenmezken, herkes en kıymetli eşyalarını O'na emanet ederdi. O, emanete asla ihanet etmez, sözünde durur ve dürüst davranırdı. Bu sebeple henüz peygamber olmadan önce kendisine <strong>\"El-Emin\"</strong> (Güvenilir) lakabı verilmişti.\n                </p>\n                <div class=\"bg-emerald-50 border-l-4 border-emerald-600 p-4 rounded-r-lg\">\n                    <h4 class=\"font-bold text-emerald-800 mb-1\">Örnek Olay:</h4>\n                    <p class=\"text-sm text-slate-700 italic\">\n                        Abdullah bin Ebu Hamsa ile yaptığı ticarette, verdiği sözü unutmayıp buluşma yerinde 3 gün beklemesi, O'nun ahde vefasını gösterir.\n                    </p>\n                </div>\n            </div>\n            <div class=\"bg-white p-6 rounded-2xl shadow-lg border border-slate-100 relative\">\n                <div class=\"absolute -top-4 -right-4 bg-yellow-400 text-yellow-900 w-16 h-16 rounded-full flex items-center justify-center font-bold shadow-md rotate-12\">\n                    EMİN\n                </div>\n                <h3 class=\"font-bold text-lg mb-4 text-center border-b pb-2\">Ahlaki Özellikleri</h3>\n                <div class=\"grid grid-cols-2 gap-4\">\n                    <div class=\"text-center p-3 bg-slate-50 rounded-lg\">\n                        <i data-lucide=\"scale\" class=\"w-6 h-6 mx-auto text-emerald-600 mb-2\"></i>\n                        <span class=\"font-bold text-sm block\">Adaletli</span>\n                    </div>\n                    <div class=\"text-center p-3 bg-slate-50 rounded-lg\">\n                        <i data-lucide=\"heart-handshake\" class=\"w-6 h-6 mx-auto text-emerald-600 mb-2\"></i>\n                        <span class=\"font-bold text-sm block\">Yardımsever</span>\n                    </div>\n                    <div class=\"text-center p-3 bg-slate-50 rounded-lg\">\n                        <i data-lucide=\"smile\" class=\"w-6 h-6 mx-auto text-emerald-600 mb-2\"></i>\n                        <span class=\"font-bold text-sm block\">Güler Yüzlü</span>\n                    </div>\n                    <div class=\"text-center p-3 bg-slate-50 rounded-lg\">\n                        <i data-lucide=\"check-circle\" class=\"w-6 h-6 mx-auto text-emerald-600 mb-2\"></i>\n                        <span class=\"font-bold text-sm block\">Doğru Sözlü</span>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 2. Hilfülfudul (Erdemliler Birliği) -->\n        <section class=\"bg-amber-50 rounded-3xl p-8 md:p-12 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 opacity-5\">\n                <i data-lucide=\"users\" class=\"w-64 h-64\"></i>\n            </div>\n            \n            <div class=\"relative z-10\">\n                <div class=\"flex items-center gap-3 mb-4\">\n                    <span class=\"bg-amber-200 text-amber-900 p-2 rounded-lg\">\n                        <i data-lucide=\"handshake\" class=\"w-6 h-6\"></i>\n                    </span>\n                    <h2 class=\"text-3xl font-bold text-amber-900\">Hilfülfudul (Erdemliler Birliği)</h2>\n                </div>\n                \n                <p class=\"text-amber-900/80 mb-6 max-w-3xl\">\n                    Cahiliye Dönemi'nde güçsüzlerin ezilmesini önlemek amacıyla kurulan sivil toplum kuruluşudur. Hz. Muhammed (sav) gençliğinde bu birliğe katılmış ve haksızlığa uğrayanların yanında olmuştur.\n                </p>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                    <!-- Hadis Kartı -->\n                    <div class=\"bg-white p-6 rounded-xl shadow-sm border border-amber-100\">\n                        <h4 class=\"font-bold text-amber-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"message-square\" class=\"w-4 h-4\"></i> Peygamberimizin Sözü\n                        </h4>\n                        <p class=\"text-sm text-slate-600 italic\">\n                            \"Abdullah bin Cüdan’ın evinde yapılan bir antlaşmada hazır bulundum. O, benim için en kıymetli dünya mallarından bile daha değerlidir. Eğer İslam döneminde de böyle bir antlaşmaya çağrılsaydım mutlaka katılırdım.\"\n                        </p>\n                    </div>\n                    \n                    <!-- Olay Kartı -->\n                    <div class=\"bg-white p-6 rounded-xl shadow-sm border border-amber-100\">\n                        <h4 class=\"font-bold text-amber-800 mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"alert-triangle\" class=\"w-4 h-4\"></i> Bir Olay: Ebu Cehil ve Tüccar\n                        </h4>\n                        <p class=\"text-sm text-slate-600\">\n                            Zübeydli bir tüccarın malına düşük fiyat verip sattırmayan Ebu Cehil'e karşı, Hz. Muhammed (sav) tüccarın malını değerinde satın almış ve Ebu Cehil'i <strong>Hilfülfudul</strong> kurallarıyla uyarmıştır.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 3. Aile Hayatı ve Hz. Hatice -->\n        <section>\n            <h2 class=\"text-2xl font-bold text-center mb-8 flex items-center justify-center gap-2\">\n                <i data-lucide=\"home\" class=\"text-emerald-600\"></i>\n                Hz. Hatice ile Evliliği ve Ailesi\n            </h2>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                <!-- Hz. Hatice -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md card-hover border-t-4 border-rose-400\">\n                    <h3 class=\"text-xl font-bold mb-2\">Hz. Hatice</h3>\n                    <div class=\"text-xs font-bold text-rose-500 uppercase mb-4\">Müminlerin Annesi</div>\n                    <ul class=\"space-y-3 text-sm text-slate-600\">\n                        <li class=\"flex items-start gap-2\">\n                            <i data-lucide=\"star\" class=\"w-4 h-4 text-rose-400 mt-0.5\"></i>\n                            <span>Lakabı <strong>Tahire</strong> (Tertemiz) idi.</span>\n                        </li>\n                        <li class=\"flex items-start gap-2\">\n                            <i data-lucide=\"briefcase\" class=\"w-4 h-4 text-rose-400 mt-0.5\"></i>\n                            <span>Ticaretle uğraşırdı. Kervanını yönetmesi için dürüstlüğü sebebiyle Hz. Muhammed'i (sav) seçti.</span>\n                        </li>\n                        <li class=\"flex items-start gap-2\">\n                            <i data-lucide=\"heart\" class=\"w-4 h-4 text-rose-400 mt-0.5\"></i>\n                            <span>Peygamberimize ilk inanan ve O'nu malıyla destekleyen kişidir.</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Çocuklar -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md card-hover border-t-4 border-blue-400 lg:col-span-2\">\n                    <h3 class=\"text-xl font-bold mb-4\">Çocukları</h3>\n                    <p class=\"text-sm text-slate-600 mb-4\">\n                        Hz. Muhammed (sav) ve Hz. Hatice'nin 6 çocuğu olmuştur. Cahiliye adetlerinin aksine kız çocuklarına büyük değer vermiş, onlara sevgi ve şefkat göstermiştir.\n                    </p>\n                    \n                    <div class=\"grid grid-cols-2 md:grid-cols-3 gap-4\">\n                        <div class=\"bg-blue-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-blue-800\">Kasım</div>\n                            <span class=\"text-xs text-slate-500\">İlk oğlu (Vefat etti)</span>\n                        </div>\n                         <div class=\"bg-blue-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-blue-800\">Abdullah</div>\n                            <span class=\"text-xs text-slate-500\">İkinci oğlu (Vefat etti)</span>\n                        </div>\n                        <div class=\"bg-rose-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-rose-800\">Zeyneb</div>\n                            <span class=\"text-xs text-slate-500\">En büyük kızı</span>\n                        </div>\n                        <div class=\"bg-rose-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-rose-800\">Rukiye</div>\n                        </div>\n                        <div class=\"bg-rose-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-rose-800\">Ümmü Gülsüm</div>\n                        </div>\n                        <div class=\"bg-rose-50 p-3 rounded text-center\">\n                            <div class=\"font-bold text-rose-800\">Fatıma</div>\n                            <span class=\"text-xs text-slate-500\">Soyu ondan devam etti</span>\n                        </div>\n                    </div>\n                    \n                    <div class=\"mt-4 p-3 bg-slate-100 rounded text-xs text-slate-600 flex items-center gap-2\">\n                        <i data-lucide=\"info\" class=\"w-4 h-4\"></i>\n                        <span>Not: Oğlu İbrahim, Hz. Mariye'den dünyaya gelmiştir.</span>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 4. Kâbe Hakemliği -->\n        <section class=\"bg-slate-900 text-white rounded-3xl p-8 md:p-12\">\n            <div class=\"text-center mb-10\">\n                <span class=\"bg-slate-700 text-slate-300 px-3 py-1 rounded-full text-xs font-bold uppercase mb-3 inline-block\">Toplumsal Barış</span>\n                <h2 class=\"text-3xl font-bold\">Kâbe Hakemliği</h2>\n                <p class=\"text-slate-400 mt-2\">Zekası ve güvenilirliği ile bir savaşı önleyen çözüm.</p>\n            </div>\n\n            <div class=\"relative\">\n                <!-- Vertical Line -->\n                <div class=\"hidden md:block absolute left-1/2 top-0 bottom-0 w-1 bg-slate-700 -translate-x-1/2\"></div>\n\n                <!-- Step 1 -->\n                <div class=\"flex flex-col md:flex-row items-center mb-8 relative\">\n                    <div class=\"md:w-1/2 p-4 text-center md:text-right\">\n                        <h4 class=\"text-xl font-bold text-emerald-400\">Sorun</h4>\n                        <p class=\"text-sm text-slate-300 mt-2\">\n                            Kâbe tamir edilirken Hacerülesved taşını yerine kimin koyacağı konusunda kabileler arasında büyük bir kavga çıktı.\n                        </p>\n                    </div>\n                    <div class=\"absolute left-1/2 -translate-x-1/2 bg-slate-800 border-4 border-slate-900 w-10 h-10 rounded-full flex items-center justify-center z-10 hidden md:flex\">\n                        <span class=\"font-bold\">1</span>\n                    </div>\n                    <div class=\"md:w-1/2 p-4 hidden md:block\"></div>\n                </div>\n\n                <!-- Step 2 -->\n                <div class=\"flex flex-col md:flex-row items-center mb-8 relative\">\n                    <div class=\"md:w-1/2 p-4 hidden md:block\"></div>\n                    <div class=\"absolute left-1/2 -translate-x-1/2 bg-slate-800 border-4 border-slate-900 w-10 h-10 rounded-full flex items-center justify-center z-10 hidden md:flex\">\n                        <span class=\"font-bold\">2</span>\n                    </div>\n                    <div class=\"md:w-1/2 p-4 text-center md:text-left\">\n                        <h4 class=\"text-xl font-bold text-emerald-400\">Teklif</h4>\n                        <p class=\"text-sm text-slate-300 mt-2\">\n                            \"Şu kapıdan giren ilk kişi hakem olsun\" dediler. Gelen Hz. Muhammed (sav) olunca \"El-Emin geldi, razıyız!\" dediler.\n                        </p>\n                    </div>\n                </div>\n\n                <!-- Step 3 -->\n                <div class=\"flex flex-col md:flex-row items-center relative\">\n                    <div class=\"md:w-1/2 p-4 text-center md:text-right\">\n                        <h4 class=\"text-xl font-bold text-emerald-400\">Çözüm</h4>\n                        <p class=\"text-sm text-slate-300 mt-2\">\n                            Hırkasını yere serdi. Taşı ortaya koydu. Her kabile reisinin hırkanın ucundan tutmasını istedi. Taşı kendi elleriyle yerine yerleştirdi.\n                        </p>\n                    </div>\n                    <div class=\"absolute left-1/2 -translate-x-1/2 bg-emerald-600 border-4 border-slate-900 w-10 h-10 rounded-full flex items-center justify-center z-10 hidden md:flex\">\n                        <i data-lucide=\"check\" class=\"w-5 h-5\"></i>\n                    </div>\n                    <div class=\"md:w-1/2 p-4 hidden md:block\"></div>\n                </div>\n            </div>\n            \n            <div class=\"mt-8 bg-slate-800 p-4 rounded-xl text-center border border-slate-700\">\n                <p class=\"font-bold text-emerald-400\">Sonuç:</p>\n                <p class=\"text-sm text-slate-300\">\n                    Kan dökülmesi engellendi, birlik sağlandı ve Peygamberimizin zekası ile güvenilirliği bir kez daha kanıtlandı.\n                </p>\n            </div>\n        </section>\n\n    </main>\n\n    <footer class=\"bg-emerald-900 text-white text-center py-6 mt-12\">\n        <p class=\"text-sm opacity-70\">1. Ünite: Peygamber ve İlahi Kitap İnancı</p>\n    </footer>\n\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>"
}