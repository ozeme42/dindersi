{
  "title": "1. Peygamberimizin Gençlerle İletişimi",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hz. Peygamber ve Gençler İnfografiği</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\" rel=\"stylesheet\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Nunito:wght@400;600;700;800&display=swap');\n        \n        body {\n            font-family: 'Nunito', sans-serif;\n            background-color: #f0fdf4; /* Light Green background */\n        }\n        \n        .arabic-text {\n            font-family: 'Amiri', serif;\n        }\n\n        .card-hover:hover {\n            transform: translateY(-5px);\n            transition: all 0.3s ease;\n        }\n    </style>\n</head>\n<body class=\"text-gray-800\">\n\n    <!-- Header Section -->\n    <header class=\"bg-emerald-700 text-white py-8 shadow-lg relative overflow-hidden\">\n        <div class=\"absolute top-0 right-0 opacity-10 text-9xl transform rotate-12 -mr-16 -mt-10\">\n            <i class=\"fas fa-mosque\"></i>\n        </div>\n        <div class=\"container mx-auto px-4 text-center relative z-10\">\n            <h1 class=\"text-3xl md:text-5xl font-bold mb-2\">Hz. Peygamber'in Gençlerle İletişimi</h1>\n            <p class=\"text-emerald-100 text-lg md:text-xl font-light\">Sevgi, Saygı, Güven ve Sorumluluk Ekseni</p>\n        </div>\n    </header>\n\n    <main class=\"container mx-auto px-4 py-8\">\n\n        <!-- Introduction Quote -->\n        <section class=\"max-w-4xl mx-auto mb-12 text-center bg-white p-6 rounded-2xl shadow-md border-l-4 border-emerald-500\">\n            <i class=\"fas fa-quote-left text-3xl text-emerald-200 mb-2\"></i>\n            <p class=\"text-xl italic text-gray-700\">\n                \"Resulullah konuştuğunda sahabileri, başlarının üzerinde kuş varmış gibi sessiz ve dikkatli bir şekilde onu dinlerlerdi.\"\n            </p>\n            <footer class=\"mt-4 font-bold text-emerald-700\">- Üsame bin Şerîk (ra)</footer>\n        </section>\n\n        <!-- Main Pillars Grid -->\n        <h2 class=\"text-3xl font-bold text-center text-emerald-800 mb-8\">İletişimin 4 Temel İlkesi</h2>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12\">\n            \n            <!-- Pillar 1: Merhamet -->\n            <div class=\"bg-white rounded-xl shadow-lg overflow-hidden card-hover\">\n                <div class=\"bg-amber-100 p-4 flex justify-center items-center h-24\">\n                    <i class=\"fas fa-heart text-4xl text-amber-500\"></i>\n                </div>\n                <div class=\"p-6\">\n                    <h3 class=\"font-bold text-xl mb-2 text-gray-800\">Sevgi ve Merhamet</h3>\n                    <p class=\"text-sm text-gray-600 mb-4\">Hatalara karşı yapıcı olmak ve affedici yaklaşmak.</p>\n                    <div class=\"bg-gray-50 p-3 rounded text-xs border border-gray-200\">\n                        <span class=\"font-bold block text-emerald-600 mb-1\">Örnek:</span>\n                        Uhud Savaşı'nda kendisine zarar verenlere bile beddua etmeyip, \"Allah'ım kavmimi affet, onlar bilmiyorlar\" diyerek dua etmiştir.\n                    </div>\n                </div>\n            </div>\n\n            <!-- Pillar 2: İstişare -->\n            <div class=\"bg-white rounded-xl shadow-lg overflow-hidden card-hover\">\n                <div class=\"bg-blue-100 p-4 flex justify-center items-center h-24\">\n                    <i class=\"fas fa-comments text-4xl text-blue-500\"></i>\n                </div>\n                <div class=\"p-6\">\n                    <h3 class=\"font-bold text-xl mb-2 text-gray-800\">İstişare (Danışma)</h3>\n                    <p class=\"text-sm text-gray-600 mb-4\">Gençlerin fikirlerine değer vermek ve kararlara ortak etmek.</p>\n                    <div class=\"bg-gray-50 p-3 rounded text-xs border border-gray-200\">\n                        <span class=\"font-bold block text-emerald-600 mb-1\">Örnek:</span>\n                        Bedir Savaşı'nda ordunun konumu hakkında genç bir sahabi olan Hubab bin Münzir'in stratejik önerisini uygulamıştır.\n                    </div>\n                </div>\n            </div>\n\n            <!-- Pillar 3: Hoşgörü -->\n            <div class=\"bg-white rounded-xl shadow-lg overflow-hidden card-hover\">\n                <div class=\"bg-purple-100 p-4 flex justify-center items-center h-24\">\n                    <i class=\"fas fa-hands-helping text-4xl text-purple-500\"></i>\n                </div>\n                <div class=\"p-6\">\n                    <h3 class=\"font-bold text-xl mb-2 text-gray-800\">Nezaket ve Hoşgörü</h3>\n                    <p class=\"text-sm text-gray-600 mb-4\">Kırmadan, incitmeden eğitmek ve eğitici olmak.</p>\n                    <div class=\"bg-gray-50 p-3 rounded text-xs border border-gray-200\">\n                        <span class=\"font-bold block text-emerald-600 mb-1\">Örnek:</span>\n                        10 yıl hizmetinde bulunan Enes bin Malik'e bir kez bile \"Öf\" dememiş, \"Bunu niye yaptın?\" diye azarlamamıştır.\n                    </div>\n                </div>\n            </div>\n\n            <!-- Pillar 4: Sorumluluk -->\n            <div class=\"bg-white rounded-xl shadow-lg overflow-hidden card-hover\">\n                <div class=\"bg-rose-100 p-4 flex justify-center items-center h-24\">\n                    <i class=\"fas fa-award text-4xl text-rose-500\"></i>\n                </div>\n                <div class=\"p-6\">\n                    <h3 class=\"font-bold text-xl mb-2 text-gray-800\">Sorumluluk Verme</h3>\n                    <p class=\"text-sm text-gray-600 mb-4\">Gençlerin yeteneklerini keşfedip onları görevlendirmek.</p>\n                    <div class=\"bg-gray-50 p-3 rounded text-xs border border-gray-200\">\n                        <span class=\"font-bold block text-emerald-600 mb-1\">Örnek:</span>\n                        Genç sahabi Muaz bin Cebel'i (ra), Yemen'e yönetici (kadı) ve öğretmen olarak göndermiş, ona güvenmiştir.\n                    </div>\n                </div>\n            </div>\n\n        </div>\n\n        <!-- Spotlight Section: Ebu Mahzure Story -->\n        <section class=\"bg-white rounded-2xl shadow-xl overflow-hidden mb-12\">\n            <div class=\"md:flex\">\n                <div class=\"md:w-1/3 bg-emerald-600 p-8 text-white flex flex-col justify-center items-center text-center\">\n                    <i class=\"fas fa-microphone-alt text-6xl mb-4 text-emerald-200\"></i>\n                    <h3 class=\"text-2xl font-bold\">Kriz Yönetimi ve Kazanım</h3>\n                    <p class=\"mt-2 text-emerald-100\">Ebu Mahzure Olayı</p>\n                </div>\n                <div class=\"md:w-2/3 p-8\">\n                    <h4 class=\"text-xl font-bold text-gray-800 mb-3\">Olayın Özeti:</h4>\n                    <p class=\"text-gray-600 mb-4\">\n                        Mekke fethi sonrası Ebu Mahzure ve arkadaşları ezanla alay ederler. Sahabiler kızar ancak Hz. Peygamber durumu fark eder.\n                    </p>\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                        <div class=\"border-l-4 border-amber-500 pl-4\">\n                            <h5 class=\"font-bold text-gray-800\">Hz. Peygamber'in Tepkisi</h5>\n                            <p class=\"text-sm text-gray-600\">Kızmadı, cezalandırmadı. Ebu Mahzure'nin sesinin güzelliğini fark etti ve ona ezan okutturdu.</p>\n                        </div>\n                        <div class=\"border-l-4 border-emerald-500 pl-4\">\n                            <h5 class=\"font-bold text-gray-800\">Sonuç</h5>\n                            <p class=\"text-sm text-gray-600\">Ebu Mahzure'nin kalbi İslam'a ısındı, Müslüman oldu ve Mekke'ye müezzin olarak atandı.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Practical Application -->\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-2xl font-bold text-center text-emerald-800 mb-6\">Gençler İçin Dersler: Hata ve Telafi</h2>\n            <div class=\"bg-gradient-to-r from-emerald-50 to-teal-50 rounded-xl p-6 border border-emerald-100\">\n                <div class=\"flex flex-col md:flex-row items-center gap-6\">\n                    <div class=\"flex-1\">\n                        <ul class=\"space-y-4\">\n                            <li class=\"flex items-start\">\n                                <i class=\"fas fa-check-circle text-emerald-500 mt-1 mr-3\"></i>\n                                <span><strong>Dürüstlük:</strong> Kab bin Malik (ra) sefere katılmadığında bahane uydurmadı, dürüst oldu ve tövbesi kabul edildi.</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <i class=\"fas fa-check-circle text-emerald-500 mt-1 mr-3\"></i>\n                                <span><strong>Özür Dilemek:</strong> Ebu Zer (ra), Bilal Habeşi'yi (ra) incittiğinde hatasını anlayıp hemen özür diledi.</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <i class=\"fas fa-check-circle text-emerald-500 mt-1 mr-3\"></i>\n                                <span><strong>Kötülüğü İyilikle Silmek:</strong> \"Yaptığın kötülüğün ardından bir iyilik yap ki onu yok etsin.\" (Hadis-i Şerif)</span>\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"w-full md:w-1/3 bg-white p-4 rounded-lg shadow-sm text-center\">\n                        <h4 class=\"font-bold text-emerald-700 mb-2\">Anahtar Kavram</h4>\n                        <div class=\"text-4xl font-bold text-gray-800 mb-1\">RAHMET</div>\n                        <p class=\"text-xs text-gray-500 uppercase tracking-wider\">Merhamet Etmek, Sevmek, Şefkat Göstermek</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n    </main>\n\n    <footer class=\"bg-emerald-800 text-white py-6 mt-12 text-center\">\n        <p class=\"opacity-80\">9. Sınıf / 2. Ünite: Peygamberimizin Gençlerle İletişimi</p>\n        <p class=\"text-xs mt-2 opacity-60\">Bu infografik ders materyali olarak hazırlanmıştır.</p>\n    </footer>\n\n</body>\n</html>"
}