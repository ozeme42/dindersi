{
  "title": "6.Bir Ayet Tanıyorum: Enam Suresi 162. Ayet ve Anlamı",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bir Ayet Tanıyorum: Enam Suresi 162. Ayet</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Amiri:ital,wght@0,400;0,700;1,400&family=Noto+Naskh+Arabic:wght@400;700&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        body { font-family: 'Inter', sans-serif; }\n        .font-arabic { font-family: 'Noto Naskh Arabic', serif; line-height: 2; }\n        \n        /* Animasyonlar */\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-fade-in-up {\n            animation: fadeInUp 0.5s ease-out forwards;\n        }\n\n        /* Sekme Yönetimi */\n        .tab-content { display: none; }\n        .tab-content.active { display: block; }\n        \n        /* Scrollbar Gizleme */\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        /* Custom Gradients */\n        .bg-islamic {\n            background: radial-gradient(circle at center, #0f766e 0%, #042f2e 100%);\n        }\n    </style>\n</head>\n<body class=\"min-h-screen bg-slate-50 text-slate-800 selection:bg-teal-200\">\n\n    <!-- Header Section -->\n    <header class=\"bg-islamic text-white py-12 px-4 shadow-xl relative overflow-hidden\">\n        <div class=\"absolute inset-0 opacity-10\" style=\"background-image: url('data:image/svg+xml,%3Csvg width=\\'60\\' height=\\'60\\' viewBox=\\'0 0 60 60\\' xmlns=\\'http://www.w3.org/2000/svg\\'%3E%3Cg fill=\\'none\\' fill-rule=\\'evenodd\\'%3E%3Cg fill=\\'%23ffffff\\' fill-opacity=\\'1\\'%3E%3Cpath d=\\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');\"></div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <div class=\"inline-flex items-center gap-2 bg-white/10 px-4 py-1 rounded-full text-teal-100 text-sm font-semibold mb-4 border border-white/20\">\n                <i data-lucide=\"book-open\" size=\"14\"></i> BİR AYET TANIYORUM\n            </div>\n            <h1 class=\"text-4xl md:text-5xl font-bold mb-3 tracking-wide font-arabic\">Enam Suresi 162. Ayet</h1>\n            <p class=\"text-teal-100/90 text-lg font-light max-w-2xl mx-auto\">\"Benim namazım, ibadetim, hayatım ve ölümüm...\"</p>\n        </div>\n    </header>\n\n    <!-- Navigation Tabs -->\n    <div class=\"sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm border-b border-teal-100\">\n        <div class=\"max-w-5xl mx-auto flex overflow-x-auto justify-start md:justify-center p-2 gap-2 md:gap-4 no-scrollbar\">\n            <button onclick=\"openTab('ayet', this)\" class=\"tab-btn active flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-bold bg-teal-700 text-white shadow-md transition-all whitespace-nowrap\">\n                <i data-lucide=\"scroll-text\"></i> Ayet ve Anlamı\n            </button>\n            <button onclick=\"openTab('kavramlar', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"library\"></i> Kavramlar\n            </button>\n            <button onclick=\"openTab('hadis', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"message-circle\"></i> Hadis-i Şerif\n            </button>\n            <button onclick=\"openTab('pusulam', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"compass\"></i> Pusulam\n            </button>\n        </div>\n    </div>\n\n    <main class=\"max-w-4xl mx-auto p-4 md:p-8 min-h-[600px]\">\n\n        <!-- TAB 1: AYET VE ANLAMI -->\n        <div id=\"ayet\" class=\"tab-content active animate-fade-in-up\">\n            <div class=\"bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100\">\n                <!-- Arapça Metin -->\n                <div class=\"bg-teal-50 p-8 md:p-12 text-center border-b border-teal-100 relative\">\n                    <div class=\"absolute top-4 left-4 opacity-10\"><i data-lucide=\"quote\" size=\"48\"></i></div>\n                    <div class=\"absolute bottom-4 right-4 opacity-10 rotate-180\"><i data-lucide=\"quote\" size=\"48\"></i></div>\n                    \n                    <p class=\"text-3xl md:text-5xl font-arabic text-teal-900 leading-loose mb-6 dir-rtl\">\n                        قُلْ اِنَّ صَلَات۪ي وَنُسُك۪ي وَمَحْيَايَ وَمَمَات۪ي لِلّٰهِ رَبِّ الْعَالَم۪ينَۙ\n                    </p>\n                </div>\n\n                <!-- Okunuş ve Meal -->\n                <div class=\"p-8 md:p-10 space-y-8\">\n                    <div>\n                        <h3 class=\"text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"mic\"></i> Okunuşu\n                        </h3>\n                        <p class=\"text-xl md:text-2xl text-slate-700 font-serif italic\">\n                            \"Gul inne salâtî ve nüsükî ve mahyâye ve memâtî lillâhi Rabbil âlemîn.\"\n                        </p>\n                    </div>\n                    \n                    <div class=\"bg-amber-50 p-6 rounded-xl border-l-4 border-amber-400\">\n                        <h3 class=\"text-xs font-bold text-amber-600 uppercase tracking-widest mb-2 flex items-center gap-2\">\n                            <i data-lucide=\"book\"></i> Anlamı\n                        </h3>\n                        <p class=\"text-lg md:text-xl text-amber-900 font-medium\">\n                            De ki: “Benim namazım, (her türlü) ibadetim, hayatım ve ölümüm, hepsi âlemlerin Rabbi olan Allah (cc) içindir.″\n                        </p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"mt-6 text-center text-slate-500 text-sm\">\n                <i data-lucide=\"headphones\" class=\"inline-block mr-1 align-text-bottom\"></i> \n                Kitaptaki karekoddan ayetin okunuşunu dinleyebilirsiniz.\n            </div>\n        </div>\n\n        <!-- TAB 2: KAVRAMLAR -->\n        <div id=\"kavramlar\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"text-center mb-8\">\n                <h2 class=\"text-2xl font-bold text-slate-800\">Kur'an'dan Kavramlar</h2>\n                <p class=\"text-slate-500\">Ayette geçen önemli kelimeler</p>\n            </div>\n\n            <div class=\"grid md:grid-cols-2 gap-6\">\n                <!-- Enam Kartı -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-t-4 border-teal-600 hover:shadow-xl transition-all group\">\n                    <div class=\"w-14 h-14 bg-teal-100 rounded-full flex items-center justify-center text-teal-700 mb-4 group-hover:bg-teal-600 group-hover:text-white transition-colors\">\n                        <i data-lucide=\"dog\" size=\"28\"></i> <!-- Using dog as placeholder for animal/cattle, lucide doesn't have cow -->\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-teal-900 mb-2\">Enam</h3>\n                    <p class=\"text-slate-600 leading-relaxed\">\n                        Sureye ismini veren bu kelime; <span class=\"font-semibold text-teal-700\">koyun, deve, sığır</span> gibi evcil hayvanlara (kurbanlık hayvanlara) karşılık gelir.\n                    </p>\n                </div>\n\n                <!-- Nüsük Kartı -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-t-4 border-teal-600 hover:shadow-xl transition-all group\">\n                    <div class=\"w-14 h-14 bg-teal-100 rounded-full flex items-center justify-center text-teal-700 mb-4 group-hover:bg-teal-600 group-hover:text-white transition-colors\">\n                        <i data-lucide=\"hands-praying\" size=\"28\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-teal-900 mb-2\">Nüsük</h3>\n                    <p class=\"text-slate-600 leading-relaxed\">\n                        Bu ifade, genel olarak <span class=\"font-semibold text-teal-700\">tüm ibadetlere</span>, özelde ise hac ve <span class=\"font-semibold text-teal-700\">kurban ibadetine</span> işaret eder.\n                    </p>\n                    <div class=\"mt-4 text-xs text-slate-400 text-right\">(Kur’an Yolu Meâli, C 2, ss. 368, 496.)</div>\n                </div>\n            </div>\n\n            <!-- Tevhit Vurgusu -->\n            <div class=\"mt-8 bg-blue-50 p-6 rounded-2xl border border-blue-200 flex items-start gap-4\">\n                <i data-lucide=\"info\" class=\"text-blue-600 shrink-0 mt-1\"></i>\n                <div>\n                    <h4 class=\"font-bold text-blue-900\">Temel Mesaj: Tevhit</h4>\n                    <p class=\"text-blue-800 text-sm\">\n                        Hz. Âdem’den Hz. Muhammed’e (sav) kadar tüm peygamberler, gönderildikleri topluma tevhit inancını tebliğ etmişlerdir. Tevhit, Allah’ın (cc) bir ve tek olması demektir.\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 3: BİR DEMET GÜL (HADİS) -->\n        <div id=\"hadis\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"bg-amber-50 rounded-3xl p-8 border border-amber-200 relative\">\n                <div class=\"absolute top-0 right-0 bg-amber-200 text-amber-900 px-4 py-2 rounded-bl-2xl font-bold text-sm\">Bir Demet Gül</div>\n                \n                <h3 class=\"text-2xl font-bold text-amber-900 mb-6 flex items-center gap-2\">\n                    <i data-lucide=\"scroll\"></i> Hz. Peygamber'in Duası\n                </h3>\n\n                <div class=\"prose prose-amber text-slate-700 mb-6\">\n                    <p class=\"font-medium italic text-lg mb-4\">\n                        Câbir b. Abdullah anlatıyor: Resulullah (sav) bir bayram günü kurban olarak iki koç kesti ve onları kıbleye doğru yatırdığı zaman şöyle dedi:\n                    </p>\n                    <div class=\"bg-white p-6 rounded-xl shadow-sm border-l-4 border-amber-500\">\n                        <p class=\"mb-2\">\n                            “Ben hanif (hakka yönelmiş) olarak yüzümü gökleri ve yeri yaratana çevirdim, ben müşriklerden değilim. Şüphesiz benim namazım, kurbanım, hayatım ve ölümüm âlemlerin Rabbi olan Allah içindir. O’nun hiçbir ortağı yoktur. Ben bununla emrolundum ve ben Müslümanların ilkiyim...\"\n                        </p>\n                        <p class=\"text-right font-bold text-amber-700 text-sm mt-2\">\n                            (Ebu Davud, Dahâyâ, 3-4.)\n                        </p>\n                    </div>\n                </div>\n\n                <div class=\"grid md:grid-cols-2 gap-4\">\n                    <div class=\"bg-white/60 p-4 rounded-lg flex items-center gap-3\">\n                        <div class=\"bg-amber-200 p-2 rounded-full\"><i data-lucide=\"x-circle\" class=\"text-amber-800\" size=\"16\"></i></div>\n                        <p class=\"text-sm font-medium\">Putlara tapmayın</p>\n                    </div>\n                    <div class=\"bg-white/60 p-4 rounded-lg flex items-center gap-3\">\n                        <div class=\"bg-amber-200 p-2 rounded-full\"><i data-lucide=\"check-circle\" class=\"text-amber-800\" size=\"16\"></i></div>\n                        <p class=\"text-sm font-medium\">İbadeti sadece Allah'a yapın</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 4: PUSULAM (İLKELER) -->\n        <div id=\"pusulam\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"bg-slate-900 text-white rounded-3xl p-8 shadow-2xl relative overflow-hidden\">\n                <div class=\"absolute top-0 right-0 p-8 opacity-5\">\n                    <i data-lucide=\"compass\" size=\"200\"></i>\n                </div>\n\n                <h2 class=\"text-3xl font-bold text-teal-400 mb-2\">Pusulam</h2>\n                <p class=\"text-slate-400 mb-8\">Bu ayetten hayatıma hangi ilkeleri katmalıyım?</p>\n\n                <div class=\"space-y-6 relative z-10\">\n                    <!-- İlke 1 -->\n                    <div class=\"flex gap-4 items-start group\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center font-bold text-lg shrink-0 group-hover:scale-110 transition-transform\">1</div>\n                        <div>\n                            <h3 class=\"text-xl font-bold text-teal-100\">Âlemlerin Rabbi Allah’tır (cc).</h3>\n                            <p class=\"text-slate-300 text-sm mt-1\">Her şeyi yaratan ve yöneten O'dur.</p>\n                        </div>\n                    </div>\n\n                    <!-- İlke 2 -->\n                    <div class=\"flex gap-4 items-start group\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center font-bold text-lg shrink-0 group-hover:scale-110 transition-transform\">2</div>\n                        <div>\n                            <h3 class=\"text-xl font-bold text-teal-100\">Allah (cc) bir ve tektir.</h3>\n                            <p class=\"text-slate-300 text-sm mt-1\">O'ndan başka ilah yoktur (Tevhit).</p>\n                        </div>\n                    </div>\n\n                    <!-- İlke 3 -->\n                    <div class=\"flex gap-4 items-start group\">\n                        <div class=\"w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center font-bold text-lg shrink-0 group-hover:scale-110 transition-transform\">3</div>\n                        <div>\n                            <h3 class=\"text-xl font-bold text-teal-100\">Sadece Allah’a (cc) kulluk edilmelidir.</h3>\n                            <p class=\"text-slate-300 text-sm mt-1\">Hac, namaz, kurban ve tüm yaşam O'nun rızası içindir.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"mt-8 pt-8 border-t border-slate-700\">\n                    <h4 class=\"font-bold text-amber-400 mb-3 flex items-center gap-2\">\n                        <i data-lucide=\"lightbulb\"></i> Günlük Hayatta Uygulama\n                    </h4>\n                    <p class=\"text-slate-300 italic leading-relaxed\">\n                        \"Bir kul, namazını kılarken, haccedip kurbanını keserken ve diğer tüm ibadetlerinde sadece Allah (cc) rızasını gözetmelidir. Her şeyi yoktan var edenin Allah (cc) olduğunu bilip O’ndan başkasına kulluk etmemelidir.\"\n                    </p>\n                </div>\n            </div>\n        </div>\n\n    </main>\n\n    <footer class=\"py-8 text-center text-slate-400 text-sm mt-12 border-t border-slate-200\">\n        <p>2. Ünite: Hac ve Kurban | Enam Suresi 162. Ayet Kaynağı</p>\n    </footer>\n\n    <script>\n        // İkonları oluştur\n        lucide.createIcons();\n\n        function openTab(tabName, btnElement) {\n            // İçerikleri gizle\n            const contents = document.getElementsByClassName(\"tab-content\");\n            for (let i = 0; i < contents.length; i++) {\n                contents[i].classList.remove(\"active\");\n            }\n            \n            // Buton stillerini sıfırla\n            const buttons = document.getElementsByClassName(\"tab-btn\");\n            for (let i = 0; i < buttons.length; i++) {\n                buttons[i].classList.remove(\"active\", \"bg-teal-700\", \"text-white\", \"shadow-md\");\n                buttons[i].classList.add(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-teal-50\");\n            }\n\n            // Seçileni aç ve stillendir\n            document.getElementById(tabName).classList.add(\"active\");\n            \n            // Animasyon reflow\n            const activeContent = document.getElementById(tabName);\n            activeContent.classList.remove('animate-fade-in-up');\n            void activeContent.offsetWidth; \n            activeContent.classList.add('animate-fade-in-up');\n\n            // Aktif buton stili\n            btnElement.classList.remove(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-teal-50\");\n            btnElement.classList.add(\"active\", \"bg-teal-700\", \"text-white\", \"shadow-md\");\n        }\n    </script>\n</body>\n</html>"
}