{
  "title": "1.İslam'da Hac İbadeti ve Önemi",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hac ve Kurban - İnfografik</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Merriweather:ital,wght@1,300;1,700&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n        }\n        .serif-italic {\n            font-family: 'Merriweather', serif;\n            font-style: italic;\n        }\n        \n        /* Animasyonlar */\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-fade-in-up {\n            animation: fadeInUp 0.5s ease-out forwards;\n        }\n\n        /* Sekme İçerik Gizleme/Gösterme */\n        .tab-content {\n            display: none;\n        }\n        .tab-content.active {\n            display: block;\n        }\n\n        /* Aktif Buton Stili */\n        .tab-btn.active {\n            background-color: #059669; /* emerald-600 */\n            color: white;\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n            transform: scale(1.05);\n        }\n        .tab-btn {\n            transition: all 0.3s ease;\n        }\n    </style>\n</head>\n<body class=\"min-h-screen bg-emerald-50 text-slate-800 selection:bg-emerald-200\">\n\n    <!-- Header Section -->\n    <header class=\"bg-emerald-900 text-white py-12 px-4 relative overflow-hidden\">\n        <!-- Background Pattern -->\n        <div class=\"absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none\">\n            <svg width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\">\n                <defs>\n                    <pattern id=\"pattern\" x=\"0\" y=\"0\" width=\"40\" height=\"40\" patternUnits=\"userSpaceOnUse\">\n                        <circle cx=\"20\" cy=\"20\" r=\"2\" fill=\"#fff\" />\n                    </pattern>\n                </defs>\n                <rect width=\"100%\" height=\"100%\" fill=\"url(#pattern)\" />\n            </svg>\n        </div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <h1 class=\"text-4xl md:text-6xl font-bold mb-4 tracking-tight\">HAC VE KURBAN</h1>\n            <p class=\"text-emerald-200 text-xl font-light italic\">\"Hac, Müslümanları bir araya getirir.\"</p>\n            <div class=\"mt-8 inline-block bg-emerald-800/50 backdrop-blur-sm p-4 rounded-xl border border-emerald-700 max-w-2xl\">\n                <p class=\"text-sm md:text-base leading-relaxed\">\n                    <span class=\"font-bold text-amber-400\">Hadis-i Şerif:</span> “İslam, beş esas üzerine kurulmuştur: Allah’tan başka ilah olmadığına ve Muhammed’in Allah’ın resulü olduğuna şahitlik etmek, namazı dosdoğru kılmak, zekât vermek, Kâbe’yi haccetmek ve ramazan orucunu tutmak.”\n                    <br/><span class=\"text-xs text-emerald-400 mt-2 block\">(Müslim, İman, 21.)</span>\n                </p>\n            </div>\n        </div>\n    </header>\n\n    <!-- Navigation Tabs -->\n    <div class=\"sticky top-0 z-50 bg-white/90 backdrop-blur shadow-sm border-b border-emerald-100\">\n        <div class=\"max-w-5xl mx-auto flex overflow-x-auto justify-center p-2 gap-2 md:gap-4 no-scrollbar\">\n            <button onclick=\"openTab('sartlar', this)\" class=\"tab-btn active flex items-center gap-2 px-4 py-3 rounded-full text-sm font-semibold bg-emerald-600 text-white shadow-md transform scale-105 whitespace-nowrap\">\n                <i data-lucide=\"book-open\" width=\"18\"></i> Haccın Şartları\n            </button>\n            <button onclick=\"openTab('bireysel', this)\" class=\"tab-btn flex items-center gap-2 px-4 py-3 rounded-full text-sm font-semibold bg-slate-100 text-slate-600 hover:bg-emerald-100 whitespace-nowrap\">\n                <i data-lucide=\"smile\" width=\"18\"></i> Bireysel Faydalar\n            </button>\n            <button onclick=\"openTab('toplumsal', this)\" class=\"tab-btn flex items-center gap-2 px-4 py-3 rounded-full text-sm font-semibold bg-slate-100 text-slate-600 hover:bg-emerald-100 whitespace-nowrap\">\n                <i data-lucide=\"users\" width=\"18\"></i> Toplumsal Faydalar\n            </button>\n            <button onclick=\"openTab('malcolm', this)\" class=\"tab-btn flex items-center gap-2 px-4 py-3 rounded-full text-sm font-semibold bg-slate-100 text-slate-600 hover:bg-emerald-100 whitespace-nowrap\">\n                <i data-lucide=\"globe\" width=\"18\"></i> Geçmişin İzinde\n            </button>\n        </div>\n    </div>\n\n    <main class=\"max-w-5xl mx-auto p-4 md:p-8 space-y-12 min-h-[600px]\">\n\n        <!-- SECTION: HACCIN ŞARTLARI -->\n        <div id=\"sartlar\" class=\"tab-content active animate-fade-in-up\">\n            <div class=\"text-center mb-10\">\n                <h2 class=\"text-3xl font-bold text-emerald-900 mb-4\">Kimlere Farzdır?</h2>\n                <p class=\"text-slate-600 max-w-2xl mx-auto\">Müslümanların ömründe bir defa haccetmeleri farzdır. Ancak kişinin bu ibadeti yerine getirebilmesi için aşağıdaki 6 şartı taşıması gerekir.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6\">\n                <!-- Card 1 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"user\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Müslüman Olmak</h3>\n                    <p class=\"text-slate-500 text-sm\">Hac ibadeti sadece Müslümanlara farzdır.</p>\n                </div>\n                <!-- Card 2 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"brain\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Akıl ve Ergenlik</h3>\n                    <p class=\"text-slate-500 text-sm\">Akıllı olmak ve ergenlik çağına girmiş bulunmak.</p>\n                </div>\n                <!-- Card 3 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"wallet\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Maddi İmkan</h3>\n                    <p class=\"text-slate-500 text-sm\">Belli derecede maddi imkâna sahip olmak.</p>\n                </div>\n                <!-- Card 4 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"heart-pulse\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Sağlıklı Olmak</h3>\n                    <p class=\"text-slate-500 text-sm\">Yolculuğa ve ibadete engel hastalığı bulunmamak.</p>\n                </div>\n                <!-- Card 5 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"shield-check\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Yol Güvenliği</h3>\n                    <p class=\"text-slate-500 text-sm\">Gidilecek yolun güvenli olması.</p>\n                </div>\n                <!-- Card 6 -->\n                <div class=\"bg-white p-6 rounded-2xl shadow-lg border-b-4 border-emerald-500 hover:shadow-xl transition-shadow flex flex-col items-center text-center group\">\n                    <div class=\"w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300\">\n                        <i data-lucide=\"lock-open\" width=\"40\" height=\"40\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Özgür Olmak</h3>\n                    <p class=\"text-slate-500 text-sm\">Kişinin hürriyetinin kısıtlanmamış olması.</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- SECTION: BİREYSEL FAYDALAR -->\n        <div id=\"bireysel\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"bg-white rounded-3xl overflow-hidden shadow-xl flex flex-col md:flex-row mb-8\">\n                <div class=\"md:w-1/3 bg-emerald-800 p-8 flex flex-col justify-center text-white\">\n                    <h3 class=\"text-3xl font-bold mb-4\">Manevi Bir Eğitim</h3>\n                    <p class=\"opacity-90\">Hac yolculuğu, sadece bedenen yapılan bir yolculuk değil, ruhun olgunlaşma sürecidir.</p>\n                </div>\n                <div class=\"md:w-2/3 p-8 bg-white grid grid-cols-1 gap-6\">\n                    <div class=\"flex gap-4 items-start\">\n                        <div class=\"bg-amber-100 p-3 rounded-lg text-amber-600 flex-shrink-0 mt-1\">\n                            <i data-lucide=\"smile\"></i>\n                        </div>\n                        <div>\n                            <h4 class=\"font-bold text-lg text-emerald-900\">Tevhit Mücadelesini Hatırlamak</h4>\n                            <p class=\"text-slate-600 text-sm\">Hz. Peygamber’in ve müminlerin yaşadıklarını hatırlar, o atmosferde olgunlaşır.</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-4 items-start\">\n                        <div class=\"bg-amber-100 p-3 rounded-lg text-amber-600 flex-shrink-0 mt-1\">\n                            <i data-lucide=\"shield-check\"></i>\n                        </div>\n                        <div>\n                            <h4 class=\"font-bold text-lg text-emerald-900\">Sabır ve Tevekkül</h4>\n                            <p class=\"text-slate-600 text-sm\">Sıkıntılar karşısında isyan etmek yerine Allah’a tevekkül etmeyi öğrenir.</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-4 items-start\">\n                        <div class=\"bg-amber-100 p-3 rounded-lg text-amber-600 flex-shrink-0 mt-1\">\n                            <i data-lucide=\"heart-pulse\"></i>\n                        </div>\n                        <div>\n                            <h4 class=\"font-bold text-lg text-emerald-900\">Mahşer Bilinci</h4>\n                            <p class=\"text-slate-600 text-sm\">İhram kıyafeti ve Arafat'taki bekleyiş, kişiye öldükten sonra dirilmeyi ve mahşer meydanını hatırlatır.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"bg-amber-50 border-l-8 border-amber-400 p-6 rounded-r-xl shadow-sm\">\n                <h4 class=\"text-amber-800 font-bold text-lg mb-2 flex items-center gap-2\">\n                    <i data-lucide=\"quote\" width=\"20\"></i>\n                    Müjde: Yeniden Doğuş\n                </h4>\n                <p class=\"italic text-slate-700 mb-2\">\n                    “Kim Allah için hacceder de kötü söz ve davranışlardan ve Allah’a karşı gelmekten sakınırsa \n                    <span class=\"font-bold text-emerald-700 bg-emerald-100 px-1 mx-1 rounded\">annesinden doğduğu günkü gibi</span> \n                    günahlarından arınmış olarak döner.”\n                </p>\n                <div class=\"text-right text-xs font-bold text-amber-700\">(Buhari, Hac, 4.)</div>\n            </div>\n        </div>\n\n        <!-- SECTION: TOPLUMSAL FAYDALAR -->\n        <div id=\"toplumsal\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"grid md:grid-cols-2 gap-8 items-center\">\n                <div>\n                    <h2 class=\"text-3xl font-bold text-emerald-900 mb-6\">\"Ben\" Değil, \"Biz\" Olmak</h2>\n                    <div class=\"space-y-4\">\n                        <div class=\"bg-white p-5 rounded-xl shadow border border-slate-100\">\n                            <h4 class=\"font-bold text-emerald-700 mb-2\">Eşitlik ve Kardeşlik</h4>\n                            <p class=\"text-slate-600 text-sm\">Makam, dil, ırk ve renk farkı gözetmeksizin herkes aynı ihram kıyafetiyle Allah’a yönelir. Bu durum mutlak eşitliği simgeler.</p>\n                        </div>\n                        <div class=\"bg-white p-5 rounded-xl shadow border border-slate-100\">\n                            <h4 class=\"font-bold text-emerald-700 mb-2\">Kültürel Kaynaşma</h4>\n                            <p class=\"text-slate-600 text-sm\">Dünyanın dört bir yanından gelen Müslümanlar tanışır, kültür alışverişinde bulunur ve birbirlerinin dertleriyle dertlenir.</p>\n                        </div>\n                        <div class=\"bg-white p-5 rounded-xl shadow border border-slate-100\">\n                            <h4 class=\"font-bold text-emerald-700 mb-2\">Ahlaki Güzellik</h4>\n                            <p class=\"text-slate-600 text-sm\">Hac; sabrı güçlendirir, incitmeme duygusunu geliştirir. Kibir ve gösteriş yerine alçak gönüllülük hakim olur.</p>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"bg-emerald-100 rounded-full aspect-square flex flex-col items-center justify-center p-8 text-center relative overflow-hidden shadow-inner\">\n                    <div class=\"absolute inset-0 bg-emerald-600/10 rounded-full animate-pulse\"></div>\n                    <i data-lucide=\"users\" width=\"80\" height=\"80\" class=\"text-emerald-600 mb-4 relative z-10\"></i>\n                    <h3 class=\"text-2xl font-bold text-emerald-800 relative z-10\">Evrensel Birlik</h3>\n                    <p class=\"text-emerald-700 mt-2 text-sm relative z-10\">Milyonlarca insan, tek bir amaç için, tek bir yöne...</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- SECTION: MALCOLM X -->\n        <div id=\"malcolm\" class=\"tab-content animate-fade-in-up\">\n             <div class=\"bg-slate-900 text-white rounded-3xl p-8 md:p-12 shadow-2xl relative overflow-hidden\">\n                <div class=\"absolute top-0 right-0 p-8 opacity-10\">\n                   <i data-lucide=\"quote\" width=\"120\" height=\"120\"></i>\n                </div>\n                \n                <h2 class=\"text-3xl font-bold text-amber-400 mb-8 border-b border-slate-700 pb-4 inline-block\">Geçmişin İzinde: Malcolm X</h2>\n                \n                <div class=\"flex flex-col md:flex-row gap-8\">\n                  <div class=\"md:w-3/4\">\n                    <p class=\"text-lg md:text-xl leading-relaxed serif-italic text-slate-300\">\n                      “Hacca gitmek, görüş açımı alabildiğine genişletmiştir: Bu gezi, yeni bir anlayış üfledi benim ruhuma. Kutsal Belde’de geçirdiğim iki hafta içerisinde, Amerika’da geçirdiğim otuzdokuz yıl boyunca hiç rastlamadığım şeylere tanık oldum. <span class=\"text-white font-bold bg-emerald-900/80 px-1\">Bütün ırkları, bütün renkleri tanıdım; hem de gerçek bir kardeşlik anlayışı içerisinde!</span> Tek bir yürek gibi çarpan! Tek bir beden gibi yaşayan! Tek bir varlık gibi ibadet eden!..”\n                    </p>\n                    <div class=\"mt-6 flex items-center gap-4\">\n                       <div class=\"h-px w-12 bg-amber-500\"></div>\n                       <span class=\"font-bold text-amber-400\">Malcolm X (1925-1965)</span>\n                    </div>\n                  </div>\n                  \n                  <div class=\"md:w-1/4 flex items-center justify-center border-l border-slate-700 pl-4\">\n                     <div class=\"text-center\">\n                        <span class=\"block text-4xl font-bold text-emerald-500 mb-2\">1964</span>\n                        <span class=\"text-sm text-slate-400\">Yılında Hac Tecrübesi</span>\n                     </div>\n                  </div>\n                </div>\n             </div>\n        </div>\n\n    </main>\n\n    <footer class=\"mt-20 py-8 text-center text-slate-500 text-sm border-t border-emerald-100 bg-white\">\n        <p>Ünite 2: Hac ve Kurban | Grafik Bilgi 2.1 & Görsel 2.1 referans alınmıştır.</p>\n    </footer>\n\n    <!-- JavaScript Interactions -->\n    <script>\n        // Lucide ikonlarını oluştur\n        lucide.createIcons();\n\n        function openTab(tabName, btnElement) {\n            // 1. Tüm sekme içeriklerini gizle\n            const contents = document.getElementsByClassName(\"tab-content\");\n            for (let i = 0; i < contents.length; i++) {\n                contents[i].classList.remove(\"active\");\n            }\n\n            // 2. Tüm butonlardaki aktif stilini kaldır\n            const buttons = document.getElementsByClassName(\"tab-btn\");\n            for (let i = 0; i < buttons.length; i++) {\n                buttons[i].classList.remove(\"active\", \"bg-emerald-600\", \"text-white\", \"shadow-md\", \"transform\", \"scale-105\");\n                buttons[i].classList.add(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-emerald-100\");\n            }\n\n            // 3. Seçilen içeriği göster\n            document.getElementById(tabName).classList.add(\"active\");\n\n            // 4. Tıklanan butona aktif stili ekle\n            btnElement.classList.remove(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-emerald-100\");\n            btnElement.classList.add(\"active\", \"bg-emerald-600\", \"text-white\", \"shadow-md\", \"transform\", \"scale-105\");\n            \n            // Animasyonu yeniden tetiklemek için ufak bir hile (opsiyonel)\n            const activeContent = document.getElementById(tabName);\n            activeContent.classList.remove('animate-fade-in-up');\n            void activeContent.offsetWidth; // trigger reflow\n            activeContent.classList.add('animate-fade-in-up');\n        }\n    </script>\n</body>\n</html>"
}