{
  "title": "1. ÜNİTE: MELEK VE AHİRET İNANCI",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>1. Ünite: Melek ve Ahiret İnancı (Akıllı Tahta)</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@300;400;500;700&display=swap');\n        @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap');\n\n        /* --- GENEL AYARLAR (Akıllı Tahta İçin Büyütülmüş) --- */\n        html {\n            font-size: 20px; /* Temel font boyutu artırıldı */\n        }\n\n        body {\n            margin: 0; padding: 0;\n            background: linear-gradient(135deg, #0f172a 0%, #312e81 100%);\n            font-family: 'Roboto', sans-serif;\n            color: #fff;\n            box-sizing: border-box;\n            height: 100vh; width: 100vw;\n            overflow: hidden; \n        }\n\n        /* --- KONTROL BUTONLARI (SAĞ ÜST) --- */\n        #display-controls {\n            position: fixed;\n            top: 20px;\n            right: 20px;\n            z-index: 9999;\n            display: flex;\n            gap: 10px;\n            background: rgba(0,0,0,0.6);\n            padding: 10px;\n            border-radius: 15px;\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255,255,255,0.2);\n        }\n        .ctrl-btn {\n            background: #818cf8;\n            color: #fff;\n            border: none;\n            width: 50px;\n            height: 50px;\n            border-radius: 10px;\n            font-size: 1.8rem;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: transform 0.2s;\n            font-weight: bold;\n        }\n        .ctrl-btn:hover { transform: scale(1.1); background: #6366f1; }\n        .ctrl-btn-blue { background: #4f46e5; }\n\n        /* --- ANA KAPLAYICI --- */\n        #app-wrapper {\n            width: 100%; height: 100%;\n            display: flex; justify-content: center; align-items: center;\n            transition: transform 0.3s ease;\n        }\n\n        #app-container {\n            width: 1500px; height: 850px;\n            background: rgba(15, 23, 42, 0.95);\n            border: 4px solid #818cf8; /* İndigo Çerçeve */\n            border-radius: 30px;\n            box-shadow: 0 40px 80px rgba(0,0,0,0.8);\n            position: relative;\n            display: flex; flex-direction: column;\n            overflow: hidden;\n            transform-origin: center center;\n        }\n\n        /* --- MENÜ EKRANI --- */\n        #menu-screen {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(15, 23, 42, 0.98);\n            z-index: 50;\n            display: flex; flex-direction: column; align-items: center; justify-content: center;\n            overflow-y: auto;\n        }\n        .menu-title { font-family: 'Playfair Display', serif; font-size: 4rem; color: #818cf8; margin-bottom: 40px; text-align: center; text-shadow: 0 4px 10px rgba(0,0,0,0.5); }\n        .menu-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 30px; width: 90%; max-width: 1300px; }\n        .menu-btn {\n            background: rgba(255, 255, 255, 0.05); border: 2px solid #818cf8;\n            padding: 30px; border-radius: 20px; cursor: pointer;\n            transition: transform 0.2s, background 0.2s; text-align: left;\n            display: flex; flex-direction: column; align-items: center; gap: 15px; text-align: center;\n        }\n        .menu-btn:hover { transform: scale(1.03); background: rgba(129, 140, 248, 0.2); }\n        .menu-icon { font-size: 3rem; }\n        .menu-text h3 { margin: 0; font-size: 1.5rem; color: #c7d2fe; }\n        .menu-text p { margin: 5px 0 0 0; color: #94a3b8; font-size: 1rem; }\n\n        /* --- ÜNİTE ARAYÜZÜ --- */\n        .header-bar {\n            height: 90px; border-bottom: 2px solid rgba(129, 140, 248, 0.3);\n            display: flex; align-items: center; justify-content: space-between;\n            padding: 0 50px; background: rgba(0,0,0,0.3); flex-shrink: 0;\n        }\n        .header-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #818cf8; }\n        .home-btn { background: none; border: 2px solid #818cf8; color: #818cf8; padding: 10px 25px; border-radius: 10px; cursor: pointer; font-size: 1.2rem; font-weight: bold; }\n\n        .slide-content {\n            flex: 1; padding: 50px 60px; display: flex; gap: 50px;\n            overflow-y: auto; position: relative; animation: fadeIn 0.5s ease-out;\n        }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }\n\n        .text-panel { flex: 1.4; padding-right: 30px; font-size: 1.4rem; line-height: 1.7; color: #e2e8f0; }\n        .text-panel h2 {\n            font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #fff;\n            margin-top: 0; margin-bottom: 25px; border-bottom: 4px solid #818cf8; display: inline-block;\n        }\n\n        .visual-panel {\n            flex: 0.6; display: flex; flex-direction: column; justify-content: center; align-items: center;\n            background: rgba(255,255,255,0.03); border-radius: 20px; padding: 30px; border: 2px dashed rgba(129, 140, 248, 0.3);\n        }\n        .visual-icon { font-size: 8rem; margin-bottom: 30px; filter: drop-shadow(0 0 15px rgba(129,140,248,0.4)); }\n        \n        .activity-btn {\n            background: linear-gradient(45deg, #818cf8, #4f46e5); border: none; padding: 20px 40px;\n            font-size: 1.6rem; font-weight: bold; color: #fff; border-radius: 50px; cursor: pointer;\n            width: 100%; box-shadow: 0 10px 20px rgba(79, 70, 229, 0.3); animation: pulse 2s infinite;\n        }\n        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.03); } 100% { transform: scale(1); } }\n\n        .controls-bar {\n            height: 90px; padding: 0 50px; display: flex; justify-content: space-between; align-items: center;\n            background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.1); flex-shrink: 0;\n        }\n        .nav-btn {\n            background: transparent; border: 3px solid #818cf8; color: #818cf8; padding: 15px 40px;\n            font-size: 1.4rem; border-radius: 12px; cursor: pointer; font-weight: bold;\n        }\n        .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; border-color: #555; color: #555; }\n\n        /* --- ÖZEL İÇERİK STİLLERİ --- */\n        .concept-table { width: 100%; border-collapse: collapse; margin-top: 25px; background: rgba(255,255,255,0.05); font-size: 1.3rem; }\n        .concept-table th { text-align: left; padding: 15px; color: #818cf8; background: rgba(0,0,0,0.2); }\n        .concept-table td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); }\n        .compare-table { width: 100%; border-collapse: separate; border-spacing: 0 15px; margin-top: 25px; font-size: 1.3rem; }\n        .compare-table th { padding: 15px; text-align: center; }\n        .compare-table td { background: rgba(255,255,255,0.05); padding: 20px; vertical-align: middle; }\n        .compare-left { border-left: 6px solid #93c5fd; border-radius: 15px 0 0 15px; }\n        .compare-right { border-left: 6px solid #818cf8; border-radius: 0 15px 15px 0; }\n        \n        .info-card { background: rgba(49, 46, 129, 0.4); border-left: 6px solid #818cf8; padding: 20px; margin-bottom: 20px; border-radius: 0 15px 15px 0; font-size: 1.3rem; }\n        .quote { font-style: italic; background: rgba(129, 140, 248, 0.1); padding: 20px; border-left: 5px solid #c7d2fe; margin: 20px 0; color: #e0e7ff; font-size: 1.4rem; }\n        .arabic-text { font-family: 'Amiri', serif; font-size: 2.5rem; color: #c7d2fe; display: block; margin-bottom: 10px; direction: rtl; }\n\n        /* OYUN MODALI */\n        #activity-overlay {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(15, 23, 42, 0.98); z-index: 100; display: none;\n            flex-direction: column; align-items: center; padding: 40px; box-sizing: border-box;\n        }\n        .activity-header { font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #818cf8; margin-bottom: 30px; text-align: center; }\n        .close-activity { position: absolute; top: 30px; right: 40px; background: transparent; border: none; color: #fff; font-size: 3rem; cursor: pointer; }\n        .game-area { width: 90%; height: 80%; background: rgba(255,255,255,0.05); border-radius: 25px; padding: 40px; display: flex; flex-direction: column; align-items: center; overflow-y: auto; }\n        .feedback-msg { margin-top: 20px; font-size: 2rem; height: 40px; font-weight: bold; text-align: center; }\n        .success { color: #34d399; } .error { color: #f87171; }\n\n        /* OYUNLAR */\n        .match-container { \n            display: flex; \n            justify-content: space-between; \n            width: 100%; \n            gap: 50px; \n            flex-direction: row; /* Yan yana */\n        }\n        .match-col { \n            flex: 1; \n            display: flex; \n            flex-direction: column; \n            gap: 20px; \n        }\n        .match-item { \n            background: #312e81; \n            padding: 25px; \n            text-align: center; \n            border-radius: 15px; \n            cursor: pointer; \n            border: 4px solid transparent; \n            display: flex; \n            align-items: center; \n            justify-content: center; \n            min-height: 80px; \n            font-size: 1.6rem;\n        }\n        .match-item.selected { border-color: #818cf8; background: #4338ca; }\n        .match-item.matched { background: #059669; opacity: 0.6; pointer-events: none; }\n        .match-item.wrong { background: #dc2626; animation: shake 0.4s; }\n        \n        .quiz-option { width: 90%; padding: 25px; margin: 15px 0; background: #312e81; border: 3px solid #818cf8; border-radius: 15px; cursor: pointer; text-align: left; font-size: 1.6rem; color: white; }\n        \n        .sort-container { width: 80%; display: flex; flex-direction: column; gap: 20px; }\n        .sort-item { background: #312e81; padding: 25px; border-radius: 10px; border-left: 8px solid #818cf8; cursor: pointer; font-size: 1.5rem; }\n\n        .anagram-container { text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center; }\n        .anagram-slots { display: flex; gap: 20px; margin-bottom: 40px; flex-wrap: wrap; justify-content: center; }\n        .anagram-slot { width: 60px; height: 80px; border-bottom: 6px solid #818cf8; font-size: 3rem; color: #818cf8; display: flex; justify-content: center; align-items: center; }\n        .letter-pool { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }\n        .letter-btn { width: 70px; height: 70px; background: #312e81; color: #fff; border: 3px solid #818cf8; border-radius: 15px; font-size: 2rem; cursor: pointer; }\n        .letter-btn.correct { opacity: 0; pointer-events: none; }\n        .letter-btn.wrong { background: #dc2626; animation: shake 0.4s; }\n\n        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } 100% { transform: translateX(0); } }\n\n        /* MOBİL UYUMLULUK */\n        @media screen and (max-width: 1024px) {\n            body { overflow-y: auto; height: auto; }\n            #app-wrapper { display: block; height: auto; }\n            #app-container { width: 100%; height: auto; min-height: 100vh; border: none; border-radius: 0; transform: none !important; box-shadow: none; }\n            #display-controls { display: none; }\n            \n            #menu-screen { position: relative; height: auto; min-height: 100vh; padding: 40px 20px; justify-content: flex-start; }\n            .menu-title { font-size: 2.5rem; margin-bottom: 30px; line-height: 1.2; }\n            .menu-grid { grid-template-columns: 1fr; width: 100%; gap: 15px; }\n            .menu-btn { flex-direction: row; padding: 20px; text-align: left; }\n            .menu-icon { font-size: 2.5rem; }\n            .menu-text h3 { font-size: 1.3rem; }\n            \n            .header-bar { padding: 10px 20px; flex-direction: column; height: auto; gap: 10px; }\n            .slide-content { flex-direction: column; padding: 20px; overflow: visible; }\n            .text-panel, .visual-panel { width: 100%; flex: none; padding-right: 0; }\n            .visual-panel { margin-top: 20px; }\n            .visual-icon { font-size: 4rem; }\n            \n            #activity-overlay { position: fixed; height: 100%; padding: 10px; z-index: 9999; }\n            .game-area { width: 95%; height: 85%; padding: 10px; justify-content: flex-start; }\n            \n            .match-container { flex-direction: column; gap: 15px; }\n            .match-item { font-size: 1rem; min-height: auto; padding: 15px; }\n            .quiz-option { width: 100%; font-size: 1.1rem; }\n            .letter-btn { width: 45px; height: 45px; font-size: 1.3rem; }\n            .anagram-slot { width: 35px; height: 45px; font-size: 1.8rem; }\n            .controls-bar { padding: 10px 20px; position: sticky; bottom: 0; background: #0f172a; z-index: 50; }\n            html { font-size: 16px; }\n        }\n    </style>\n</head>\n<body>\n\n<!-- KONTROL BUTONLARI -->\n<div id=\"display-controls\">\n    <button class=\"ctrl-btn ctrl-btn-blue\" onclick=\"window.appFunctions.toggleFullScreen()\" title=\"Tam Ekran\">⛶</button>\n    <button class=\"ctrl-btn\" onclick=\"window.appFunctions.zoomOut()\" title=\"Küçült\">-</button>\n    <button class=\"ctrl-btn\" onclick=\"window.appFunctions.zoomIn()\" title=\"Büyüt\">+</button>\n</div>\n\n<div id=\"app-wrapper\">\n    <div id=\"app-container\">\n        <!-- MENÜ EKRANI -->\n        <div id=\"menu-screen\">\n            <h1 class=\"menu-title\">1. Ünite: Melek ve Ahiret İnancı</h1>\n            <div class=\"menu-grid\">\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(0)\">\n                    <span class=\"menu-icon\">👁️</span>\n                    <div class=\"menu-text\"><h3>1. Görülen ve Görülemeyen Varlıklar</h3><p>Âlem, Gayb, Cin ve Şeytan.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(1)\">\n                    <span class=\"menu-icon\">🪽</span>\n                    <div class=\"menu-text\"><h3>2. Melekler ve Özellikleri</h3><p>4 Büyük Melek ve Görevleri.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(2)\">\n                    <span class=\"menu-icon\">🌍</span>\n                    <div class=\"menu-text\"><h3>3. Dünya ve Ahiret Hayatı</h3><p>Yaratılış amacı, Ölüm ve Ötesi.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(3)\">\n                    <span class=\"menu-icon\">⚖️</span>\n                    <div class=\"menu-text\"><h3>4. Ahiret Hayatının Aşamaları</h3><p>Kıyamet, Diriliş, Mahşer, Mizan.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(4)\">\n                    <span class=\"menu-icon\">🧠</span>\n                    <div class=\"menu-text\"><h3>5. Ahiret İnancının Etkisi</h3><p>Davranışlara yansıması.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(5)\">\n                    <span class=\"menu-icon\">✝️</span>\n                    <div class=\"menu-text\"><h3>6. Hz. İsa (as)</h3><p>Hayatı, Mucizeleri ve Tebliği.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"window.appFunctions.selectUnit(6)\">\n                    <span class=\"menu-icon\">🤲</span>\n                    <div class=\"menu-text\"><h3>7. Nâs Suresi</h3><p>Okunuşu ve Anlamı.</p></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- ÜNİTE EKRANI -->\n        <div id=\"unit-screen\" style=\"display:none; flex-direction:column; height:100%;\">\n            <div class=\"header-bar\">\n                <div style=\"display:flex; align-items:center; gap:15px; width:100%; justify-content:space-between;\">\n                    <button class=\"home-btn\" onclick=\"window.appFunctions.returnToMenu()\">🏠 Menü</button>\n                    <div class=\"header-title\" id=\"unit-title\">Başlık</div>\n                    <div class=\"progress-indicator\" style=\"font-size:1.1rem;\">Sf <span id=\"current-page\">1</span></div>\n                </div>\n            </div>\n\n            <div id=\"slide-container\" class=\"slide-content\"></div>\n\n            <div class=\"controls-bar\">\n                <button id=\"prev-btn\" class=\"nav-btn\" onclick=\"window.appFunctions.prevSlide()\">❮ Geri</button>\n                <button id=\"next-btn\" class=\"nav-btn\" onclick=\"window.appFunctions.nextSlide()\">İleri ❯</button>\n            </div>\n        </div>\n\n        <!-- OYUN MODALI -->\n        <div id=\"activity-overlay\">\n            <button class=\"close-activity\" onclick=\"window.appFunctions.closeActivity()\">✕</button>\n            <div class=\"activity-header\" id=\"activity-title\">Etkinlik</div>\n            <div class=\"game-area\" id=\"game-board\"></div>\n            <div class=\"feedback-msg\" id=\"feedback\"></div>\n        </div>\n    </div>\n</div>\n\n<script>\n{\n    /* --- EKRAN AYARLARI VE ZOOM --- */\n    let currentScale = 1;\n    let manualZoom = 0;\n\n    function fitScreen() {\n        if(window.innerWidth > 1024) {\n            const container = document.getElementById('app-container');\n            const targetWidth = 1540;\n            const targetHeight = 890;\n            const winWidth = window.innerWidth;\n            const winHeight = window.innerHeight;\n            \n            let scale = Math.min(winWidth / targetWidth, winHeight / targetHeight);\n            currentScale = scale + manualZoom;\n            \n            container.style.transform = `scale(${currentScale})`;\n        } else {\n            document.getElementById('app-container').style.transform = 'none';\n        }\n    }\n\n    /* --- İÇERİK VERİSİ --- */\n    const units = [\n        // 1. GÖRÜLEN VE GÖRÜLEMEYEN VARLIKLAR\n        {\n            title: \"1. Görülen ve Görülemeyen Varlıklar\",\n            slides: [\n                {\n                    title: \"Varlıklar Âlemi\",\n                    content: `<p>Dünya görsel bir şölendir. Bazı varlıkları (Güneş, dağ, insan) gözle görürüz. Bazılarını ise (mikroorganizma, uzaydaki yıldızlar) teknoloji ile görürüz. Ancak bir de gözle görülemeyen varlıklar vardır.</p>\n                    <div class=\"info-card\"><strong>Âlem:</strong> Allah'ın (cc) dışındaki tüm varlıklara denir.</div>\n                    <div class=\"info-card\"><strong>Gayb:</strong> Gözle görülemeyen, duyularla bilinemeyen, sadece Allah'ın bildirmesiyle bilinen âlemdir.</div>`,\n                    icon: \"🌌\", activityType: \"ordering\", activityTitle: \"Varlıkları Sınıflandır (Zihinden)\",\n                    activityData: [\"Görülen: İnsan, Ağaç\", \"Görülemeyen: Melek, Cin, Şeytan, Akıl, Sevgi\"]\n                },\n                {\n                    title: \"Cinler ve Şeytan\",\n                    content: `<p><strong>Cin:</strong> Ateşten yaratılmış, irade sahibi, görülemeyen varlıklardır. İnsanlar gibi Allah'a kulluk için yaratılmışlardır.</p>\n                    <p><strong>Şeytan:</strong> Ateşten yaratılan, Hz. Adem'e secde etmeyip kibirlenen ve Allah'ın huzurundan kovulan varlıktır. İnsanlara sadece vesvese verebilir, zorla kötülük yaptıramaz.</p>`,\n                    icon: \"🔥\", activityType: \"quiz\", activityTitle: \"Doğru mu Yanlış mı?\",\n                    activityData: [{q:\"Şeytan insanlara zorla kötülük yaptırabilir.\", options:[\"Doğru\", \"Yanlış\"], a:\"Yanlış\"}, {q:\"Cinler ateşten yaratılmıştır.\", options:[\"Doğru\", \"Yanlış\"], a:\"Doğru\"}]\n                },\n                {\n                    title: \"Batıl İnançlar\",\n                    content: `<p><strong>Hurafe:</strong> Akla ve dine aykırı uydurma sözlerdir (Örn: Nazar boncuğu, fal, ruh çağırma).</p><p>Sihir ve falcılık dinimizce yasaklanmıştır. Geleceği sadece Allah bilir.</p>`,\n                    icon: \"🚫\", activityType: \"none\", activityTitle: \"\", activityData: null\n                }\n            ]\n        },\n        // 2. MELEKLER\n        {\n            title: \"2. Melekler ve Özellikleri\",\n            slides: [\n                {\n                    title: \"Melek Nedir?\",\n                    content: `<p>Nurdan yaratılmış, yeme-içme, cinsiyet, uyuma gibi özellikleri olmayan, Allah'a tam itaat eden varlıklardır. Gözle görülmezler ancak peygamberler vahiy yoluyla bildirmiştir.</p>\n                    <div class=\"quote\">\"İman; Allah'a, meleklerine... inanmandır.\" (Hadis)</div>`,\n                    icon: \"🪽\", activityType: \"quiz\", activityTitle: \"Melek Özellikleri\",\n                    activityData: [{q:\"Meleklerin cinsiyeti var mıdır?\", options:[\"Evet\", \"Hayır\"], a:\"Hayır\"}, {q:\"Melekler neden yaratılmıştır?\", options:[\"Ateş\", \"Nur\", \"Toprak\"], a:\"Nur\"}]\n                },\n                {\n                    title: \"Dört Büyük Melek\",\n                    content: `<table class=\"concept-table\">\n                    <tr><th>Melek</th><th>Görevi</th></tr>\n                    <tr><td><strong>Cebrail (as)</strong></td><td>Vahiy meleği. Emirleri peygamberlere iletir.</td></tr>\n                    <tr><td><strong>Azrail (as)</strong></td><td>Ölüm meleği. Canları alır.</td></tr>\n                    <tr><td><strong>Mikâil (as)</strong></td><td>Doğa olaylarını ve rızkı düzenler.</td></tr>\n                    <tr><td><strong>İsrafil (as)</strong></td><td>Sûra üflemekle görevlidir (Kıyamet).</td></tr>\n                    </table>`,\n                    icon: \"📜\", activityType: \"matching\", activityTitle: \"Melekleri Eşleştir\",\n                    activityData: [{term:\"Cebrail\", def:\"Vahiy\"}, {term:\"Azrail\", def:\"Ölüm\"}, {term:\"Mikâil\", def:\"Doğa Olayları\"}, {term:\"İsrafil\", def:\"Sûr'a üflemek\"}]\n                },\n                {\n                    title: \"Diğer Melekler\",\n                    content: `<p><strong>Kiramen Kâtibin:</strong> Yazıcı melekler. Sağ ve solumuzda iyilik ve kötülükleri yazarlar.</p>\n                    <p><strong>Münker ve Nekir:</strong> Sorgu melekleri. Kabirde insanı sorgularlar.</p>\n                    <p><strong>Hafaza:</strong> Koruyucu melekler.</p>`,\n                    icon: \"✍️\", activityType: \"matching\", activityTitle: \"Diğer Melekler\",\n                    activityData: [{term:\"Kiramen Kâtibin\", def:\"Yazıcı\"}, {term:\"Münker-Nekir\", def:\"Sorgu\"}, {term:\"Hafaza\", def:\"Koruyucu\"}]\n                }\n            ]\n        },\n        // 3. DÜNYA VE AHİRET\n        {\n            title: \"3. Dünya ve Ahiret Hayatı\",\n            slides: [\n                {\n                    title: \"Hayatın Amacı\",\n                    content: `<p>Dünya hayatı geçici, ahiret hayatı ise sonsuzdur. Dünya, ahiretin tarlasıdır. İnsan, Allah'a kulluk etmek ve imtihan edilmek için yaratılmıştır.</p>\n                    <div class=\"quote\">\"Dünya hayatı bir oyun ve eğlenceden başka bir şey değildir.\" (Enam, 32)</div>`,\n                    icon: \"🌍\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Ölüm Bir Son Değildir\",\n                    content: `<p>Ölüm, yok oluş değil, yeni bir hayatın başlangıcıdır. Baharda kuruyan bitkilerin canlanması gibi, insanlar da ahirette yeniden diriltilecektir.</p>`,\n                    icon: \"🌱\", activityType: \"quiz\", activityTitle: \"Kavrama Testi\",\n                    activityData: [{q:\"Dünya hayatı nasıldır?\", options:[\"Sonsuz\", \"Geçici\"], a:\"Geçici\"}, {q:\"Ölüm ne anlama gelir?\", options:[\"Yok oluş\", \"Ahirete geçiş\"], a:\"Ahirete geçiş\"}]\n                }\n            ]\n        },\n        // 4. AHİRET AŞAMALARI\n        {\n            title: \"4. Ahiret Hayatının Aşamaları\",\n            slides: [\n                {\n                    title: \"1. Ölüm ve Berzah\",\n                    content: `<p><strong>Ölüm:</strong> Ruhun bedenden ayrılması. Ecel, belirlenen ölüm vaktidir.</p>\n                    <p><strong>Berzah (Kabir):</strong> Ölümle diriliş arasındaki bekleme dönemi.</p>`,\n                    icon: \"⚰️\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"2. Kıyamet ve Diriliş\",\n                    content: `<p><strong>Kıyamet:</strong> İsrafil (as) 1. kez Sûra üfler, evrenin düzeni bozulur ve her şey ölür.</p>\n                    <p><strong>Baas (Diriliş):</strong> İsrafil (as) 2. kez Sûra üfler, herkes yeniden dirilir.</p>`,\n                    icon: \"🎺\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"3. Mahşer ve Mizan\",\n                    content: `<p><strong>Haşir/Mahşer:</strong> Dirilen insanların hesap vermek için toplanması (Meydan).</p>\n                    <p><strong>Mizan:</strong> İyilik ve kötülüklerin tartıldığı adalet terazisi.</p>`,\n                    icon: \"⚖️\", activityType: \"matching\", activityTitle: \"Kavramları Eşleştir\",\n                    activityData: [{term:\"Kıyamet\", def:\"Evrenin sonu\"}, {term:\"Baas\", def:\"Yeniden Diriliş\"}, {term:\"Mahşer\", def:\"Toplanma yeri\"}, {term:\"Mizan\", def:\"Tartı/Terazi\"}]\n                },\n                {\n                    title: \"4. Cennet ve Cehennem\",\n                    content: `<p><strong>Cennet:</strong> İman edip iyi işler yapanların sonsuz ödül yeri.</p>\n                    <p><strong>Cehennem:</strong> İnkâr edenlerin ve günahkarların ceza yeri.</p>`,\n                    icon: \"🏁\", activityType: \"ordering\", activityTitle: \"Sıralama Yap\",\n                    activityData: [\"Ölüm\", \"Berzah\", \"Kıyamet\", \"Diriliş (Baas)\", \"Mahşer\", \"Hesap/Mizan\", \"Cennet/Cehennem\"]\n                }\n            ]\n        },\n        // 5. İNANCIN ETKİSİ\n        {\n            title: \"5. Ahiret İnancının Etkisi\",\n            slides: [\n                {\n                    title: \"Davranışlara Etkisi\",\n                    content: `<p>Ahirete inanan insan:</p><ul><li>Yaptıklarının hesabını vereceğini bilir, kötülükten kaçınır.</li><li>Zorluklara sabreder, ümitsizliğe düşmez.</li><li>Adaletli, merhametli ve dürüst olur.</li><li>\"Ne ekersen onu biçersin\" bilinciyle yaşar.</li></ul>`,\n                    icon: \"🧠\", activityType: \"quiz\", activityTitle: \"Davranış Analizi\",\n                    activityData: [{q:\"Hesap vereceğini bilen insan nasıl davranır?\", options:[\"Sorumsuzca\", \"Dikkatli ve dürüst\"], a:\"Dikkatli ve dürüst\"}]\n                }\n            ]\n        },\n        // 6. HZ. İSA\n        {\n            title: \"6. Bir Peygamber: Hz. İsa (as)\",\n            slides: [\n                {\n                    title: \"Doğumu ve Hayatı\",\n                    content: `<p>Annesi Hz. Meryem'dir. Babasız olarak mucizevi bir şekilde Kudüs'te doğmuştur. Hz. Muhammed'den (sav) önceki peygamberdir. Kendisine <strong>İncil</strong> verilmiştir.</p><p>Havariler: Ona inanan 12 arkadaşı.</p>`,\n                    icon: \"✝️\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Mucizeleri\",\n                    content: `<p>Allah'ın izniyle:</p><ul><li>Beşikteyken konuşması.</li><li>Ölüleri diriltmesi.</li><li>Körü ve alacalı hastayı iyileştirmesi.</li><li>Çamurdan kuşa can vermesi.</li></ul>`,\n                    icon: \"✨\", activityType: \"quiz\", activityTitle: \"Hz. İsa Bilgisi\",\n                    activityData: [{q:\"Hz. İsa'nın annesi kimdir?\", options:[\"Hz. Asiye\", \"Hz. Meryem\"], a:\"Hz. Meryem\"}, {q:\"Hangi kitap verilmiştir?\", options:[\"Tevrat\", \"İncil\"], a:\"İncil\"}]\n                }\n            ]\n        },\n        // 7. NÂS SURESİ\n        {\n            title: \"7. Bir Sure: Nâs Suresi\",\n            slides: [\n                {\n                    title: \"Tanıtım ve Okunuş\",\n                    content: `<p>Kur'an'ın son (114.) suresidir. \"Nâs\" insanlar demektir. Felak suresi ile birlikte \"Muavvizeteyn\" (İki koruyucu) denir.</p>\n                    <div class=\"verse-box\"><span class=\"arabic-text\">قُلْ اَعُوذُ بِرَبِّ النَّاسِۙ</span>1. Kul eûzu birabbinnâs (De ki: Sığınırım insanların Rabbine)</div>\n                    <div class=\"verse-box\"><span class=\"arabic-text\">مَلِكِ النَّاسِۙ</span>2. Melikinnâs (İnsanların Melik'ine/Hükümdarına)</div>\n                    <div class=\"verse-box\"><span class=\"arabic-text\">اِلٰهِ النَّاسِۙ</span>3. İlâhinnâs (İnsanların İlahına)</div>`,\n                    icon: \"🤲\", activityType: \"ordering\", activityTitle: \"İlk 3 Ayeti Sırala\",\n                    activityData: [\"Kul eûzu birabbinnâs\", \"Melikinnâs\", \"İlâhinnâs\"]\n                },\n                {\n                    title: \"Devamı ve Anlamı\",\n                    content: `<div class=\"verse-box\"><span class=\"arabic-text\">مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِۙ</span>4. Min şerril vesvâsil ḫannâs (Sinsi vesvesecinin şerrinden)</div>\n                    <div class=\"verse-box\"><span class=\"arabic-text\">اَلَّذ۪ي يُوَسْوِسُ ف۪ي صُدُورِ النَّاسِۙ</span>5. Ellezî yuvesvisu fî sudûrinnâs (O ki insanların göğüslerine vesvese verir)</div>\n                    <div class=\"verse-box\"><span class=\"arabic-text\">مِنَ الْجِنَّةِ وَالنَّاسِ</span>6. Minel cinneti vennâs (Gerek cinlerden gerek insanlardan)</div>`,\n                    icon: \"🛡️\", activityType: \"matching\", activityTitle: \"Anlam Eşleştirme\",\n                    activityData: [{term:\"Nâs\", def:\"İnsanlar\"}, {term:\"Vesvese\", def:\"Kötü fısıltı\"}, {term:\"Rab/Melik/İlah\", def:\"Allah'ın sıfatları\"}, {term:\"Hannas\", def:\"Sinsi vesveseci\"}]\n                }\n            ]\n        }\n    ];\n\n    /* --- DURUM YÖNETİMİ --- */\n    let currentUnitIdx = 0;\n    let currentSlideIdx = 0;\n    let currentData = null;\n    let selectedItem = null;\n    let anagramIndex = 0;\n    let currentAnagramState = { word:\"\", pos:0 };\n\n    /* --- GÖRÜNÜM KONTROLÜ --- */\n    function init() {\n        fitScreen();\n    }\n\n    // Expose functions to window so HTML onClick works with scoped functions\n    window.appFunctions = {\n        zoomIn: () => { manualZoom += 0.1; fitScreen(); },\n        zoomOut: () => { if(currentScale > 0.3) { manualZoom -= 0.1; fitScreen(); } },\n        toggleFullScreen: () => {\n            if (!document.fullscreenElement) { document.documentElement.requestFullscreen(); }\n            else { if (document.exitFullscreen) { document.exitFullscreen(); } }\n        },\n        selectUnit: (index) => {\n            currentUnitIdx = index;\n            currentSlideIdx = 0;\n            document.getElementById('menu-screen').style.display = 'none';\n            document.getElementById('unit-screen').style.display = 'flex';\n            document.getElementById('unit-title').textContent = units[index].title;\n            renderSlide();\n        },\n        returnToMenu: () => {\n            document.getElementById('unit-screen').style.display = 'none';\n            document.getElementById('menu-screen').style.display = 'flex';\n        },\n        nextSlide: () => { if(currentSlideIdx < units[currentUnitIdx].slides.length-1) { currentSlideIdx++; renderSlide(); } },\n        prevSlide: () => { if(currentSlideIdx > 0) { currentSlideIdx--; renderSlide(); } },\n        openActivity: () => {\n            const slide = units[currentUnitIdx].slides[currentSlideIdx];\n            const board = document.getElementById('game-board');\n            document.getElementById('activity-overlay').style.display = 'flex';\n            document.getElementById('activity-title').textContent = slide.activityTitle;\n            document.getElementById('feedback').textContent = \"\";\n            board.innerHTML = \"\";\n            currentData = slide.activityData;\n\n            if(slide.activityType === 'quiz') loadQuiz(board, currentData);\n            else if(slide.activityType === 'matching') loadMatching(board, currentData);\n            else if(slide.activityType === 'ordering') loadOrdering(board, currentData);\n            else if(slide.activityType === 'anagram') { anagramIndex=0; loadAnagram(board, currentData); }\n        },\n        closeActivity: () => { document.getElementById('activity-overlay').style.display = 'none'; }\n    };\n\n    function renderSlide() {\n        const slide = units[currentUnitIdx].slides[currentSlideIdx];\n        const container = document.getElementById('slide-container');\n        document.getElementById('current-page').innerText = currentSlideIdx + 1;\n        document.getElementById('prev-btn').disabled = currentSlideIdx === 0;\n        document.getElementById('next-btn').disabled = currentSlideIdx === units[currentUnitIdx].slides.length - 1;\n\n        let btnHtml = slide.activityType !== \"none\"\n            ? `<button class=\"activity-btn\" onclick=\"window.appFunctions.openActivity()\">🎮 ETKİNLİK BAŞLAT</button>` \n            : ``;\n\n        container.innerHTML = `\n            <div class=\"text-panel\"><h2>${slide.title}</h2>${slide.content}</div>\n            <div class=\"visual-panel\"><div class=\"visual-icon\">${slide.icon}</div>${btnHtml}</div>\n        `;\n    }\n\n    /* --- ETKİNLİK MOTORU --- */\n    \n    // 1. QUIZ\n    function loadQuiz(board, data) {\n        const show = (idx) => {\n            if(idx >= data.length) { board.innerHTML=\"<h2 class='success'>Tamamladın! 🎉</h2>\"; return; }\n            let q = data[idx];\n            board.innerHTML = `<h3 style=\"font-size:1.8rem; text-align:center;\">${q.q}</h3><div id=\"opts\" style=\"width:100%; display:flex; flex-direction:column; align-items:center;\"></div>`;\n            q.options.forEach(opt => {\n                let btn = document.createElement(\"div\"); btn.className = \"quiz-option\"; btn.textContent = opt;\n                btn.onclick = function() { \n                    if(opt === q.a) { this.style.background=\"#059669\"; setTimeout(()=>show(idx+1), 600); }\n                    else { this.style.background=\"#dc2626\"; }\n                };\n                document.getElementById('opts').appendChild(btn);\n            });\n        };\n        show(0);\n    }\n\n    // 2. EŞLEŞTİRME (YATAY DÜZEN)\n    function loadMatching(board, data) {\n        board.innerHTML = `<div class=\"match-container\"><div class=\"match-col\" id=\"left\"></div><div class=\"match-col\" id=\"right\"></div></div>`;\n        let leftCol = document.getElementById('left');\n        let rightCol = document.getElementById('right');\n        let rightItems = [...data].sort(() => Math.random() - 0.5);\n\n        data.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.term; btn.dataset.pair = item.def;\n            btn.onclick = () => selectLeft(btn); leftCol.appendChild(btn);\n        });\n\n        rightItems.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.def;\n            btn.onclick = () => checkMatch(btn); rightCol.appendChild(btn);\n        });\n    }\n\n    function selectLeft(elem) {\n        if(elem.classList.contains('matched')) return;\n        // Fix: Use correct ID selector '#left' instead of '#col-left'\n        document.querySelectorAll('#left .match-item').forEach(e => e.classList.remove('selected'));\n        elem.classList.add('selected'); selectedItem = elem;\n    }\n\n    function checkMatch(elem) {\n        if(!selectedItem || elem.classList.contains('matched')) return;\n        const feedback = document.getElementById('feedback');\n        if(selectedItem.dataset.pair === elem.textContent) {\n            elem.classList.add('matched'); selectedItem.classList.add('matched'); selectedItem.classList.remove('selected'); selectedItem = null;\n            feedback.innerHTML = \"<span class='success'>Doğru!</span>\";\n            // Fix: Use correct ID selector '#left'\n            if(document.querySelectorAll('#left .match-item:not(.matched)').length === 0) feedback.innerHTML = \"<span class='success'>Tebrikler!</span>\";\n        } else {\n            elem.classList.add('wrong'); setTimeout(() => elem.classList.remove('wrong'), 500);\n            feedback.innerHTML = \"<span class='error'>Yanlış!</span>\";\n        }\n    }\n\n    // 3. SIRALAMA\n    function loadOrdering(board, data) {\n        board.innerHTML = `<p style=\"text-align:center; font-size:1.5rem;\">Sırasıyla seç:</p><div id=\"sort-area\" class=\"sort-container\"></div>`;\n        let area = document.getElementById('sort-area');\n        let shuffled = [...data].sort(()=>Math.random()-0.5);\n        let step = 0;\n\n        shuffled.forEach(txt => {\n            let div = document.createElement('div'); div.className = 'sort-item'; div.textContent = txt;\n            div.onclick = function() {\n                if(txt === data[step]) {\n                    this.style.background = '#059669'; this.style.pointerEvents='none'; step++;\n                    if(step === data.length) document.getElementById('feedback').innerHTML=\"<span class='success'>Tebrikler!</span>\";\n                } else {\n                    this.style.background = '#dc2626'; setTimeout(()=>this.style.background='#312e81', 500);\n                }\n            };\n            area.appendChild(div);\n        });\n    }\n\n    // 4. ANAGRAM\n    function loadAnagram(board, data) {\n        if(anagramIndex >= data.length) { board.innerHTML=\"<h2 class='success'>Bitti! 🎉</h2>\"; return; }\n        let item = data[anagramIndex];\n        currentAnagramState = { word: item.answer, pos: 0 };\n        board.innerHTML = `<div class=\"anagram-container\"><div style=\"margin-bottom:20px; color:#93c5fd; font-size:1.5rem;\">İpucu: ${item.hint}</div><div id=\"slots\" class=\"anagram-slots\"></div><div id=\"pool\" class=\"letter-pool\"></div></div>`;\n        \n        for(let i=0; i<item.answer.length; i++) {\n            let s = document.createElement('div'); s.className='anagram-slot'; s.id=`s-${i}`; document.getElementById('slots').appendChild(s);\n        }\n        item.scrambled.split('').forEach(char => {\n            let btn = document.createElement('button'); btn.className='letter-btn'; btn.textContent=char;\n            btn.onclick = function() {\n                if(char === currentAnagramState.word[currentAnagramState.pos]) {\n                    document.getElementById(`s-${currentAnagramState.pos}`).textContent = char;\n                    this.classList.add('correct'); currentAnagramState.pos++;\n                    if(currentAnagramState.pos >= item.answer.length) { anagramIndex++; setTimeout(()=>loadAnagram(board, data), 1000); }\n                } else {\n                    this.classList.add('wrong'); setTimeout(()=>this.classList.remove('wrong'), 400);\n                }\n            };\n            document.getElementById('pool').appendChild(btn);\n        });\n    }\n\n    // Event listeners attached to window for scope safety\n    window.addEventListener('resize', fitScreen);\n    window.addEventListener('load', fitScreen);\n\n    // Başlat\n    init();\n}\n</script>\n</body>\n</html>"
}