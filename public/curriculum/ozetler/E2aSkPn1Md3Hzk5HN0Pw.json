{
  "title": "3.İlahi Kitaplar",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>İlahi Kitaplar ve Peygamberler</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Amiri:wght@400;700&display=swap');\n        body {\n            font-family: 'Inter', sans-serif;\n        }\n        .font-amiri {\n            font-family: 'Amiri', serif;\n        }\n        .card-hover:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n        }\n    </style>\n</head>\n<body class=\"bg-slate-50 text-slate-800 min-h-screen pb-12\">\n\n    <!-- Header Section -->\n    <header class=\"bg-gradient-to-r from-teal-700 to-emerald-800 text-white pt-12 pb-20 px-4 relative overflow-hidden\">\n        <div class=\"absolute top-0 left-0 w-full h-full opacity-10\">\n            <i data-lucide=\"book\" class=\"absolute right-10 top-10 w-64 h-64\"></i>\n            <i data-lucide=\"scroll\" class=\"absolute left-10 bottom-10 w-48 h-48\"></i>\n        </div>\n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <span class=\"inline-block py-1 px-3 rounded-full bg-emerald-600/50 border border-emerald-400/30 text-sm font-medium mb-4 backdrop-blur-sm\">\n                1. Ünite: Peygamber ve İlahi Kitap İnancı\n            </span>\n            <h1 class=\"text-4xl md:text-6xl font-bold font-amiri mb-4\">İlahi Kitaplar</h1>\n            <p class=\"text-emerald-100 text-lg md:text-xl max-w-2xl mx-auto\">\n                Dünya ve ahiret mutluluğu için Allah'ın (cc) peygamberleri aracılığıyla gönderdiği rehberler.\n            </p>\n        </div>\n    </header>\n\n    <!-- Main Content Container -->\n    <main class=\"max-w-5xl mx-auto px-4 -mt-10 relative z-20 space-y-12\">\n\n        <!-- Suhuf Bölümü (Küçük Kartlar) -->\n        <section>\n            <div class=\"bg-white rounded-xl shadow-lg p-6 md:p-8 border-t-4 border-orange-400\">\n                <div class=\"flex items-center gap-3 mb-6\">\n                    <div class=\"p-2 bg-orange-100 rounded-lg text-orange-600\">\n                        <i data-lucide=\"file-text\" size=\"24\"></i>\n                    </div>\n                    <div>\n                        <h2 class=\"text-xl font-bold text-slate-800\">Suhuf (Sayfalar)</h2>\n                        <p class=\"text-sm text-slate-500\">Dört büyük kitaptan önce bazı peygamberlere gönderilen sayfalar.</p>\n                    </div>\n                </div>\n                \n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n                    <!-- Suhuf Kartları -->\n                    <div class=\"bg-orange-50 p-4 rounded-lg text-center border border-orange-100\">\n                        <div class=\"text-3xl font-bold text-orange-600 mb-1\">10</div>\n                        <div class=\"text-xs text-orange-400 uppercase font-bold tracking-wider mb-1\">Sayfa</div>\n                        <div class=\"font-bold text-slate-700\">Hz. Âdem</div>\n                    </div>\n                    <div class=\"bg-orange-50 p-4 rounded-lg text-center border border-orange-100\">\n                        <div class=\"text-3xl font-bold text-orange-600 mb-1\">50</div>\n                        <div class=\"text-xs text-orange-400 uppercase font-bold tracking-wider mb-1\">Sayfa</div>\n                        <div class=\"font-bold text-slate-700\">Hz. Şit</div>\n                    </div>\n                    <div class=\"bg-orange-50 p-4 rounded-lg text-center border border-orange-100\">\n                        <div class=\"text-3xl font-bold text-orange-600 mb-1\">30</div>\n                        <div class=\"text-xs text-orange-400 uppercase font-bold tracking-wider mb-1\">Sayfa</div>\n                        <div class=\"font-bold text-slate-700\">Hz. İdris</div>\n                    </div>\n                    <div class=\"bg-orange-50 p-4 rounded-lg text-center border border-orange-100\">\n                        <div class=\"text-3xl font-bold text-orange-600 mb-1\">10</div>\n                        <div class=\"text-xs text-orange-400 uppercase font-bold tracking-wider mb-1\">Sayfa</div>\n                        <div class=\"font-bold text-slate-700\">Hz. İbrahim</div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 4 Büyük Kitap Bölümü -->\n        <section>\n            <h2 class=\"text-2xl font-bold text-center mb-8 flex items-center justify-center gap-2\">\n                <i data-lucide=\"library\" class=\"text-emerald-600\"></i>\n                Dört Büyük İlahi Kitap\n            </h2>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" id=\"books-container\">\n                <!-- Tevrat -->\n                <div class=\"bg-white rounded-xl shadow-md overflow-hidden card-hover transition-all duration-300 border border-slate-100\">\n                    <div class=\"bg-blue-600 text-white p-4 flex justify-between items-center\">\n                        <h3 class=\"text-xl font-bold font-amiri\">Tevrat</h3>\n                        <span class=\"text-xs bg-blue-700 px-2 py-1 rounded\">İlk Kitap</span>\n                    </div>\n                    <div class=\"p-6\">\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"user\" class=\"text-blue-600\" size=\"18\"></i>\n                            <span class=\"font-semibold\">Hz. Musa</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"languages\" class=\"text-blue-600\" size=\"18\"></i>\n                            <span class=\"text-sm text-slate-600\">Dili: <strong>İbranice</strong></span>\n                        </div>\n                        <p class=\"text-sm text-slate-600 mb-4 bg-blue-50 p-3 rounded-lg\">\n                            \"Şüphesiz Tevrat'ı biz indirdik. İçinde bir hidayet, bir nur vardır...\" (Maide, 44)\n                        </p>\n                        <div class=\"mt-4 pt-4 border-t border-slate-100\">\n                            <h4 class=\"text-xs font-bold text-slate-400 uppercase mb-2\">Peygamber Bilgisi</h4>\n                            <p class=\"text-xs text-slate-600\">İsrailoğulları'na gönderildi. Firavun ile mücadele etti. Asasının yılan olması mucizesi vardır.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Zebur -->\n                <div class=\"bg-white rounded-xl shadow-md overflow-hidden card-hover transition-all duration-300 border border-slate-100\">\n                    <div class=\"bg-purple-600 text-white p-4 flex justify-between items-center\">\n                        <h3 class=\"text-xl font-bold font-amiri\">Zebur</h3>\n                        <span class=\"text-xs bg-purple-700 px-2 py-1 rounded\">Dualar Kitabı</span>\n                    </div>\n                    <div class=\"p-6\">\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"user\" class=\"text-purple-600\" size=\"18\"></i>\n                            <span class=\"font-semibold\">Hz. Davud</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"languages\" class=\"text-purple-600\" size=\"18\"></i>\n                            <span class=\"text-sm text-slate-600\">Dili: <strong>İbranice</strong></span>\n                        </div>\n                         <p class=\"text-sm text-slate-600 mb-4 bg-purple-50 p-3 rounded-lg\">\n                            Tevrat'tan sonra gönderilmiştir. İçerisinde dualar ve ilahiler yer alır.\n                        </p>\n                        <div class=\"mt-4 pt-4 border-t border-slate-100\">\n                            <h4 class=\"text-xs font-bold text-slate-400 uppercase mb-2\">Peygamber Bilgisi</h4>\n                            <p class=\"text-xs text-slate-600\">Sesi çok güzeldi. Demir işleme sanatını bilirdi. Dağlar ve kuşlar emrine verilmişti.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- İncil -->\n                <div class=\"bg-white rounded-xl shadow-md overflow-hidden card-hover transition-all duration-300 border border-slate-100\">\n                    <div class=\"bg-rose-600 text-white p-4 flex justify-between items-center\">\n                        <h3 class=\"text-xl font-bold font-amiri\">İncil</h3>\n                        <span class=\"text-xs bg-rose-700 px-2 py-1 rounded\">Müjde</span>\n                    </div>\n                    <div class=\"p-6\">\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"user\" class=\"text-rose-600\" size=\"18\"></i>\n                            <span class=\"font-semibold\">Hz. İsa</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"languages\" class=\"text-rose-600\" size=\"18\"></i>\n                            <span class=\"text-sm text-slate-600\">Dili: <strong>Aramice</strong></span>\n                        </div>\n                         <p class=\"text-sm text-slate-600 mb-4 bg-rose-50 p-3 rounded-lg\">\n                            Zebur'dan sonra gönderilmiştir. Kendisine uyanların kalbine şefkat konulmuştur.\n                        </p>\n                        <div class=\"mt-4 pt-4 border-t border-slate-100\">\n                            <h4 class=\"text-xs font-bold text-slate-400 uppercase mb-2\">Peygamber Bilgisi</h4>\n                            <p class=\"text-xs text-slate-600\">Babasız dünyaya gelmiştir. Ölüleri diriltme mucizesi vardır. Kur'an'da \"Mesih\" olarak anılır.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Kur'an-ı Kerim (Highlighted) -->\n                <div class=\"bg-white rounded-xl shadow-lg overflow-hidden transform md:scale-105 border-2 border-emerald-500 relative\">\n                    <div class=\"absolute top-0 right-0 bg-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg z-10\">SON KİTAP</div>\n                    <div class=\"bg-emerald-700 text-white p-5 flex justify-between items-center\">\n                        <h3 class=\"text-2xl font-bold font-amiri\">Kur'an-ı Kerim</h3>\n                    </div>\n                    <div class=\"p-6\">\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"user\" class=\"text-emerald-600\" size=\"18\"></i>\n                            <span class=\"font-semibold text-lg\">Hz. Muhammed (sav)</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 mb-4\">\n                            <i data-lucide=\"languages\" class=\"text-emerald-600\" size=\"18\"></i>\n                            <span class=\"text-sm text-slate-600\">Dili: <strong>Arapça</strong></span>\n                        </div>\n                        \n                        <div class=\"bg-emerald-50 rounded-lg p-4 mb-4\">\n                            <h4 class=\"font-bold text-emerald-800 mb-2 text-sm\">Temel Özellikleri</h4>\n                            <ul class=\"space-y-2 text-sm text-emerald-700\">\n                                <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"14\"></i> Değişmeden günümüze gelmiştir.</li>\n                                <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"14\"></i> Kıyamete kadar korunacaktır.</li>\n                                <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"14\"></i> Şifa, Rahmet ve Rehberdir.</li>\n                            </ul>\n                        </div>\n\n                         <div class=\"mt-4 pt-4 border-t border-slate-100\">\n                            <h4 class=\"text-xs font-bold text-slate-400 uppercase mb-2\">Peygamber Bilgisi</h4>\n                            <p class=\"text-xs text-slate-600\">Hatemülenbiya (Son Peygamber). Alemlere rahmet olarak gönderilmiştir.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Etkinlik: Kronolojik Sıralama -->\n        <section class=\"bg-slate-800 text-white rounded-2xl p-6 md:p-10 shadow-xl\">\n            <div class=\"text-center mb-6\">\n                <h2 class=\"text-2xl font-bold mb-2\">Etkinlik: Kronolojik Sıralama</h2>\n                <p class=\"text-slate-300 text-sm\">İlahi kitapları gönderiliş sırasına göre (Eskiden Yeniye) tıklayınız.</p>\n            </div>\n\n            <div class=\"max-w-3xl mx-auto\">\n                <div class=\"flex flex-wrap justify-center gap-4 mb-8\" id=\"game-buttons\">\n                    <button onclick=\"checkOrder('İncil', this)\" class=\"game-btn bg-rose-600 hover:bg-rose-500 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-all\">İncil</button>\n                    <button onclick=\"checkOrder('Tevrat', this)\" class=\"game-btn bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-all\">Tevrat</button>\n                    <button onclick=\"checkOrder('Kur\\'an-ı Kerim', this)\" class=\"game-btn bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-all\">Kur'an-ı Kerim</button>\n                    <button onclick=\"checkOrder('Zebur', this)\" class=\"game-btn bg-purple-600 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-all\">Zebur</button>\n                </div>\n\n                <div id=\"game-feedback\" class=\"h-16 flex items-center justify-center\">\n                    <div class=\"flex items-center gap-2 text-slate-400 bg-slate-700/50 px-4 py-2 rounded-full\">\n                        <i data-lucide=\"help-circle\" size=\"18\"></i>\n                        <span>Sırayla seçiniz...</span>\n                    </div>\n                </div>\n\n                <!-- Timeline Visualization (Hidden initially) -->\n                <div id=\"timeline-display\" class=\"hidden mt-6 pt-6 border-t border-slate-700\">\n                     <div class=\"flex flex-col md:flex-row justify-between items-center gap-4 relative\">\n                        <!-- Connecting Line -->\n                        <div class=\"absolute left-1/2 top-0 bottom-0 w-1 md:w-full md:h-1 md:left-0 md:top-1/2 bg-slate-600 -z-10\"></div>\n                        \n                        <div class=\"w-full md:w-auto bg-blue-600 p-3 rounded-lg text-center z-10 w-32\"><span class=\"font-bold block\">1. Tevrat</span><span class=\"text-xs opacity-75\">Hz. Musa</span></div>\n                        <div class=\"w-full md:w-auto bg-purple-600 p-3 rounded-lg text-center z-10 w-32\"><span class=\"font-bold block\">2. Zebur</span><span class=\"text-xs opacity-75\">Hz. Davud</span></div>\n                        <div class=\"w-full md:w-auto bg-rose-600 p-3 rounded-lg text-center z-10 w-32\"><span class=\"font-bold block\">3. İncil</span><span class=\"text-xs opacity-75\">Hz. İsa</span></div>\n                        <div class=\"w-full md:w-auto bg-emerald-600 p-3 rounded-lg text-center z-10 w-32\"><span class=\"font-bold block\">4. Kur'an</span><span class=\"text-xs opacity-75\">Hz. Muhammed</span></div>\n                     </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n    <script>\n        // Lucide Icons Init\n        lucide.createIcons();\n\n        // Game Logic\n        const correctOrder = ['Tevrat', 'Zebur', 'İncil', 'Kur\\'an-ı Kerim'];\n        let currentStep = 0;\n\n        function checkOrder(bookName, btnElement) {\n            const feedbackEl = document.getElementById('game-feedback');\n            \n            if (bookName === correctOrder[currentStep]) {\n                // Correct\n                btnElement.classList.add('opacity-50', 'cursor-not-allowed', 'ring-2', 'ring-green-400');\n                btnElement.disabled = true;\n                currentStep++;\n                \n                if (currentStep === correctOrder.length) {\n                    feedbackEl.innerHTML = `\n                        <div class=\"flex items-center gap-2 text-green-400 bg-green-900/30 px-4 py-2 rounded-full border border-green-800\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg>\n                            <span class=\"font-bold\">Tebrikler! Sıralama Doğru.</span>\n                        </div>\n                    `;\n                    document.getElementById('timeline-display').classList.remove('hidden');\n                } else {\n                     feedbackEl.innerHTML = `\n                        <div class=\"text-emerald-400 font-medium\">Doğru! Şimdi sıradaki kitabı seç.</div>\n                    `;\n                }\n            } else {\n                // Wrong\n                btnElement.classList.add('animate-pulse', 'bg-red-600');\n                setTimeout(() => {\n                    btnElement.classList.remove('animate-pulse', 'bg-red-600');\n                }, 500);\n                feedbackEl.innerHTML = `\n                    <div class=\"text-red-400 font-medium\">Yanlış sıra. Tekrar dene.</div>\n                `;\n            }\n        }\n    </script>\n</body>\n</html>"
}