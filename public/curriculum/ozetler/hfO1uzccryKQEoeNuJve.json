{
  "title": "4.Kurban İbadeti ve Önemi",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kurban İbadeti ve Önemi</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        body { font-family: 'Inter', sans-serif; }\n        .font-serif-custom { font-family: 'Crimson Text', serif; }\n        \n        /* Animasyonlar */\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-fade-in-up {\n            animation: fadeInUp 0.5s ease-out forwards;\n        }\n\n        /* Sekme Yönetimi */\n        .tab-content { display: none; }\n        .tab-content.active { display: block; }\n        \n        /* Scrollbar Gizleme */\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        /* Pasta Grafiği (CSS ile) */\n        .pie-chart {\n            width: 150px;\n            height: 150px;\n            border-radius: 50%;\n            background: conic-gradient(\n                #f59e0b 0% 33%, \n                #10b981 33% 66%, \n                #3b82f6 66% 100%\n            );\n            position: relative;\n        }\n    </style>\n</head>\n<body class=\"min-h-screen bg-orange-50 text-slate-800 selection:bg-orange-200\">\n\n    <!-- Header Section -->\n    <header class=\"bg-gradient-to-r from-orange-800 to-amber-700 text-white py-12 px-4 shadow-xl relative overflow-hidden\">\n        <div class=\"absolute inset-0 opacity-10\" style=\"background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;\"></div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <h1 class=\"text-4xl md:text-5xl font-bold mb-4 tracking-tight\">KURBAN İBADETİ VE ÖNEMİ</h1>\n            <p class=\"text-amber-100 text-xl font-light italic\">\"Kurban, Allah’a yaklaşmaktır.\"</p>\n        </div>\n    </header>\n\n    <!-- Navigation Tabs -->\n    <div class=\"sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm border-b border-orange-100\">\n        <div class=\"max-w-6xl mx-auto flex overflow-x-auto justify-start md:justify-center p-2 gap-2 md:gap-4 no-scrollbar\">\n            <button onclick=\"openTab('onem', this)\" class=\"tab-btn active flex items-center gap-2 px-5 py-3 rounded-full text-sm font-bold bg-orange-600 text-white shadow-lg transform scale-105 transition-all whitespace-nowrap\">\n                <i data-lucide=\"heart-handshake\"></i> Önemi & Anlamı\n            </button>\n            <button onclick=\"openTab('cesitler', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-full text-sm font-bold bg-slate-100 text-slate-600 hover:bg-orange-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"layers\"></i> Kurban Çeşitleri\n            </button>\n            <button onclick=\"openTab('sartlar', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-full text-sm font-bold bg-slate-100 text-slate-600 hover:bg-orange-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"clipboard-check\"></i> Şartlar & Paylaşım\n            </button>\n            <button onclick=\"openTab('alevi', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-full text-sm font-bold bg-slate-100 text-slate-600 hover:bg-orange-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"flower-2\"></i> Alevi-Bektaşi Geleneği\n            </button>\n        </div>\n    </div>\n\n    <main class=\"max-w-5xl mx-auto p-4 md:p-8 min-h-[600px]\">\n\n        <!-- TAB 1: ÖNEMİ & ANLAMI -->\n        <div id=\"onem\" class=\"tab-content active animate-fade-in-up\">\n            <div class=\"grid md:grid-cols-2 gap-8\">\n                \n                <!-- Tanım ve Amaç -->\n                <div class=\"bg-white p-8 rounded-3xl shadow-lg border-l-8 border-orange-500\">\n                    <h2 class=\"text-2xl font-bold text-orange-800 mb-4 flex items-center gap-2\">\n                        <i data-lucide=\"book-open\"></i> Kurban Nedir?\n                    </h2>\n                    <p class=\"text-slate-600 leading-relaxed mb-6\">\n                        Kurban, belli nitelikleri olan bir hayvanı belirli günlerde ibadet niyetiyle usulüne uygun bir biçimde kesmektir. Mali bir ibadet olup Allah’ın verdiği nimetlere şükür ifadesidir.\n                    </p>\n                    \n                    <div class=\"bg-orange-50 p-4 rounded-xl border border-orange-100\">\n                        <h3 class=\"font-bold text-orange-900 mb-2\">Manevi Boyutu</h3>\n                        <ul class=\"space-y-2 text-sm text-slate-700\">\n                            <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Hz. İbrahim ve İsmail'in teslimiyetini hatırlatır.</li>\n                            <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Allah'a yakınlaşma (kurbiyet) vesilesidir.</li>\n                            <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Cimrilikten kurtulup paylaşmayı öğretir.</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Ayet ve Hadis -->\n                <div class=\"space-y-6\">\n                    <!-- Ayet Kartı -->\n                    <div class=\"bg-emerald-50 border border-emerald-200 p-6 rounded-2xl relative\">\n                        <i data-lucide=\"quote\" class=\"absolute top-4 right-4 text-emerald-200\" size=\"48\"></i>\n                        <h3 class=\"text-emerald-800 font-bold mb-3\">Kur'an-ı Kerim Buyuruyor ki:</h3>\n                        <p class=\"font-serif-custom italic text-lg text-emerald-900 leading-relaxed\">\n                            “Onların ne etleri Allah’a ulaşır ne de kanları. O’na ulaşacak olan sadece sizin takvanızdır...”\n                        </p>\n                        <div class=\"mt-3 text-right text-sm font-bold text-emerald-700\">(Hac suresi, 37. ayet)</div>\n                    </div>\n\n                    <!-- Hadis Kartı -->\n                    <div class=\"bg-amber-50 border border-amber-200 p-6 rounded-2xl relative\">\n                        <i data-lucide=\"message-circle\" class=\"absolute top-4 right-4 text-amber-200\" size=\"48\"></i>\n                        <h3 class=\"text-amber-800 font-bold mb-3\">Hz. Peygamber (sav) Buyuruyor:</h3>\n                        <p class=\"font-serif-custom italic text-lg text-amber-900 leading-relaxed\">\n                            “Kurban, henüz kanı yere düşmeden, Allah tarafından kabul edilir. Bu sebeple kurban kesme konusunda gönlünüz hoş olsun.”\n                        </p>\n                        <div class=\"mt-3 text-right text-sm font-bold text-amber-700\">(Tirmizî, Edâhî, 1.)</div>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n\n        <!-- TAB 2: KURBAN ÇEŞİTLERİ -->\n        <div id=\"cesitler\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"text-center mb-8\">\n                <h2 class=\"text-2xl font-bold text-slate-800\">Kurban Çeşitleri</h2>\n                <p class=\"text-slate-500\">Grafik Bilgi 2.7</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                <!-- Vacip Kurban -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md border-t-4 border-red-500 hover:shadow-xl transition-shadow group\">\n                    <div class=\"bg-red-100 w-12 h-12 rounded-full flex items-center justify-center text-red-600 mb-4 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"calendar\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Vacip Kurban</h3>\n                    <p class=\"text-slate-600 text-sm\">Kurban Bayramı günlerinde kesilen ve dinen zengin sayılanlara vacip olan kurbandır.</p>\n                </div>\n\n                <!-- Adak Kurbanı -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md border-t-4 border-blue-500 hover:shadow-xl transition-shadow group\">\n                    <div class=\"bg-blue-100 w-12 h-12 rounded-full flex items-center justify-center text-blue-600 mb-4 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"message-square\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Adak Kurbanı</h3>\n                    <p class=\"text-slate-600 text-sm\">Bir dileğin gerçekleşmesi hâlinde kesilmek üzere Allah’a söz verilen kurbandır.</p>\n                </div>\n\n                <!-- Akika Kurbanı -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md border-t-4 border-pink-500 hover:shadow-xl transition-shadow group\">\n                    <div class=\"bg-pink-100 w-12 h-12 rounded-full flex items-center justify-center text-pink-600 mb-4 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"baby\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Akika Kurbanı</h3>\n                    <p class=\"text-slate-600 text-sm\">Yeni doğan çocuk için Allah’a şükür amacıyla kesilen kurbandır.</p>\n                </div>\n\n                <!-- Şükür Kurbanı -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md border-t-4 border-emerald-500 hover:shadow-xl transition-shadow group\">\n                    <div class=\"bg-emerald-100 w-12 h-12 rounded-full flex items-center justify-center text-emerald-600 mb-4 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"smile\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Şükür Kurbanı</h3>\n                    <p class=\"text-slate-600 text-sm\">Herhangi bir güzel sebeple kişinin Allah’a şükretmek için kestiği kurbandır.</p>\n                </div>\n\n                <!-- Hedy Kurbanı -->\n                <div class=\"bg-white p-6 rounded-xl shadow-md border-t-4 border-amber-500 hover:shadow-xl transition-shadow group\">\n                    <div class=\"bg-amber-100 w-12 h-12 rounded-full flex items-center justify-center text-amber-600 mb-4 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"map-pin\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-slate-800 mb-2\">Hedy Kurbanı</h3>\n                    <p class=\"text-slate-600 text-sm\">Hac ve Umre ibadeti sırasında Kutsal Topraklarda kesilen kurbanlardır.</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 3: ŞARTLAR & PAYLAŞIM -->\n        <div id=\"sartlar\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"space-y-10\">\n                \n                <!-- Kurban Kesme Şartları -->\n                <div class=\"bg-white p-8 rounded-2xl shadow-lg border border-slate-100\">\n                    <h3 class=\"text-2xl font-bold text-orange-800 mb-6 flex items-center gap-2\">\n                        <i data-lucide=\"user-check\"></i> Kimlere Kurban Düşer?\n                    </h3>\n                    <div class=\"grid sm:grid-cols-2 md:grid-cols-3 gap-4\">\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg\">\n                            <i data-lucide=\"check-circle\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Müslüman Olmak</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg\">\n                            <i data-lucide=\"check-circle\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Akıllı Olmak</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg\">\n                            <i data-lucide=\"check-circle\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Ergenliğe Girmiş Olmak</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg\">\n                            <i data-lucide=\"check-circle\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Hür Olmak</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg\">\n                            <i data-lucide=\"check-circle\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Mukim Olmak (Yolcu olmamak)</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 p-3 bg-orange-50 rounded-lg border border-orange-200\">\n                            <i data-lucide=\"wallet\" class=\"text-orange-600\"></i> <span class=\"font-semibold\">Zengin Olmak (Nisap Miktarı)</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Hayvan Şartları ve Etin Paylaşımı -->\n                <div class=\"grid md:grid-cols-2 gap-8\">\n                    <!-- Hayvan Şartları -->\n                    <div class=\"bg-slate-50 p-6 rounded-2xl border border-slate-200\">\n                        <h3 class=\"text-xl font-bold text-slate-800 mb-4\">Kurbanlık Hayvan Şartları</h3>\n                        <div class=\"space-y-4\">\n                            <div class=\"bg-white p-4 rounded-lg shadow-sm\">\n                                <h4 class=\"font-bold text-slate-700\">Küçükbaş (Koyun/Keçi)</h4>\n                                <p class=\"text-sm text-slate-500\">1 Yaşını doldurmalı. Sadece 1 kişi adına kesilebilir.</p>\n                            </div>\n                            <div class=\"bg-white p-4 rounded-lg shadow-sm\">\n                                <h4 class=\"font-bold text-slate-700\">Büyükbaş (Sığır/Manda)</h4>\n                                <p class=\"text-sm text-slate-500\">2 Yaşını doldurmalı. En fazla 7 kişi ortak olabilir.</p>\n                            </div>\n                            <div class=\"bg-white p-4 rounded-lg shadow-sm\">\n                                <h4 class=\"font-bold text-slate-700\">Deve</h4>\n                                <p class=\"text-sm text-slate-500\">5 Yaşını doldurmalı. En fazla 7 kişi ortak olabilir.</p>\n                            </div>\n                            <div class=\"bg-red-50 p-3 rounded-lg border border-red-100 text-xs text-red-700 font-bold flex gap-2\">\n                                <i data-lucide=\"alert-triangle\" size=\"16\"></i>\n                                Kör, kulaksız veya dişlerinin çoğu dökülmüş hayvan kurban olmaz. Tavuk/Kaz kurban edilmez.\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Etin Paylaşımı -->\n                    <div class=\"bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col items-center justify-center text-center\">\n                        <h3 class=\"text-xl font-bold text-slate-800 mb-6\">Etin Paylaşımı (Sünnet Olan)</h3>\n                        \n                        <div class=\"pie-chart mb-6 shadow-inner\"></div>\n                        \n                        <div class=\"w-full space-y-2\">\n                            <div class=\"flex items-center justify-between bg-amber-50 p-3 rounded-lg border-l-4 border-amber-500\">\n                                <span class=\"font-bold text-slate-700\">1/3 Yoksullar</span>\n                                <span class=\"text-xs text-amber-600 bg-white px-2 py-1 rounded\">Yardımlaşma</span>\n                            </div>\n                            <div class=\"flex items-center justify-between bg-emerald-50 p-3 rounded-lg border-l-4 border-emerald-500\">\n                                <span class=\"font-bold text-slate-700\">1/3 Akraba/Komşu</span>\n                                <span class=\"text-xs text-emerald-600 bg-white px-2 py-1 rounded\">Hediyeleşme</span>\n                            </div>\n                            <div class=\"flex items-center justify-between bg-blue-50 p-3 rounded-lg border-l-4 border-blue-500\">\n                                <span class=\"font-bold text-slate-700\">1/3 Aile Fertleri</span>\n                                <span class=\"text-xs text-blue-600 bg-white px-2 py-1 rounded\">İhtiyaç</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 4: ALEVİ-BEKTAŞİ GELENEĞİ -->\n        <div id=\"alevi\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-100\">\n                <div class=\"bg-indigo-900 p-8 text-white relative\">\n                    <div class=\"absolute right-0 top-0 h-full w-1/3 bg-indigo-800 opacity-20 skew-x-12\"></div>\n                    <h2 class=\"text-3xl font-bold mb-2\">Alevi-Bektaşi Geleneğinde Kurban</h2>\n                    <p class=\"text-indigo-200\">Dinî hayatın önemli bir unsuru: \"Tığlama\"</p>\n                </div>\n                \n                <div class=\"p-8\">\n                    <div class=\"flex flex-col md:flex-row gap-8\">\n                        <div class=\"md:w-1/3 space-y-4\">\n                            <h3 class=\"font-bold text-indigo-900 text-xl border-b border-indigo-100 pb-2\">Ritüel Nasıl Yapılır?</h3>\n                            <ul class=\"space-y-4\">\n                                <li class=\"flex gap-3 text-slate-700\">\n                                    <span class=\"bg-indigo-100 text-indigo-700 w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs shrink-0\">1</span>\n                                    Kurban edilecek hayvana tuz ve su verilir.\n                                </li>\n                                <li class=\"flex gap-3 text-slate-700\">\n                                    <span class=\"bg-indigo-100 text-indigo-700 w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs shrink-0\">2</span>\n                                    Dede, besmele çekip tekbir getirir.\n                                </li>\n                                <li class=\"flex gap-3 text-slate-700\">\n                                    <span class=\"bg-indigo-100 text-indigo-700 w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs shrink-0\">3</span>\n                                    Kur'an'dan ayetler okunur ve \"Gülbank\" (dua) yapılır.\n                                </li>\n                            </ul>\n                        </div>\n\n                        <div class=\"md:w-2/3\">\n                            <div class=\"bg-slate-50 p-8 rounded-2xl border-l-4 border-indigo-500 relative\">\n                                <i data-lucide=\"scroll\" class=\"absolute top-4 right-4 text-indigo-200\" size=\"40\"></i>\n                                <h4 class=\"font-bold text-indigo-900 mb-4\">Kurban Tığlama Duası</h4>\n                                <p class=\"font-serif-custom italic text-lg leading-relaxed text-slate-700\">\n                                    “Fermân-ı Celîl, kurban-ı Halîl, itaat-ı (can-ı) İsmâil, delîl-i Cebrâil, şefaat-ı Nebî, kerem-i (Ali) velî, himmet-i pîr ola. Kurbanımız kabul ola, dergâh-ı Hakk’a yazılmış ola, hayır nimetlerimiz kabul ola muratlar hasıl ola dünyada kurban, ahirette Burak ola... kurbanımız kazaları, belâları, afetleri defetmiş ola...”\n                                </p>\n                                <div class=\"mt-4 text-right text-xs text-slate-500 font-bold\">\n                                    (Kaynak: Anadolu’da Alevi Ocakları ve Grupları, s. 335-336)\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n    </main>\n\n    <footer class=\"py-8 text-center text-slate-500 text-sm mt-12 border-t border-slate-200\">\n        <p>2. Ünite: Hac ve Kurban | Grafik Bilgi 2.7, 2.8, 2.9 referans alınmıştır.</p>\n    </footer>\n\n    <script>\n        // İkonları oluştur\n        lucide.createIcons();\n\n        function openTab(tabName, btnElement) {\n            // İçerikleri gizle\n            const contents = document.getElementsByClassName(\"tab-content\");\n            for (let i = 0; i < contents.length; i++) {\n                contents[i].classList.remove(\"active\");\n            }\n            \n            // Buton stillerini sıfırla\n            const buttons = document.getElementsByClassName(\"tab-btn\");\n            for (let i = 0; i < buttons.length; i++) {\n                buttons[i].classList.remove(\"active\", \"bg-orange-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n                buttons[i].classList.add(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-orange-50\");\n            }\n\n            // Seçileni aç ve stillendir\n            document.getElementById(tabName).classList.add(\"active\");\n            \n            // Animasyon reflow\n            const activeContent = document.getElementById(tabName);\n            activeContent.classList.remove('animate-fade-in-up');\n            void activeContent.offsetWidth; \n            activeContent.classList.add('animate-fade-in-up');\n\n            // Aktif buton stili\n            btnElement.classList.remove(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-orange-50\");\n            btnElement.classList.add(\"active\", \"bg-orange-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n        }\n    </script>\n</body>\n</html>"
}