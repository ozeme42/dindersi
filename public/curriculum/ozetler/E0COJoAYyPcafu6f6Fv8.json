{
  "title": "2. Vahyin Gelişi",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Vahiy Dönemi Sıralama Etkinliği</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        /* Ana Stil */\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #0c1a2c; /* Deep Night Blue */\n            color: #e2e8f0;\n            min-height: 100vh;\n        }\n        /* Olay kartları için genel stil */\n        .event-card {\n            background-color: #1a273b; \n            padding: 24px;\n            border-radius: 16px; \n            transition: all 0.3s ease;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n            border-bottom: 5px solid; \n            margin-bottom: 24px; \n            position: relative;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n        }\n        .event-card:hover {\n            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.8);\n            transform: translateY(-5px); \n        }\n\n        /* Yıl Etiketi Stili */\n        .year-label {\n            position: absolute;\n            top: 0;\n            right: 0;\n            background-color: rgba(59, 130, 246, 0.9);\n            color: white;\n            padding: 4px 16px;\n            font-weight: 800;\n            font-size: 1.125rem;\n            border-bottom-left-radius: 16px;\n            z-index: 10;\n        }\n        \n        /* Renkler */\n        .color-initial { border-color: #FFD700; } \n        .color-persecution { border-color: #EF4444; } \n        .color-transition { border-color: #3B82F6; } \n        .color-victory { border-color: #10B981; } \n        .color-final { border-color: #F97316; } \n\n        .text-initial { color: #FFD700; }\n        .text-persecution { color: #EF4444; }\n        .text-transition { color: #3B82F6; }\n        .text-victory { color: #10B981; }\n        .text-final { color: #F97316; }\n\n        /* Sıralama Etkinliği Listesi */\n        #sortable-list li {\n            background-color: #1f2a3e;\n            padding: 15px;\n            margin-bottom: 8px;\n            border-radius: 8px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            border-left: 5px solid #60a5fa;\n            cursor: grab; /* Sürükleme imleci */\n            transition: background-color 0.2s, transform 0.2s;\n        }\n\n        #sortable-list li:hover {\n            background-color: #2c3a50;\n        }\n        \n        /* Sürükle-Bırak Stilleri */\n        .dragging {\n            opacity: 0.4;\n            border: 2px dashed #60a5fa;\n            background-color: #1a273b !important;\n            box-shadow: none;\n        }\n\n        /* Yeni Eklenen Görsel İpucu Stilleri */\n        .drag-over-above {\n            border-top: 5px solid #a855f7; /* Üstte mor çizgi */\n            margin-top: 0px;\n        }\n        .drag-over-below {\n            border-bottom: 5px solid #a855f7; /* Altta mor çizgi */\n            margin-bottom: 0px;\n        }\n\n        /* Yeni Sekme Stilleri */\n        .tab-button {\n            padding: 8px 16px; /* Daha küçük padding */\n            font-weight: 600;\n            transition: all 0.3s;\n            color: #9ca3af; /* İnaktif renk */\n            border-bottom: 4px solid transparent; /* Sekme alt çizgisi */\n            margin-bottom: -1px; /* Alt çizgiyi nav border'ı üzerine oturtmak için */\n            font-size: 0.9rem; /* Küçültülmüş yazı boyutu */\n            background: none; /* Arka planı kaldır */\n            cursor: pointer;\n        }\n        .tab-button:hover {\n            color: #e2e8f0;\n        }\n        .active-tab {\n            color: #60a5fa; /* Aktif metin rengi */\n            border-color: #60a5fa; /* Mavi alt çizgi */\n            font-weight: 700;\n        }\n    </style>\n</head>\n<body class=\"p-4 md:p-12\">\n\n    <header class=\"text-center mb-12\">\n        <h1 class=\"text-4xl md:text-6xl font-black text-white mb-4 tracking-tight\">\n            Hz. Muhammed (SAV) Risalet Dönemi\n        </h1>\n        <p class=\"text-xl text-gray-400 italic\" id=\"subtitle-text\">\n            İlk Vahiyden Veda Hutbesi'ne Önemli Olaylar\n        </p>\n    </header>\n\n    <!-- Navigation Tabs (SEKMELİ YAPI) -->\n    <nav class=\"max-w-5xl mx-auto mb-12 flex justify-center border-b border-gray-700 space-x-2 md:space-x-4\">\n        <button id=\"listViewBtn\" onclick=\"switchView('list-view')\" class=\"tab-button\">\n            OLAY LİSTESİ\n        </button>\n        <button id=\"activityViewBtn\" onclick=\"switchView('activity-view')\" class=\"tab-button\">\n            SIRALAMA ETKİNLİĞİ\n        </button>\n        <!-- YENİ SEKMELER -->\n        <button id=\"firstsViewBtn\" onclick=\"switchView('firsts-view')\" class=\"tab-button\">\n            İSLAM'IN İLKLERİ\n        </button>\n    </nav>\n    \n    <!-- 1. Olay Listesi Görünümü -->\n    <div id=\"list-view\" class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 px-4\">\n        \n        <!-- Olay 1: İLK VAHİY (610) -->\n        <div class=\"event-card color-initial\">\n            <span class=\"year-label text-initial\" style=\"background-color: #FFD700; color: #0c1a2c;\">610</span>\n            <h3 class=\"text-xl font-extrabold text-initial mb-2 mt-4\">İLK VAHİY: \"OKU!\"</h3>\n            <p class=\"text-gray-300\">\n                Hz. Peygamber’in Hira Mağarası’nda aldığı ilk vahiy Alak suresinin ilk beş ayetidir. Bu emir ile İslam daveti başlamıştır.\n            </p>\n        </div>\n\n        <!-- Olay 2: HABEŞİSTAN'A HİCRET (615) -->\n        <div class=\"event-card color-victory\">\n            <span class=\"year-label text-victory\" style=\"background-color: #10B981; color: #0c1a2c;\">615</span>\n            <h3 class=\"text-xl font-extrabold text-victory mb-2 mt-4\">HABEŞİSTAN'A İLK HİCRET</h3>\n            <p class=\"text-gray-300\">\n                Mekke’de müşriklerin yaptığı baskılar karşısında Müslümanların bir kısmının, adil hükümdar Necaşi'nin ülkesi olan Habeşistan’a yaptığı ilk hicrettir.\n            </p>\n        </div>\n\n        <!-- Olay 3: SOSYAL VE EKONOMİK BOYKOY (616-619) -->\n        <div class=\"event-card color-persecution\">\n            <span class=\"year-label text-persecution\" style=\"background-color: #EF4444; color: #0c1a2c;\">616-619</span>\n            <h3 class=\"text-xl font-extrabold text-persecution mb-2 mt-4\">SOSYAL VE EKONOMİK BOYKOY YILLARI</h3>\n            <p class=\"text-gray-300\">\n                Mekkeli müşrikler, Müslümanlara ve Hz. Peygamber’in kabilesi olan Haşimoğulları’na karşı sosyal ve ekonomik kısıtlama uygulamışlardır.\n            </p>\n        </div>\n\n        <!-- Olay 4: HÜZÜN YILI (620) -->\n        <div class=\"event-card\" style=\"border-bottom-color: #A855F7;\">\n            <span class=\"year-label\" style=\"background-color: #A855F7; color: #0c1a2c;\">620</span>\n            <h3 class=\"text-xl font-extrabold\" style=\"color: #A855F7;\">HÜZÜN YILI (Amû'l-Hüzn)</h3>\n            <p class=\"text-gray-300\">\n                Hz. Peygamber’e destek olan amcası Ebu Talib ve eşi Hz. Hatice’nin peş peşe vefat ettiği, büyük üzüntü duyduğu yıldır.\n            </p>\n        </div>\n\n        <!-- Olay 5: AKABE BİATİ (622) -->\n        <div class=\"event-card color-transition\">\n            <span class=\"year-label text-transition\" style=\"background-color: #3B82F6; color: #0c1a2c;\">622</span>\n            <h3 class=\"text-xl font-extrabold text-transition mb-2 mt-4\">AKABE BİATİ VE HİCRET KARARI</h3>\n            <p class=\"text-gray-300\">\n                Hz. Peygamber, Medinelilerle (Ensar) ikinci defa görüşmüş ve bu görüşme neticesinde Medine’ye hicret kararı alınmıştır.\n            </p>\n        </div>\n        \n        <!-- Olay 6: MEDİNE'YE HİCRET (622) -->\n        <div class=\"event-card\" style=\"border-bottom-color: #06B6D4;\">\n            <span class=\"year-label\" style=\"background-color: #06B6D4; color: #0c1a2c;\">622</span>\n            <h3 class=\"text-xl font-extrabold\" style=\"color: #06B6D4;\">MEDİNE’YE HİCRET</h3>\n            <p class=\"text-gray-300\">\n                Müslümanların Mekke'den Medine'ye göçü başlamıştır. Hz. Muhammed (SAV) ve Hz. Ebu Bekir farklı bir güzergâh kullanarak Medine’ye ulaşmışlardır.\n            </p>\n        </div>\n        \n        <!-- Olay 7: MEKKE’NİN FETHİ (630) -->\n        <div class=\"event-card color-victory\">\n            <span class=\"year-label text-victory\" style=\"background-color: #10B981; color: #0c1a2c;\">630</span>\n            <h3 class=\"text-xl font-extrabold text-victory mb-2 mt-4\">MEKKE’NİN FETHİ</h3>\n            <p class=\"text-gray-300\">\n                Siyasi ve askerî olarak güçlenen Müslümanlar, kıblemiz Kâbe’nin bulunduğu şehri savaşmadan fethetmiş, genel af ilan edilmiştir.\n            </p>\n        </div>\n\n        <!-- Olay 8: VEDA HUTBESİ VE VEFAT (632) -->\n        <div class=\"event-card color-final\">\n            <span class=\"year-label text-final\" style=\"background-color: #F97316; color: #0c1a2c;\">632</span>\n            <h3 class=\"text-xl font-extrabold text-final mb-2 mt-4\">VEDA HUTBESİ VE VEFAT</h3>\n            <p class=\"text-gray-300\">\n                Hz. Peygamber, ilk ve son haccında Veda Hutbesi’ni okumuş ve aynı yıl \"En yüce dosta\" diyerek Medine’de vefat etmiştir.\n            </p>\n        </div>\n    </div>\n\n    <!-- 2. Sıralama Etkinliği Görünümü -->\n    <div id=\"activity-view\" class=\"max-w-4xl mx-auto px-4 hidden\">\n        <p class=\"text-center text-xl text-yellow-400 font-bold mb-6\">\n            Olayları kronolojik (tarih sırasına) göre **sürükleyip bırakarak** sıralayınız.\n        </p>\n\n        <ol id=\"sortable-list\" class=\"list-none p-0 mb-8\">\n            <!-- JS ile olaylar buraya eklenecek -->\n        </ol>\n\n        <div class=\"flex flex-col md:flex-row justify-center space-y-4 md:space-y-0 md:space-x-4\">\n            <button onclick=\"checkOrder()\" class=\"px-8 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-full shadow-xl transition duration-300 transform hover:scale-105\">\n                Kontrol Et\n            </button>\n            <button onclick=\"resetActivity()\" class=\"px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-full shadow-xl transition duration-300 transform hover:scale-105\">\n                Yeniden Başlat\n            </button>\n        </div>\n\n        <div id=\"feedback\" class=\"mt-8 text-center text-2xl font-bold rounded-lg p-4 transition-all duration-500\"></div>\n\n    </div>\n\n    <!-- 3. İslam'ın İlkleri Görünümü (YENİ EKLENEN SEKMELER) -->\n    <div id=\"firsts-view\" class=\"max-w-4xl mx-auto px-4 hidden\">\n        <h2 class=\"text-3xl font-bold text-center text-yellow-400 mb-8\">İslam Tarihinin Başlangıç Noktaları</h2>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            \n            <!-- 1. İLK VAHİY -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-yellow-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-yellow-300 mb-2\">İLK VAHİY: \"OKU!\" (610)</h4>\n                <p class=\"text-gray-300\">\n                    Hz. Muhammed’e **Hira Mağarası’nda** Cebrail (a.s.) aracılığıyla indirilen Alak suresinin ilk ayetleridir. Risaletin başlangıcıdır.\n                </p>\n            </div>\n\n            <!-- 2. İLK MÜSLÜMANLAR -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-blue-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-blue-300 mb-2\">İLK MÜSLÜMANLAR (Sâbikûn-i Evvelûn)</h4>\n                <p class=\"text-gray-300\">\n                    **Hz. Hatice**, hür erkeklerden **Hz. Ebu Bekir**, çocuklardan **Hz. Ali** ve azatlılardan **Zeyd b. Hârise** ilk Müslümanlardır.\n                </p>\n            </div>\n\n            <!-- 3. İSLAM'IN İLK OKULU -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-green-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-green-300 mb-2\">İSLAM'IN İLK OKULU: DÂRÜ'L-ERKAM</h4>\n                <p class=\"text-gray-300\">\n                    Gizli davet döneminde, Müslümanların toplanıp ibadet ve eğitim gördüğü, **Erkam b. Ebi'l-Erkam'ın evi**dir.\n                </p>\n            </div>\n\n            <!-- 4. İLK HİCRET -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-red-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-red-300 mb-2\">İLK HİCRET: HABEŞİSTAN (615)</h4>\n                <p class=\"text-gray-300\">\n                    Mekke'de artan baskılar nedeniyle bir grup Müslümanın, adil hükümdar Necaşi'nin yönettiği **Habeşistan'a sığınması**dır.\n                </p>\n            </div>\n\n            <!-- 5. İLK ÖĞRETMEN -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-indigo-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-indigo-300 mb-2\">İLK ÖĞRETMEN: MUS'AB B. UMEYR</h4>\n                <p class=\"text-gray-300\">\n                    **Birinci Akabe Biatı'ndan sonra** Medinelilere Kur'an öğretmek ve İslam'ı tebliğ etmek için görevlendirilen ilk öğretmendir.\n                </p>\n            </div>\n\n            <!-- 6. İLK MESCİD -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-teal-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-teal-300 mb-2\">İLK MESCİD: MESCİD-İ KUBA</h4>\n                <p class=\"text-gray-300\">\n                    Hz. Peygamber’in Medine'ye hicreti sırasında, şehir dışında durakladığı **Kuba'da inşa ettirdiği** ve İslam'ın ilk mescididir.\n                </p>\n            </div>\n\n            <!-- 7. İLK CUMA NAMAZI -->\n            <div class=\"p-6 bg-[#1f2a3e] rounded-xl border-l-4 border-pink-500 shadow-lg transition duration-300 hover:bg-[#2c3a50]\">\n                <h4 class=\"text-xl font-extrabold text-pink-300 mb-2\">İLK CUMA NAMAZI: RÂNÛNA VADİSİ</h4>\n                <p class=\"text-gray-300\">\n                    Hz. Peygamber'in Medine'ye girişi sırasında, Rânûna vadisindeki Salim b. Avf kabilesinde kıldırdığı **İslam'ın ilk Cuma namazı**dır.\n                </p>\n            </div>\n\n        </div>\n    </div>\n\n    <footer class=\"text-center mt-20 pt-8 border-t border-[#1a273b]\">\n        <p class=\"text-sm text-gray-500\">Bu uygulama, olayların kronolojik sırasını pekiştirmenize yardımcı olmak amacıyla hazırlanmıştır.</p>\n    </footer>\n\n    <script>\n        const events = [\n            { id: 1, year: '610', name: \"İLK VAHİY: 'OKU!'\", description: \"Hz. Peygamber’in Hira Mağarası’nda aldığı ilk vahiy (Alak 1-5).\" },\n            { id: 2, year: '615', name: \"HABEŞİSTAN'A İLK HİCRET\", description: \"Mekke’deki baskılar karşısında Müslümanların Habeşistan’a göçü.\" },\n            { id: 3, year: '616-619', name: \"SOSYAL VE EKONOMİK BOYKOY YILLARI\", description: \"Mekkeli müşriklerin Müslümanlara uyguladığı kısıtlamalar.\" },\n            { id: 4, year: '620', name: \"HÜZÜN YILI (Amû'l-Hüzn)\", description: \"Amcası Ebu Talib ve eşi Hz. Hatice’nin vefatı.\" },\n            { id: 5, year: '622', name: \"AKABE BİATİ VE HİCRET KARARI\", description: \"Hz. Peygamber'in Medinelilerle ikinci görüşmesi ve hicret kararı.\" },\n            { id: 6, year: '622-Hicret', name: \"MEDİNE’YE HİCRET\", description: \"Müslümanların Mekke'den Medine'ye göçü.\" },\n            { id: 7, year: '630', name: \"MEKKE’NİN FETHİ\", description: \"Müslümanların Kâbe’nin bulunduğu şehri savaşmadan fethetmesi.\" },\n            { id: 8, year: '632', name: \"VEDA HUTBESİ VE VEFAT\", description: \"Hz. Peygamber'in Veda Haccı ve aynı yıl Medine’de vefatı.\" }\n        ];\n\n        let currentOrder = [];\n        const sortableList = document.getElementById('sortable-list');\n        const feedbackDiv = document.getElementById('feedback');\n        const listBtn = document.getElementById('listViewBtn');\n        const activityBtn = document.getElementById('activityViewBtn');\n        const firstsViewBtn = document.getElementById('firstsViewBtn'); // Yeni buton\n        let draggedItemIndex = -1; \n\n        // Fisher-Yates shuffle algoritması\n        function shuffle(array) {\n            let currentIndex = array.length, randomIndex;\n            while (currentIndex != 0) {\n                randomIndex = Math.floor(Math.random() * currentIndex);\n                currentIndex--;\n                [array[currentIndex], array[randomIndex]] = [\n                    array[randomIndex], array[currentIndex]];\n            }\n            return array;\n        }\n\n        // --- Sürükle-Bırak Fonksiyonları ---\n\n        function dragStart(e) {\n            // Sürüklenen öğenin mevcut listedeki dizinini buluruz\n            const targetLi = e.target.closest('li');\n            if (!targetLi) return;\n\n            e.dataTransfer.effectAllowed = \"move\";\n            targetLi.classList.add('dragging');\n            draggedItemIndex = Array.from(sortableList.children).indexOf(targetLi);\n        }\n\n        function dragEnd(e) {\n            const targetLi = e.target.closest('li');\n            if (targetLi) {\n                targetLi.classList.remove('dragging');\n            }\n            draggedItemIndex = -1;\n            // Tüm drag-over (vurgu) sınıflarını temizle\n            Array.from(sortableList.children).forEach(item => item.classList.remove('drag-over-above', 'drag-over-below'));\n        }\n\n        function dragOver(e) {\n            e.preventDefault(); \n            const target = e.target.closest('li');\n            if (!target || target.classList.contains('dragging')) return;\n\n            // Tüm vurgu sınıflarını temizle\n            Array.from(sortableList.children).forEach(item => item.classList.remove('drag-over-above', 'drag-over-below'));\n\n            const rect = target.getBoundingClientRect();\n            const center = (rect.top + rect.bottom) / 2;\n\n            if (e.clientY < center) {\n                // Üst yarıda sürükleniyor: Öğenin üstüne çizgi çek\n                target.classList.add('drag-over-above');\n            } else {\n                // Alt yarıda sürükleniyor: Öğenin altına çizgi çek\n                target.classList.add('drag-over-below');\n            }\n        }\n\n        function drop(e) {\n            e.preventDefault();\n            const dropTarget = e.target.closest('li');\n            if (!dropTarget || dropTarget.classList.contains('dragging') || draggedItemIndex === -1) return;\n\n            // 1. Hedef öğenin listedeki dizinini bul\n            let targetIndex = Array.from(sortableList.children).indexOf(dropTarget);\n\n            const rect = dropTarget.getBoundingClientRect();\n            const center = (rect.top + rect.bottom) / 2;\n            \n            let finalInsertIndex = targetIndex;\n\n            // 2. Bırakma konumuna göre nihai ekleme dizinini belirle\n            if (e.clientY > center) {\n                // Hedefin altına bırakılıyor, dizini 1 artır\n                finalInsertIndex += 1;\n            }\n            \n            // Eğer aynı yere veya hemen yanına bırakılıyorsa işlemi iptal et\n            if (draggedItemIndex === finalInsertIndex || draggedItemIndex + 1 === finalInsertIndex) {\n                renderSortableList(); \n                return;\n            }\n\n            // 3. Öğeyi mevcut konumundan kaldır ve taşı\n            const itemToMove = currentOrder.splice(draggedItemIndex, 1)[0];\n            \n            // 4. Eğer öğeyi aşağı taşıdıysak (draggedIndex < finalInsertIndex), \n            // array'den çıkarma işlemi ekleme noktasından önce olduğu için ekleme dizinini 1 azaltmalıyız.\n            if (draggedItemIndex < finalInsertIndex) {\n                finalInsertIndex -= 1;\n            }\n            \n            // 5. Öğeyi yeni konuma ekle\n            currentOrder.splice(finalInsertIndex, 0, itemToMove);\n\n            // 6. Listeyi yeniden render et\n            renderSortableList();\n        }\n\n        // --- Genel Etkinlik Fonksiyonları ---\n\n        // Etkinliği başlat/sıfırla\n        function resetActivity() {\n            // Olayları karıştır\n            currentOrder = shuffle([...events]);\n            renderSortableList();\n            feedbackDiv.textContent = \"\";\n            feedbackDiv.classList.remove('bg-green-700', 'bg-red-700');\n        }\n\n        // Sıralanabilir listeyi render et\n        function renderSortableList() {\n            sortableList.innerHTML = '';\n            currentOrder.forEach((event, index) => {\n                const li = document.createElement('li');\n                li.setAttribute('data-id', event.id);\n                li.setAttribute('draggable', 'true'); // Sürüklemeye izin ver\n\n                // Sürükle-bırak event listener'ları\n                li.addEventListener('dragstart', dragStart);\n                li.addEventListener('dragover', dragOver);\n                li.addEventListener('drop', drop);\n                li.addEventListener('dragend', dragEnd);\n\n                li.innerHTML = `\n                    <div class=\"flex items-center space-x-4\">\n                        <span class=\"text-xl text-gray-400 font-extrabold w-8\">${index + 1}.</span>\n                        <div>\n                            <p class=\"font-bold text-lg text-blue-300\">${event.name}</p>\n                            <p class=\"text-sm text-gray-400\">${event.description}</p>\n                        </div>\n                    </div>\n                `;\n                sortableList.appendChild(li);\n            });\n        }\n\n        // Sıralamayı kontrol etme\n        function checkOrder() {\n            const userOrderIds = currentOrder.map(e => e.id);\n            const correctOrderIds = events.map(e => e.id);\n\n            const isCorrect = userOrderIds.every((id, index) => id === correctOrderIds[index]);\n\n            feedbackDiv.classList.remove('bg-green-700', 'bg-red-700');\n\n            if (isCorrect) {\n                feedbackDiv.textContent = \"Tebrikler! Sıralama DOĞRU. Mükemmel bir kronoloji bilgisine sahipsiniz!\";\n                feedbackDiv.classList.add('bg-green-700');\n            } else {\n                feedbackDiv.textContent = \"Sıralama YANLIŞ. Bazı olayların kronolojik sırasını kontrol ediniz ve tekrar deneyiniz.\";\n                feedbackDiv.classList.add('bg-red-700');\n            }\n        }\n\n        // Görünüm değiştirme (Listeden Etkinliğe, Etkinlikten Listeye)\n        function switchView(viewId) {\n            // Tüm görünümleri gizle\n            document.getElementById('list-view').classList.add('hidden');\n            document.getElementById('activity-view').classList.add('hidden');\n            document.getElementById('firsts-view').classList.add('hidden');\n            \n            // Tüm butonlardan aktif sınıfı kaldır\n            listBtn.classList.remove('active-tab');\n            activityBtn.classList.remove('active-tab');\n            firstsViewBtn.classList.remove('active-tab');\n            \n            // Mevcut görünümü göster ve aktif butonu ayarla\n            document.getElementById(viewId).classList.remove('hidden');\n\n            if (viewId === 'list-view') {\n                listBtn.classList.add('active-tab');\n                document.getElementById('subtitle-text').textContent = \"İlk Vahiyden Veda Hutbesi'ne Önemli Olaylar\";\n            } else if (viewId === 'activity-view') {\n                activityBtn.classList.add('active-tab');\n                document.getElementById('subtitle-text').textContent = \"Bilgi Pekiştirme Etkinliği\";\n                resetActivity(); // Etkinlik görünümüne geçince listeyi karıştır\n            } else if (viewId === 'firsts-view') {\n                firstsViewBtn.classList.add('active-tab');\n                document.getElementById('subtitle-text').textContent = \"İslamiyetin Başlangıç Adımları ve İlkleri\";\n            }\n        }\n\n        // Başlangıçta olay listesini göster ve aktif sekme yap\n        document.addEventListener('DOMContentLoaded', () => {\n            switchView('list-view');\n        });\n    </script>\n</body>\n</html>\n"
}