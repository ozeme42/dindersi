{
  "title": "2️⃣ Ramazan ve Oruç",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>2. Ünite: Oruç ve Kur'an Ayı Ramazan</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@300;400;500;700&display=swap');\n        @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap');\n\n        /* --- GENEL AYARLAR (Ramazan Teması: Koyu Yeşil/Altın/Gece Mavisi) --- */\n        body {\n            margin: 0; padding: 0;\n            background: linear-gradient(135deg, #064e3b 0%, #1e1b4b 100%);\n            font-family: 'Roboto', sans-serif;\n            color: #fff;\n            box-sizing: border-box;\n            height: 100vh; width: 100vw;\n            overflow: hidden; \n        }\n\n        /* --- ANA KAPLAYICI --- */\n        #app-wrapper {\n            width: 100%; height: 100%;\n            display: flex; justify-content: center; align-items: center;\n        }\n\n        #app-container {\n            width: 1500px; height: 850px;\n            background: rgba(6, 78, 59, 0.95); /* Koyu Yeşil Opak */\n            border: 4px solid #fbbf24; /* Altın Çerçeve */\n            border-radius: 30px;\n            box-shadow: 0 40px 80px rgba(0,0,0,0.8);\n            position: relative;\n            display: flex; flex-direction: column;\n            overflow: hidden;\n            transform-origin: center center;\n            transition: transform 0.2s;\n        }\n\n        /* --- MENÜ EKRANI --- */\n        #menu-screen {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(6, 78, 59, 0.98);\n            z-index: 50;\n            display: flex; flex-direction: column; align-items: center; justify-content: center;\n            overflow-y: auto;\n        }\n        .menu-title { font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #fbbf24; margin-bottom: 40px; text-align: center; text-shadow: 0 4px 10px rgba(0,0,0,0.5); }\n        .menu-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 25px; width: 90%; max-width: 1200px; }\n        .menu-btn {\n            background: rgba(255, 255, 255, 0.1); border: 2px solid #fbbf24;\n            padding: 25px; border-radius: 20px; cursor: pointer;\n            transition: transform 0.2s, background 0.2s; text-align: left;\n            display: flex; flex-direction: column; align-items: center; gap: 15px; text-align: center;\n        }\n        .menu-btn:hover { transform: scale(1.03); background: rgba(251, 191, 36, 0.2); }\n        .menu-icon { font-size: 3rem; }\n        .menu-text h3 { margin: 0; font-size: 1.3rem; color: #fbbf24; }\n        .menu-text p { margin: 5px 0 0 0; color: #d1d5db; font-size: 0.9rem; }\n\n        /* --- ÜNİTE ARAYÜZÜ --- */\n        .header-bar {\n            height: 80px; border-bottom: 2px solid rgba(251, 191, 36, 0.3);\n            display: flex; align-items: center; justify-content: space-between;\n            padding: 0 40px; background: rgba(0,0,0,0.3); flex-shrink: 0;\n        }\n        .header-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #fbbf24; }\n        .home-btn { background: none; border: 1px solid #fbbf24; color: #fbbf24; padding: 5px 15px; border-radius: 5px; cursor: pointer; font-size: 1rem; }\n\n        .slide-content {\n            flex: 1; padding: 40px 50px; display: flex; gap: 40px;\n            overflow-y: auto; position: relative; animation: fadeIn 0.5s ease-out;\n        }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }\n\n        .text-panel { flex: 1.4; padding-right: 20px; font-size: 1.1rem; line-height: 1.6; color: #e2e8f0; }\n        .text-panel h2 {\n            font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #fff;\n            margin-top: 0; margin-bottom: 15px; border-bottom: 3px solid #fbbf24; display: inline-block;\n        }\n\n        .visual-panel {\n            flex: 0.6; display: flex; flex-direction: column; justify-content: center; align-items: center;\n            background: rgba(255,255,255,0.03); border-radius: 20px; padding: 30px; border: 1px dashed rgba(251, 191, 36, 0.3);\n        }\n        .visual-icon { font-size: 7rem; margin-bottom: 20px; filter: drop-shadow(0 0 15px rgba(251,191,36,0.4)); }\n        \n        .activity-btn {\n            background: linear-gradient(45deg, #fbbf24, #d97706); border: none; padding: 15px 30px;\n            font-size: 1.3rem; font-weight: bold; color: #0f172a; border-radius: 50px; cursor: pointer;\n            width: 100%; box-shadow: 0 10px 20px rgba(251, 191, 36, 0.3); animation: pulse 2s infinite;\n        }\n        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.03); } 100% { transform: scale(1); } }\n\n        .controls-bar {\n            height: 80px; padding: 0 40px; display: flex; justify-content: space-between; align-items: center;\n            background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.1); flex-shrink: 0;\n        }\n        .nav-btn {\n            background: transparent; border: 2px solid #fbbf24; color: #fbbf24; padding: 10px 30px;\n            font-size: 1.1rem; border-radius: 10px; cursor: pointer;\n        }\n        .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; border-color: #777; color: #777; }\n\n        /* --- ÖZEL İÇERİK STİLLERİ --- */\n        .concept-table { width: 100%; border-collapse: collapse; margin-top: 20px; background: rgba(255,255,255,0.05); }\n        .concept-table th { text-align: left; padding: 12px; color: #fbbf24; background: rgba(0,0,0,0.2); }\n        .concept-table td { padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.1); }\n        \n        .info-card { background: rgba(255, 255, 255, 0.05); border-left: 4px solid #fbbf24; padding: 15px; margin-bottom: 15px; border-radius: 0 10px 10px 0; }\n        .quote { font-style: italic; background: rgba(251, 191, 36, 0.1); padding: 15px; border-left: 4px solid #fbbf24; margin: 15px 0; color: #fcd34d; }\n        .arabic-text { font-family: 'Amiri', serif; font-size: 2rem; color: #fbbf24; display: block; margin-bottom: 10px; direction: rtl; }\n\n        /* OYUN MODALI */\n        #activity-overlay {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(6, 78, 59, 0.98); z-index: 100; display: none;\n            flex-direction: column; align-items: center; padding: 40px; box-sizing: border-box;\n        }\n        .activity-header { font-family: 'Playfair Display', serif; font-size: 2.5rem; color: #fbbf24; margin-bottom: 20px; text-align: center; }\n        .close-activity { position: absolute; top: 20px; right: 20px; background: transparent; border: none; color: #fff; font-size: 2rem; cursor: pointer; }\n        .game-area { width: 80%; height: 70%; background: rgba(255,255,255,0.05); border-radius: 20px; padding: 30px; display: flex; flex-direction: column; align-items: center; overflow-y: auto; }\n        .feedback-msg { margin-top: 10px; font-size: 1.5rem; height: 30px; font-weight: bold; text-align: center; }\n        .success { color: #34d399; } .error { color: #f87171; }\n\n        /* OYUNLAR */\n        .match-container { display: flex; justify-content: space-between; width: 100%; gap: 30px; }\n        .match-col { flex: 1; display: flex; flex-direction: column; gap: 15px; }\n        .match-item { background: #065f46; padding: 15px; text-align: center; border-radius: 10px; cursor: pointer; border: 2px solid transparent; display: flex; align-items: center; justify-content: center; min-height: 50px; }\n        .match-item.selected { border-color: #fbbf24; background: #047857; }\n        .match-item.matched { background: #059669; opacity: 0.5; pointer-events: none; }\n        .match-item.wrong { background: #dc2626; animation: shake 0.4s; }\n        \n        .quiz-option { width: 90%; padding: 15px; margin: 10px; background: #065f46; border: 2px solid #34d399; border-radius: 10px; cursor: pointer; text-align: left; font-size: 1.1rem; }\n        \n        .sort-container { width: 80%; display: flex; flex-direction: column; gap: 10px; }\n        .sort-item { background: #065f46; padding: 15px; border-radius: 8px; border-left: 5px solid #fbbf24; cursor: pointer; }\n\n        .anagram-container { text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center; }\n        .anagram-slots { display: flex; gap: 10px; margin-bottom: 30px; flex-wrap: wrap; justify-content: center; }\n        .anagram-slot { width: 45px; height: 55px; border-bottom: 4px solid #fbbf24; font-size: 2rem; color: #fbbf24; display: flex; justify-content: center; align-items: center; }\n        .letter-pool { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }\n        .letter-btn { width: 55px; height: 55px; background: #065f46; color: #fff; border: 2px solid #34d399; border-radius: 10px; font-size: 1.5rem; cursor: pointer; }\n        .letter-btn.correct { opacity: 0; pointer-events: none; }\n        .letter-btn.wrong { background: #dc2626; animation: shake 0.4s; }\n\n        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } 100% { transform: translateX(0); } }\n\n        /* MOBİL UYUMLULUK */\n        @media screen and (max-width: 1024px) {\n            body { overflow-y: auto; height: auto; }\n            #app-wrapper { display: block; height: auto; }\n            #app-container { width: 100%; height: auto; min-height: 100vh; border: none; border-radius: 0; transform: none !important; box-shadow: none; }\n            #menu-screen { position: relative; height: auto; min-height: 100vh; padding: 40px 20px; justify-content: flex-start; }\n            .menu-title { font-size: 2.5rem; margin-bottom: 30px; }\n            .menu-grid { grid-template-columns: 1fr; width: 100%; gap: 15px; }\n            .menu-btn { flex-direction: row; padding: 20px; text-align: left; }\n            .header-bar { padding: 10px 20px; flex-direction: column; height: auto; gap: 10px; }\n            .slide-content { flex-direction: column; padding: 20px; overflow: visible; }\n            .text-panel, .visual-panel { width: 100%; flex: none; padding-right: 0; }\n            .visual-panel { margin-top: 20px; }\n            .visual-icon { font-size: 4rem; }\n            #activity-overlay { position: fixed; height: 100%; padding: 10px; z-index: 9999; }\n            .game-area { width: 95%; height: 85%; padding: 10px; justify-content: flex-start; }\n            .match-container { flex-direction: column; gap: 10px; }\n            .match-item { font-size: 0.9rem; height: auto; padding: 10px; }\n            .quiz-option { width: 100%; }\n            .letter-btn { width: 40px; height: 40px; font-size: 1.2rem; }\n            .anagram-slot { width: 30px; height: 40px; font-size: 1.5rem; }\n            .controls-bar { padding: 10px 20px; position: sticky; bottom: 0; background: #064e3b; z-index: 50; }\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"app-wrapper\">\n    <div id=\"app-container\">\n        <!-- MENÜ EKRANI -->\n        <div id=\"menu-screen\">\n            <h1 class=\"menu-title\">2. Ünite: Ramazan ve Oruç</h1>\n            <div class=\"menu-grid\">\n                <div class=\"menu-btn\" onclick=\"selectUnit(0)\">\n                    <span class=\"menu-icon\">🌙</span>\n                    <div class=\"menu-text\"><h3>2.1 Ramazan, Oruç ve Kur'an</h3><p>Orucun anlamı, Kadir Gecesi ve önemi.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(1)\">\n                    <span class=\"menu-icon\">💡</span>\n                    <div class=\"menu-text\"><h3>2.2 Ramazan ve Oruç Kavramları</h3><p>Sahur, İmsak, İftar, Teravih, Mukabele, Fitre.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(2)\">\n                    <span class=\"menu-icon\">⚠️</span>\n                    <div class=\"menu-text\"><h3>2.3 Oruç Kuralları</h3><p>Dikkat edilecekler, Bozan/Bozmayan durumlar.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(3)\">\n                    <span class=\"menu-icon\">📚</span>\n                    <div class=\"menu-text\"><h3>2.4 Oruç Çeşitleri</h3><p>Farz, Vacip ve Sünnet Oruçlar.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(4)\">\n                    <span class=\"menu-icon\">❤️</span>\n                    <div class=\"menu-text\"><h3>2.5 Orucun Kazandırdıkları</h3><p>Bireysel ve toplumsal faydalar.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(5)\">\n                    <span class=\"menu-icon\">🤲</span>\n                    <div class=\"menu-text\"><h3>2.6 Bir Dua: İftar Duası</h3><p>Anlamı ve önemi.</p></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- ÜNİTE EKRANI -->\n        <div id=\"unit-screen\" style=\"display:none; flex-direction:column; height:100%;\">\n            <div class=\"header-bar\">\n                <div style=\"display:flex; align-items:center; gap:15px; width:100%; justify-content:space-between;\">\n                    <button class=\"home-btn\" onclick=\"returnToMenu()\">🏠 Menü</button>\n                    <div class=\"header-title\" id=\"unit-title\">Başlık</div>\n                    <div class=\"progress-indicator\" style=\"font-size:0.9rem;\">Sf <span id=\"current-page\">1</span></div>\n                </div>\n            </div>\n\n            <div id=\"slide-container\" class=\"slide-content\"></div>\n\n            <div class=\"controls-bar\">\n                <button id=\"prev-btn\" class=\"nav-btn\" onclick=\"prevSlide()\">❮ Geri</button>\n                <button id=\"next-btn\" class=\"nav-btn\" onclick=\"nextSlide()\">İleri ❯</button>\n            </div>\n        </div>\n\n        <!-- OYUN MODALI -->\n        <div id=\"activity-overlay\">\n            <button class=\"close-activity\" onclick=\"closeActivity()\">✕</button>\n            <div class=\"activity-header\" id=\"activity-title\">Etkinlik</div>\n            <div class=\"game-area\" id=\"game-board\"></div>\n            <div class=\"feedback-msg\" id=\"feedback\"></div>\n        </div>\n    </div>\n</div>\n\n<script>\n    /* --- İÇERİK VERİSİ --- */\n    const units = [\n        // 2.1 RAMAZAN, ORUÇ VE KUR'AN\n        {\n            title: \"2.1 Ramazan, Oruç ve Kur'an\",\n            slides: [\n                {\n                    title: \"Oruç Nedir?\",\n                    content: `<p><strong>Oruç:</strong> Sözlükte \"bir şeyden uzak durmak, kendini tutmak\" demektir. Terim olarak; Allah rızası için tan yerinin ağarmasından (imsak) güneş batıncaya kadar (iftar) yeme, içme ve nefsi isteklerden uzak durmaktır.</p><p>İslam'ın beş şartından biridir. Hicri takvimin 9. ayı olan Ramazan'da tutulur.</p>`,\n                    icon: \"🌙\", activityType: \"quiz\", activityTitle: \"Tanım Testi\",\n                    activityData: [{q:\"Oruç hangi vakitler arasında tutulur?\", options:[\"İmsak - İftar\", \"Sabah - Öğle\"], a:\"İmsak - İftar\"}, {q:\"Ramazan hicri takvimin kaçıncı ayıdır?\", options:[\"1.\", \"9.\"], a:\"9.\"}]\n                },\n                {\n                    title: \"Kadir Gecesi ve Kur'an\",\n                    content: `<p>Ramazan ayına \"Kur'an Ayı\" denir çünkü Kur'an bu ayda indirilmeye başlanmıştır. İndirilmeye başlandığı geceye <strong>Kadir Gecesi</strong> denir.</p><div class=\"quote\">\"Şüphesiz, biz onu (Kur’an’ı) Kadir Gecesi’nde indirdik... Kadir Gecesi bin aydan daha hayırlıdır.\" (Kadir Suresi)</div><p>Hz. Muhammed (sav) bu gecenin ibadetle geçirilmesini tavsiye etmiştir.</p>`,\n                    icon: \"✨\", activityType: \"quiz\", activityTitle: \"Bilgi Kontrolü\",\n                    activityData: [{q:\"Kur'an hangi gecede indirilmeye başlandı?\", options:[\"Miraç\", \"Kadir\"], a:\"Kadir\"}, {q:\"Kadir Gecesi neyden daha hayırlıdır?\", options:[\"Bin aydan\", \"Yüz yıldan\"], a:\"Bin aydan\"}]\n                }\n            ]\n        },\n        // 2.2 KAVRAMLAR\n        {\n            title: \"2.2 Ramazan ve Oruç Kavramları\",\n            slides: [\n                {\n                    title: \"Sahur, İmsak ve İftar\",\n                    content: `<ul style=\"line-height:1.8;\"><li><strong>SAHUR:</strong> Oruç tutmak için imsaktan önce yemek yenilen vakit. \"Sahurda bereket vardır.\"</li><li><strong>İMSAK:</strong> Oruca başlama vakti (Tan yerinin ağarması). Sabah namazı vakti de girer.</li><li><strong>İFTAR:</strong> Orucu açma vakti (Akşam ezanı). İftar ettirmek sevaptır.</li></ul>`,\n                    icon: \"🍽️\", activityType: \"matching\", activityTitle: \"Kavramları Eşleştir\",\n                    activityData: [{term:\"Sahur\", def:\"Oruç öncesi yemek vakti\"}, {term:\"İmsak\", def:\"Oruca başlama vakti\"}, {term:\"İftar\", def:\"Orucu açma vakti\"}, {term:\"İmsakiye\", def:\"Vakit çizelgesi\"}]\n                },\n                {\n                    title: \"Teravih, Mukabele ve Fitre\",\n                    content: `<ul style=\"line-height:1.8;\"><li><strong>TERAVİH:</strong> Ramazanda yatsıdan sonra kılınan 20 rekâtlık sünnet namaz.</li><li><strong>MUKABELE:</strong> Birinin Kur'an okuması, diğerlerinin takip etmesi (Hatim indirme geleneği).</li><li><strong>FİTRE (Fıtır Sadakası):</strong> Ramazanda verilmesi vacip olan sadaka. Bayram namazına kadar verilmelidir.</li></ul>`,\n                    icon: \"🕌\", activityType: \"matching\", activityTitle: \"Kavramları Eşleştir 2\",\n                    activityData: [{term:\"Teravih\", def:\"Ramazan özel namazı\"}, {term:\"Mukabele\", def:\"Karşılıklı Kur'an okuma\"}, {term:\"Fitre\", def:\"Vacip sadaka\"}, {term:\"Hatim\", def:\"Kur'an'ı baştan sona okumak\"}]\n                }\n            ]\n        },\n        // 2.3 ORUÇ KURALLARI\n        {\n            title: \"2.3 Oruç Kuralları\",\n            slides: [\n                {\n                    title: \"Dikkat Edilmesi Gerekenler\",\n                    content: `<p>Oruç sadece aç kalmak değildir. Kötü söz ve davranışlardan da uzak durulmalıdır. Niyet etmek şarttır (\"Niyet ettim Allah rızası için...\").</p><div class=\"info-card\"><strong>Mazaretler:</strong> Hasta ve yolcular oruç tutmayabilir, sonra kaza ederler. İyileşemeyecek hastalar fidye verir.</div>`,\n                    icon: \"⚠️\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Orucu Bozan ve Bozmayan Şeyler\",\n                    content: `<p><strong>Bozanlar:</strong> Bilerek yemek-içmek, ilaç almak.</p><p><strong>Bozmayanlar:</strong> Unutarak yemek (hatırlayınca bırakılır), banyo yapmak, koku sürünmek, kan vermek.</p>`,\n                    icon: \"🚫\", activityType: \"ordering\", activityTitle: \"Doğru Gruba Yerleştir (Zihinden)\",\n                    activityData: [\"Bilerek yemek yemek (Bozar)\", \"Unutarak su içmek (Bozmaz)\", \"İlaç içmek (Bozar)\", \"Banyo yapmak (Bozmaz)\"]\n                }\n            ]\n        },\n        // 2.4 ORUÇ ÇEŞİTLERİ\n        {\n            title: \"2.4 Oruç Çeşitleri\",\n            slides: [\n                {\n                    title: \"Oruç Türleri\",\n                    content: `<table class=\"concept-table\"><tr><th>TÜR</th><th>AÇIKLAMA</th></tr><tr><td><strong>FARZ</strong></td><td>Ramazan orucu, Kaza orucu, Kefaret orucu.</td></tr><tr><td><strong>VACİP</strong></td><td>Adak (Nezir) orucu. (Dilek gerçekleşince tutulan).</td></tr><tr><td><strong>SÜNNET</strong></td><td>Muharrem (Aşure), Şevval (6 gün) oruçları.</td></tr></table>`,\n                    icon: \"📋\", activityType: \"matching\", activityTitle: \"Oruçları Sınıflandır\",\n                    activityData: [{term:\"Ramazan Orucu\", def:\"Farz\"}, {term:\"Adak Orucu\", def:\"Vacip\"}, {term:\"Muharrem Orucu\", def:\"Sünnet\"}, {term:\"Kaza Orucu\", def:\"Farz\"}]\n                }\n            ]\n        },\n        // 2.5 KAZANDIRDIKLARI\n        {\n            title: \"2.5 Orucun Kazandırdıkları\",\n            slides: [\n                {\n                    title: \"Bireysel ve Toplumsal Faydalar\",\n                    content: `<p><strong>Bireysel:</strong> Sabrı öğretir, iradeyi güçlendirir, sağlığı korur (\"Oruç tutun, sıhhat bulun\"), şükrü artırır.</p><p><strong>Toplumsal:</strong> Yardımlaşmayı (Fitre/Zekat), paylaşmayı (İftar sofraları), empatiyi (Açların halinden anlama) geliştirir.</p>`,\n                    icon: \"❤️\", activityType: \"anagram\", activityTitle: \"Değerleri Bul\",\n                    activityData: [{scrambled:\"SABIR\", answer:\"SABIR\", hint:\"Orucun yarısıdır\"}, {scrambled:\"EMPATİ\", answer:\"EMPATİ\", hint:\"Başkasını anlama\"}, {scrambled:\"SAĞLIK\", answer:\"SAĞLIK\", hint:\"Vücudun kazancı\"}]\n                }\n            ]\n        },\n        // 2.6 İFTAR DUASI\n        {\n            title: \"2.6 İftar Duası\",\n            slides: [\n                {\n                    title: \"İftar Duası ve Anlamı\",\n                    content: `<div class=\"info-card\"><span class=\"arabic-text\">اَللّٰهُمَّ لَكَ صُمْتُ وَ بِكَ اٰمَنْتُ وَ عَلَيْكَ تَوَكَّلْتُ وَ عَلٰى رِزْقِكَ اَفْطَرْتُ</span></div><p><strong>Anlamı:</strong> \"Allah'ım! Senin rızan için oruç tuttum, sana inandım, sana güvendim. Senin rızkınla orucumu açtım.\"</p><p>İftar vaktinde yapılan dualar geri çevrilmez.</p>`,\n                    icon: \"🤲\", activityType: \"ordering\", activityTitle: \"Duayı Sırala\",\n                    activityData: [\"Allah'ım! Senin rızan için oruç tuttum.\", \"Sana inandım.\", \"Sana güvendim.\", \"Senin rızkınla orucumu açtım.\"]\n                }\n            ]\n        }\n    ];\n\n    /* --- DURUM YÖNETİMİ --- */\n    let currentUnitIdx = 0;\n    let currentSlideIdx = 0;\n    let currentData = null;\n    let selectedItem = null;\n    let anagramIndex = 0;\n    let currentAnagramState = { word:\"\", pos:0 };\n\n    /* --- GÖRÜNÜM KONTROLÜ --- */\n    function init() {\n        fitScreen();\n        window.addEventListener('resize', fitScreen);\n    }\n\n    function selectUnit(index) {\n        currentUnitIdx = index;\n        currentSlideIdx = 0;\n        document.getElementById('menu-screen').style.display = 'none';\n        document.getElementById('unit-screen').style.display = 'flex';\n        document.getElementById('unit-title').textContent = units[index].title;\n        renderSlide();\n    }\n\n    function returnToMenu() {\n        document.getElementById('unit-screen').style.display = 'none';\n        document.getElementById('menu-screen').style.display = 'flex';\n    }\n\n    function renderSlide() {\n        const slide = units[currentUnitIdx].slides[currentSlideIdx];\n        const container = document.getElementById('slide-container');\n        document.getElementById('current-page').innerText = currentSlideIdx + 1;\n        document.getElementById('prev-btn').disabled = currentSlideIdx === 0;\n        document.getElementById('next-btn').disabled = currentSlideIdx === units[currentUnitIdx].slides.length - 1;\n\n        let btnHtml = slide.activityType !== \"none\"\n            ? `<button class=\"activity-btn\" onclick=\"openActivity()\">🎮 ETKİNLİK BAŞLAT</button>` \n            : `<div style=\"text-align:center; color:#fbbf24; font-size:1.2rem; margin-top:20px;\">Öğrendiklerini Tekrar Et</div>`;\n\n        container.innerHTML = `\n            <div class=\"text-panel\"><h2>${slide.title}</h2>${slide.content}</div>\n            <div class=\"visual-panel\"><div class=\"visual-icon\">${slide.icon}</div>${btnHtml}</div>\n        `;\n    }\n\n    function nextSlide() { if(currentSlideIdx < units[currentUnitIdx].slides.length-1) { currentSlideIdx++; renderSlide(); } }\n    function prevSlide() { if(currentSlideIdx > 0) { currentSlideIdx--; renderSlide(); } }\n\n    /* --- ETKİNLİK MOTORU --- */\n    function openActivity() {\n        const slide = units[currentUnitIdx].slides[currentSlideIdx];\n        const board = document.getElementById('game-board');\n        document.getElementById('activity-overlay').style.display = 'flex';\n        document.getElementById('activity-title').textContent = slide.activityTitle;\n        document.getElementById('feedback').textContent = \"\";\n        board.innerHTML = \"\";\n        currentData = slide.activityData;\n\n        if(slide.activityType === 'quiz') loadQuiz(board, currentData);\n        else if(slide.activityType === 'matching') loadMatching(board, currentData);\n        else if(slide.activityType === 'ordering') loadOrdering(board, currentData);\n        else if(slide.activityType === 'anagram') { anagramIndex=0; loadAnagram(board, currentData); }\n    }\n\n    function closeActivity() { document.getElementById('activity-overlay').style.display = 'none'; }\n\n    // 1. QUIZ\n    function loadQuiz(board, data) {\n        const show = (idx) => {\n            if(idx >= data.length) { board.innerHTML=\"<h2 class='success'>Harika! 🎉</h2>\"; return; }\n            let q = data[idx];\n            board.innerHTML = `<h3 style=\"font-size:1.5rem; text-align:center;\">${q.q}</h3><div id=\"opts\" style=\"width:100%; display:flex; flex-direction:column; align-items:center;\"></div>`;\n            q.options.forEach(opt => {\n                let btn = document.createElement(\"div\"); btn.className = \"quiz-option\"; btn.textContent = opt;\n                btn.onclick = function() { \n                    if(opt === q.a) { this.style.background=\"#059669\"; setTimeout(()=>show(idx+1), 600); }\n                    else { this.style.background=\"#dc2626\"; }\n                };\n                document.getElementById('opts').appendChild(btn);\n            });\n        };\n        show(0);\n    }\n\n    // 2. EŞLEŞTİRME\n    function loadMatching(board, data) {\n        board.innerHTML = `<div class=\"match-container\"><div class=\"match-col\" id=\"left\"></div><div class=\"match-col\" id=\"right\"></div></div>`;\n        let leftCol = document.getElementById('left');\n        let rightCol = document.getElementById('right');\n        let rightItems = [...data].sort(() => Math.random() - 0.5);\n\n        data.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.term; btn.dataset.pair = item.def;\n            btn.onclick = () => {\n                document.querySelectorAll('#left .match-item').forEach(e=>e.classList.remove('selected'));\n                if(!btn.classList.contains('matched')) { btn.classList.add('selected'); selectedItem = btn; }\n            };\n            leftCol.appendChild(btn);\n        });\n\n        rightItems.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.def;\n            btn.onclick = () => {\n                if(!selectedItem) return;\n                if(selectedItem.dataset.pair === btn.textContent) {\n                    selectedItem.classList.add('matched'); selectedItem.classList.remove('selected');\n                    btn.classList.add('matched'); selectedItem = null;\n                    if(document.querySelectorAll('#left .matched').length === data.length) document.getElementById('feedback').innerHTML=\"<span class='success'>Tebrikler!</span>\";\n                } else {\n                    btn.classList.add('wrong'); setTimeout(()=>btn.classList.remove('wrong'), 500);\n                }\n            };\n            rightCol.appendChild(btn);\n        });\n    }\n\n    // 3. SIRALAMA\n    function loadOrdering(board, data) {\n        board.innerHTML = `<p style=\"text-align:center;\">Sırasıyla seç:</p><div id=\"sort-area\" class=\"sort-container\"></div>`;\n        let area = document.getElementById('sort-area');\n        let shuffled = [...data].sort(()=>Math.random()-0.5);\n        let step = 0;\n\n        shuffled.forEach(txt => {\n            let div = document.createElement('div'); div.className = 'sort-item'; div.textContent = txt;\n            div.onclick = function() {\n                if(txt === data[step]) {\n                    this.style.background = '#059669'; this.style.pointerEvents='none'; step++;\n                    if(step === data.length) document.getElementById('feedback').innerHTML=\"<span class='success'>Doğru!</span>\";\n                } else {\n                    this.style.background = '#dc2626'; setTimeout(()=>this.style.background='#065f46', 500);\n                }\n            };\n            area.appendChild(div);\n        });\n    }\n\n    // 4. ANAGRAM\n    function loadAnagram(board, data) {\n        if(anagramIndex >= data.length) { board.innerHTML=\"<h2 class='success'>Bitti! 🎉</h2>\"; return; }\n        let item = data[anagramIndex];\n        currentAnagramState = { word: item.answer, pos: 0 };\n        board.innerHTML = `<div class=\"anagram-container\"><div style=\"margin-bottom:20px; color:#fbbf24;\">İpucu: ${item.hint}</div><div id=\"slots\" class=\"anagram-slots\"></div><div id=\"pool\" class=\"letter-pool\"></div></div>`;\n        \n        for(let i=0; i<item.answer.length; i++) {\n            let s = document.createElement('div'); s.className='anagram-slot'; s.id=`s-${i}`; document.getElementById('slots').appendChild(s);\n        }\n        item.scrambled.split('').forEach(char => {\n            let btn = document.createElement('button'); btn.className='letter-btn'; btn.textContent=char;\n            btn.onclick = function() {\n                if(char === currentAnagramState.word[currentAnagramState.pos]) {\n                    document.getElementById(`s-${currentAnagramState.pos}`).textContent = char;\n                    this.classList.add('correct'); currentAnagramState.pos++;\n                    if(currentAnagramState.pos >= item.answer.length) { anagramIndex++; setTimeout(()=>loadAnagram(board, data), 1000); }\n                } else {\n                    this.classList.add('wrong'); setTimeout(()=>this.classList.remove('wrong'), 400);\n                }\n            };\n            document.getElementById('pool').appendChild(btn);\n        });\n    }\n\n    /* --- ÖLÇEKLEME --- */\n    function fitScreen() {\n        if(window.innerWidth > 1024) {\n            const container = document.getElementById('app-container');\n            const scale = Math.min(window.innerWidth / 1540, window.innerHeight / 890);\n            container.style.transform = `scale(${scale})`;\n        } else {\n            document.getElementById('app-container').style.transform = 'none';\n        }\n    }\n\n    // Başlat\n    init();\n</script>\n</body>\n</html>"
}