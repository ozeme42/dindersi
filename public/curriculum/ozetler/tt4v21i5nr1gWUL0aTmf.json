{
  "title": "1. İnsanların Dokunulmazlıklarının Gözetilmesi",
  "htmlContent": "import React, { useState } from 'react';\nimport { Heart, BookOpen, Shield, Brain, Coins, Scroll, Quote, User, Info, ChevronDown, ChevronUp } from 'lucide-react';\n\nconst ProtectionCard = ({ title, icon: Icon, mainText, verse, hadith, details, colorClass }) => {\n  const [isOpen, setIsOpen] = useState(false);\n\n  return (\n    <div className={`bg-white rounded-xl shadow-lg border-t-4 ${colorClass} overflow-hidden transition-all duration-300 hover:shadow-xl`}>\n      <div className=\"p-6\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <div className={`p-3 rounded-full ${colorClass.replace('border-', 'bg-').replace('-500', '-100')}`}>\n            <Icon className={`w-8 h-8 ${colorClass.replace('border-', 'text-')}`} />\n          </div>\n          <h3 className=\"text-xl font-bold text-gray-800 ml-4 flex-1\">{title}</h3>\n        </div>\n        \n        <p className=\"text-gray-600 mb-4 text-sm leading-relaxed\">{mainText}</p>\n\n        {verse && (\n          <div className=\"bg-emerald-50 p-4 rounded-lg border border-emerald-100 mb-3 relative\">\n            <Quote className=\"w-4 h-4 text-emerald-300 absolute top-2 left-2\" />\n            <p className=\"text-emerald-900 text-sm italic pl-4 font-serif\">\"{verse.text}\"</p>\n            <p className=\"text-emerald-600 text-xs text-right mt-1 font-bold\">{verse.source}</p>\n          </div>\n        )}\n\n        <button \n          onClick={() => setIsOpen(!isOpen)}\n          className=\"w-full mt-2 flex items-center justify-center text-gray-500 hover:text-gray-700 text-sm font-medium transition-colors\"\n        >\n          {isOpen ? 'Daha Az Oku' : 'Detayları İncele'}\n          {isOpen ? <ChevronUp className=\"w-4 h-4 ml-1\" /> : <ChevronDown className=\"w-4 h-4 ml-1\" />}\n        </button>\n      </div>\n\n      {/* Expandable Content */}\n      <div className={`bg-gray-50 px-6 overflow-hidden transition-all duration-500 ease-in-out ${isOpen ? 'max-h-96 py-4 border-t' : 'max-h-0 py-0'}`}>\n        {hadith && (\n          <div className=\"mb-3\">\n             <h4 className=\"text-xs font-bold text-gray-400 uppercase tracking-wider mb-1\">Hadis-i Şerif</h4>\n             <p className=\"text-gray-700 text-sm italic border-l-2 border-gray-300 pl-3\">\"{hadith}\"</p>\n          </div>\n        )}\n        <div className=\"space-y-2\">\n          <h4 className=\"text-xs font-bold text-gray-400 uppercase tracking-wider mb-1\">Önemli Noktalar</h4>\n          <ul className=\"text-sm text-gray-600 space-y-1\">\n            {details.map((item, idx) => (\n              <li key={idx} className=\"flex items-start\">\n                <span className=\"mr-2 text-emerald-500\">•</span>\n                {item}\n              </li>\n            ))}\n          </ul>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nconst App = () => {\n  return (\n    <div className=\"min-h-screen bg-slate-50 font-sans selection:bg-emerald-100 selection:text-emerald-900\">\n      \n      {/* Header Section */}\n      <header className=\"bg-gradient-to-r from-emerald-900 to-teal-800 text-white pb-20 pt-16 px-4 relative overflow-hidden\">\n        <div className=\"absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none\">\n          {/* Abstract Pattern Imitation */}\n          <div className=\"w-64 h-64 border-8 border-white rounded-full absolute -top-20 -left-20\"></div>\n          <div className=\"w-96 h-96 border-8 border-white rounded-full absolute top-20 right-0\"></div>\n        </div>\n\n        <div className=\"max-w-6xl mx-auto text-center relative z-10\">\n          <div className=\"inline-block bg-emerald-800 bg-opacity-50 backdrop-blur-sm px-4 py-1 rounded-full text-emerald-200 text-sm font-medium mb-4 border border-emerald-700\">\n            2. Ünite: Peygamberimizin Evrensel Mesajları\n          </div>\n          <h1 className=\"text-4xl md:text-6xl font-extrabold tracking-tight mb-6 font-serif\">\n            İnsanların Dokunulmazlıklarının Gözetilmesi\n          </h1>\n          <p className=\"text-xl md:text-2xl text-emerald-100 max-w-3xl mx-auto font-light leading-relaxed\">\n            \"Bugün sizin için dininizi kemale erdirdim, size nimetimi tamamladım...\"\n            <span className=\"block text-sm mt-2 opacity-70\">(Mâide suresi, 3. ayet)</span>\n          </p>\n        </div>\n      </header>\n\n      {/* Intro Text */}\n      <div className=\"max-w-4xl mx-auto -mt-10 px-4 relative z-20 mb-16\">\n        <div className=\"bg-white p-8 rounded-xl shadow-xl border-b-4 border-amber-400\">\n          <div className=\"flex flex-col md:flex-row gap-6 items-center\">\n            <div className=\"md:w-1/4 flex justify-center\">\n              <div className=\"bg-amber-100 p-4 rounded-full\">\n                <User className=\"w-12 h-12 text-amber-600\" />\n              </div>\n            </div>\n            <div className=\"md:w-3/4\">\n              <h3 className=\"text-lg font-bold text-gray-800 mb-2\">Evrensel Mesaj</h3>\n              <p className=\"text-gray-600 leading-relaxed\">\n                Peygamberimiz (sav), insanların hayat tarzı ve alışkanlıklarında İslam'a aykırı olanları Kur'an önderliğinde düzeltmiştir. Veda Hutbesi'ndeki <strong>\"Ey İnsanlar!\"</strong> hitabı, mesajın sadece Müslümanlara değil, tüm insanlığa yönelik olduğunu gösterir. Her insan Allah katında biricik ve özeldir.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Main Grid - Zarurat-ı Hamse */}\n      <main className=\"max-w-7xl mx-auto px-4 pb-20\">\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n          \n          {/* Canın Korunması */}\n          <ProtectionCard \n            title=\"Canın Korunması\"\n            icon={Heart}\n            colorClass=\"border-red-500\"\n            mainText=\"İslam'da her insan; din, dil, ırk farkı gözetilmeksizin yaşama hakkına sahiptir. İnsan, yeryüzünün en şerefli varlığıdır.\"\n            verse={{\n              text: \"Kim; bir insanı... öldürürse o sanki bütün insanları öldürmüştür. Her kim de birini yaşatırsa sanki bütün insanları yaşatmıştır...\",\n              source: \"Mâide suresi, 32. ayet\"\n            }}\n            hadith=\"Kanlarınız, mallarınız, şeref ve namusunuz tıpkı bu beldenin, bu ayın ve bugünlerin mukaddes oluşu gibi dokunulmazdır.\"\n            details={[\n              \"Veda Haccı'nda kan davaları kaldırılmıştır.\",\n              \"Yaşam hakkı kutsaldır.\",\n              \"Kuvvetlilerin zayıfları ezmesi engellenmiştir.\"\n            ]}\n          />\n\n          {/* Dinin Korunması */}\n          <ProtectionCard \n            title=\"Dinin Korunması\"\n            icon={BookOpen}\n            colorClass=\"border-blue-500\"\n            mainText=\"İslam'da inanç hürriyeti esastır. Kimse dinini değiştirmeye zorlanamaz.\"\n            verse={{\n              text: \"Dinde zorlama yoktur...\",\n              source: \"Bakara suresi, 256. ayet\"\n            }}\n            hadith=\"Kim bir zimmiye haksızlık eder... kıyamet gününde o kişi beni karşısında bulacaktır.\"\n            details={[\n              \"Medine Sözleşmesi ile inanç özgürlüğü tanınmıştır.\",\n              \"Necranlı Hristiyanların mescitte ibadetine izin verilmiştir.\",\n              \"Farklılıklara saygı esastır.\"\n            ]}\n          />\n\n          {/* Namusun Korunması (Nesil) */}\n          <ProtectionCard \n            title=\"Namusun Korunması\"\n            icon={Shield}\n            colorClass=\"border-purple-500\"\n            mainText=\"İffetli olmak, mahremiyete saygı duymak ve nesli korumak İslam'ın temel amaçlarındandır.\"\n            verse={{\n              text: \"...Gözlerini haramdan sakınsınlar!..\",\n              source: \"Nûr suresi, 30-31. ayetler\"\n            }}\n            hadith=\"Cennete ilk girecek üç grup bana gösterildi: Şehit, iffetli ve kanaatkâr kimse...\"\n            details={[\n              \"İftira ve tecessüs (gizli halleri araştırma) yasaktır.\",\n              \"Evlerin mahremiyeti korunmuştur.\",\n              \"Aile yapısının korunması hedeflenmiştir.\"\n            ]}\n          />\n\n           {/* Aklın Korunması */}\n           <ProtectionCard \n            title=\"Aklın Korunması\"\n            icon={Brain}\n            colorClass=\"border-orange-500\"\n            mainText=\"İnsana verilen en büyük nimet akıldır. Kur'an sürekli aklı kullanmayı teşvik eder.\"\n            details={[\n              \"İçki, uyuşturucu ve kumar yasaklanmıştır.\",\n              \"Kin ve haset gibi manevi hastalıklardan uzak durulmalıdır.\",\n              \"Faydasız söz ve davranışlar aklı köreltir.\"\n            ]}\n          />\n\n          {/* Malın Korunması */}\n          <ProtectionCard \n            title=\"Malın Korunması\"\n            icon={Coins}\n            colorClass=\"border-yellow-500\"\n            mainText=\"Kişinin helal yoldan kazandığı mal dokunulmazdır. Haksız kazanç yolları kapatılmıştır.\"\n            details={[\n              \"Hırsızlık, gasp, rüşvet ve faiz yasaktır.\",\n              \"Çalışmak ibadet sayılmıştır.\",\n              \"Zekât ve sadaka ile sosyal denge sağlanır.\",\n              \"Hilfülfudul (Erdemliler Birliği) ile haksızlıklar önlenmiştir.\"\n            ]}\n          />\n\n          {/* Special Section: Okuma Kuşağı Summary */}\n          <div className=\"bg-slate-800 rounded-xl shadow-lg border-t-4 border-slate-600 overflow-hidden text-white flex flex-col justify-between\">\n            <div className=\"p-6\">\n               <div className=\"flex items-center mb-4\">\n                  <Scroll className=\"w-8 h-8 text-slate-300\" />\n                  <h3 className=\"text-xl font-bold ml-4\">Bir Hadis, Bir Ders</h3>\n               </div>\n               <div className=\"space-y-4 text-sm text-slate-300 italic\">\n                 <p>\"Malımı zorla almak isteyen birine karşı ne yapabilirim?\"</p>\n                 <div className=\"pl-4 border-l-2 border-slate-500\">\n                    <p className=\"mb-2\">Hz. Peygamber (sav) sırasıyla şunları tavsiye etmiştir:</p>\n                    <ol className=\"list-decimal pl-4 space-y-1 not-italic text-slate-200\">\n                      <li>Ona Allah'ı hatırlat.</li>\n                      <li>Müslümanlardan yardım iste.</li>\n                      <li>Resmi görevlilerden yardım iste.</li>\n                      <li>Hiçbiri olmazsa malını koru; ölürsen şehit olursun.</li>\n                    </ol>\n                 </div>\n                 <p className=\"text-xs text-right opacity-50\">(Nesâî, Muhârebe, 21)</p>\n               </div>\n            </div>\n            <div className=\"bg-slate-900 p-4 text-center\">\n               <span className=\"text-xs font-bold text-slate-400 tracking-widest\">MAL EMNİYETİ ESASTIR</span>\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Footer */}\n      <footer className=\"bg-slate-100 border-t border-slate-200 py-12\">\n        <div className=\"max-w-4xl mx-auto px-4 text-center\">\n          <Info className=\"w-8 h-8 text-slate-400 mx-auto mb-4\" />\n          <p className=\"text-slate-600 mb-2\">\n            Bu içerik, \"İnsanların Dokunulmazlıklarının Gözetilmesi\" ünitesi kapsamında hazırlanmıştır.\n          </p>\n          <p className=\"text-slate-400 text-sm\">\n            Kaynaklar: Kur'an-ı Kerim, Kütüb-i Sitte (Buhârî, Müslim, Tirmizî, Ebu Dâvûd, Nesâî)\n          </p>\n        </div>\n      </footer>\n    </div>\n  );\n};\n\nexport default App;"
}