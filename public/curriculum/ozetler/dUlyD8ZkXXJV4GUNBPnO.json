{
  "title": "1.İnsanlara Rehber: Peygamber",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Peygamber ve İlahi Kitap İnancı</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n        body {\n            font-family: 'Inter', sans-serif;\n        }\n    </style>\n</head>\n<body class=\"bg-slate-50 text-slate-800 p-4 md:p-8 min-h-screen\">\n\n    <!-- Header -->\n    <div class=\"max-w-5xl mx-auto bg-emerald-700 text-white rounded-xl shadow-lg p-8 mb-8 text-center relative overflow-hidden\">\n        <div class=\"absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none\">\n            <i data-lucide=\"star\" class=\"absolute -right-20 -top-20 w-[300px] h-[300px]\"></i>\n            <i data-lucide=\"book-open\" class=\"absolute -left-20 bottom-0 w-[200px] h-[200px]\"></i>\n        </div>\n        <h1 class=\"text-3xl md:text-5xl font-bold mb-2 relative z-10\">Peygamber ve İlahi Kitap İnancı</h1>\n        <p class=\"text-emerald-100 text-lg relative z-10\">İnsanlara Rehber: Peygamberler</p>\n    </div>\n\n    <div class=\"max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        <!-- Sol Kolon - Temel Bilgiler -->\n        <div class=\"lg:col-span-1 space-y-6\">\n            \n            <!-- Tanım Kartı -->\n            <div class=\"bg-white p-6 rounded-xl shadow-md border-l-4 border-emerald-500\">\n                <h2 class=\"text-xl font-bold mb-4 flex items-center gap-2\">\n                    <i data-lucide=\"book-open\" class=\"text-emerald-600\"></i> Temel Kavramlar\n                </h2>\n                <div class=\"space-y-4\">\n                    <div class=\"bg-slate-50 p-3 rounded-lg\">\n                        <span class=\"font-bold text-emerald-700 block\">Peygamber (Farsça)</span>\n                        <span class=\"text-sm\">Haber getiren, elçi.</span>\n                    </div>\n                    <div class=\"bg-slate-50 p-3 rounded-lg\">\n                        <span class=\"font-bold text-emerald-700 block\">Vahiy</span>\n                        <span class=\"text-sm\">Allah'ın emir ve yasaklarını peygamberlerine bildirmesi.</span>\n                    </div>\n                    <div class=\"grid grid-cols-2 gap-2\">\n                        <div class=\"bg-blue-50 p-2 rounded text-center\">\n                            <span class=\"font-bold text-blue-800 block text-sm\">Resul</span>\n                            <span class=\"text-xs\">Kendisine kitap verilen elçi.</span>\n                        </div>\n                        <div class=\"bg-orange-50 p-2 rounded text-center\">\n                            <span class=\"font-bold text-orange-800 block text-sm\">Nebi</span>\n                            <span class=\"text-xs\">Haberci, kendisine kitap verilmeyen.</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- İmanın Şartı -->\n            <div class=\"bg-emerald-800 text-white p-6 rounded-xl shadow-md\">\n                <h3 class=\"font-bold text-lg mb-2 flex items-center gap-2\">\n                    <i data-lucide=\"star\" class=\"text-yellow-400 fill-current\"></i>\n                    İmanın Şartı\n                </h3>\n                <p class=\"text-sm leading-relaxed opacity-90\">\n                    \"O'nun peygamberlerinden hiçbirini diğerinden ayırt etmeyiz.\" (Bakara, 285)\n                    <br/><br/>\n                    İlk Peygamber: <strong>Hz. Âdem</strong><br/>\n                    Son Peygamber: <strong>Hz. Muhammed (sav)</strong>\n                </p>\n            </div>\n\n        </div>\n\n        <!-- Orta Kolon - Özellikler ve Görevler -->\n        <div class=\"lg:col-span-2 space-y-6\">\n            \n            <!-- Peygamberlerin Sıfatları (JS ile doldurulacak) -->\n            <div class=\"bg-white p-6 rounded-xl shadow-md\">\n                <h2 class=\"text-xl font-bold mb-6 flex items-center gap-2 border-b pb-2\">\n                    <i data-lucide=\"user\" class=\"text-emerald-600\"></i> Peygamberlerin Sıfatları (Özellikleri)\n                </h2>\n                <div id=\"attributes-container\" class=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\n                    <!-- İçerik Script ile gelecek -->\n                </div>\n            </div>\n\n            <!-- Peygamberlerin Görevleri (JS ile doldurulacak) -->\n            <div class=\"bg-white p-6 rounded-xl shadow-md\">\n                <h2 class=\"text-xl font-bold mb-6 flex items-center gap-2 border-b pb-2\">\n                    <i data-lucide=\"zap\" class=\"text-emerald-600\"></i> Peygamberlerin Görevleri\n                </h2>\n                <div id=\"duties-container\" class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4\">\n                    <!-- İçerik Script ile gelecek -->\n                </div>\n            </div>\n\n            <!-- Mucizeler (JS ile doldurulacak) -->\n            <div class=\"bg-white p-6 rounded-xl shadow-md\">\n                <h2 class=\"text-xl font-bold mb-4 flex items-center gap-2 border-b pb-2\">\n                    <i data-lucide=\"lightbulb\" class=\"text-yellow-500\"></i> Mucizeler\n                </h2>\n                <p class=\"text-sm text-slate-600 mb-4 italic\">\n                    İnkarcılara meydan okumak ve aciz bırakmak için Allah'ın izniyle gösterilen olağanüstü olaylar.\n                </p>\n                <div id=\"miracles-container\" class=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                    <!-- İçerik Script ile gelecek -->\n                </div>\n            </div>\n\n        </div>\n\n    </div>\n\n    <!-- Alt Bölüm - Kur'an'da Adı Geçen Peygamberler -->\n    <div class=\"max-w-5xl mx-auto mt-8 bg-white p-6 rounded-xl shadow-lg\">\n        <h2 class=\"text-xl font-bold mb-4 flex items-center gap-2 text-emerald-800\">\n            <i data-lucide=\"users\" class=\"text-emerald-600\"></i> Kur'an'da Adı Geçen 25 Peygamber\n        </h2>\n        <div id=\"prophets-container\" class=\"flex flex-wrap gap-2 justify-center\">\n            <!-- İçerik Script ile gelecek -->\n        </div>\n        <div class=\"mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg flex items-start gap-3\">\n            <i data-lucide=\"info\" class=\"text-yellow-600 flex-shrink-0 mt-0.5\" size=\"18\"></i>\n            <p class=\"text-xs text-yellow-800\">\n                <strong>Not:</strong> Hz. Lokman, Hz. Üzeyir ve Hz. Zülkarneyn'in isimleri Kur'an'da geçmesine rağmen peygamber olup olmadıkları konusunda kesin bilgi yoktur.\n            </p>\n        </div>\n    </div>\n\n    <!-- JavaScript Verileri ve Render Mantığı -->\n    <script>\n        // Veriler\n        const prophets = [\n            \"Hz. Âdem\", \"Hz. İdris\", \"Hz. Nuh\", \"Hz. Hud\", \"Hz. Salih\", \n            \"Hz. İbrahim\", \"Hz. Lut\", \"Hz. İsmail\", \"Hz. İshak\", \"Hz. Yakub\", \n            \"Hz. Yusuf\", \"Hz. Eyyüb\", \"Hz. Şuayb\", \"Hz. Musa\", \"Hz. Harun\", \n            \"Hz. Davud\", \"Hz. Süleyman\", \"Hz. İlyas\", \"Hz. Elyesa\", \"Hz. Zülkifl\", \n            \"Hz. Yunus\", \"Hz. Zekeriyya\", \"Hz. Yahya\", \"Hz. İsa\", \"Hz. Muhammed (sav)\"\n        ];\n\n        const attributes = [\n            { name: \"Sıdk\", meaning: \"Doğruluk\", desc: \"Dürüst ve doğru sözlü olmak.\", icon: \"check-circle\" },\n            { name: \"Emanet\", meaning: \"Güvenilirlik\", desc: \"Emin ve güvenilir olmak.\", icon: \"shield\" },\n            { name: \"Fetanet\", meaning: \"Akıl\", desc: \"Akıllı ve zeki olmak, ikna kabiliyeti.\", icon: \"lightbulb\" },\n            { name: \"İsmet\", meaning: \"Günahsızlık\", desc: \"Günahtan korunmuş olmak.\", icon: \"heart\" },\n            { name: \"Tebliğ\", meaning: \"İletmek\", desc: \"Vahyi eksiksiz iletmek.\", icon: \"message-circle\" },\n        ];\n\n        const duties = [\n            { title: \"Tebliğ\", text: \"Allah'tan aldığı vahyi eksiksiz bildirmek.\", color: \"bg-blue-100 text-blue-800\" },\n            { title: \"Tebyin\", text: \"Emir ve yasakları açıklamak.\", color: \"bg-green-100 text-green-800\" },\n            { title: \"Temsil\", text: \"İnsanlara örnek olmak (Üsve-i Hasene).\", color: \"bg-purple-100 text-purple-800\" },\n            { title: \"İnzar\", text: \"Kötülüklere karşı uyarmak.\", color: \"bg-red-100 text-red-800\" },\n            { title: \"Tebşir\", text: \"İyileri müjdelemek.\", color: \"bg-yellow-100 text-yellow-800\" },\n            { title: \"Tezkiye\", text: \"Kötü huylardan arındırmak.\", color: \"bg-teal-100 text-teal-800\" }\n        ];\n\n        const miracles = [\n            { prophet: \"Hz. İbrahim\", event: \"Ateşin yakmaması\" },\n            { prophet: \"Hz. Musa\", event: \"Asasının yılan olması\" },\n            { prophet: \"Hz. İsa\", event: \"Ölüleri diriltmesi\" },\n            { prophet: \"Hz. Salih\", event: \"Kayadan deve çıkarması\" },\n            { prophet: \"Hz. Süleyman\", event: \"Hayvanlarla konuşması\" },\n            { prophet: \"Hz. Muhammed (sav)\", event: \"En büyük mucizesi Kur'an-ı Kerim\" },\n        ];\n\n        // Render Fonksiyonları\n        \n        // 1. Sıfatlar\n        const attrsContainer = document.getElementById('attributes-container');\n        attributes.forEach(attr => {\n            const div = document.createElement('div');\n            div.className = \"flex flex-col items-center text-center p-3 rounded-lg bg-slate-50 hover:bg-emerald-50 transition-colors border border-slate-100\";\n            div.innerHTML = `\n                <div class=\"bg-white p-2 rounded-full shadow-sm mb-2 text-emerald-600\">\n                    <i data-lucide=\"${attr.icon}\" width=\"20\" height=\"20\"></i>\n                </div>\n                <h4 class=\"font-bold text-emerald-800 text-sm\">${attr.name}</h4>\n                <span class=\"text-xs font-semibold text-slate-500 mb-1\">${attr.meaning}</span>\n                <p class=\"text-[10px] leading-tight text-slate-600\">${attr.desc}</p>\n            `;\n            attrsContainer.appendChild(div);\n        });\n\n        // 2. Görevler\n        const dutiesContainer = document.getElementById('duties-container');\n        duties.forEach(duty => {\n            const div = document.createElement('div');\n            div.className = `${duty.color} p-4 rounded-lg relative overflow-hidden group`;\n            div.innerHTML = `\n                <div class=\"absolute right-0 top-0 opacity-10 transform translate-x-2 -translate-y-2\">\n                    <i data-lucide=\"star\" width=\"40\" height=\"40\"></i>\n                </div>\n                <h3 class=\"font-bold text-lg mb-1\">${duty.title}</h3>\n                <p class=\"text-xs font-medium opacity-90\">${duty.text}</p>\n            `;\n            dutiesContainer.appendChild(div);\n        });\n\n        // 3. Mucizeler\n        const miraclesContainer = document.getElementById('miracles-container');\n        miracles.forEach(m => {\n            const div = document.createElement('div');\n            div.className = \"flex items-center gap-3 p-3 bg-slate-50 rounded-lg border-l-4 border-yellow-400\";\n            div.innerHTML = `\n                <div class=\"w-2 h-2 rounded-full bg-yellow-400 flex-shrink-0\"></div>\n                <div class=\"text-sm\">\n                    <span class=\"font-bold text-slate-800\">${m.prophet}:</span> <span class=\"text-slate-600\">${m.event}</span>\n                </div>\n            `;\n            miraclesContainer.appendChild(div);\n        });\n\n        // 4. Peygamberler Listesi\n        const prophetsContainer = document.getElementById('prophets-container');\n        prophets.forEach((name, index) => {\n            const span = document.createElement('span');\n            // İlk ve son peygamber için özel stil\n            const isFirstOrLast = index === 0 || index === prophets.length - 1;\n            span.className = `px-3 py-1.5 rounded-full text-sm font-medium border ${\n                isFirstOrLast \n                ? 'bg-emerald-600 text-white border-emerald-600 shadow-sm transform scale-105' \n                : 'bg-slate-50 text-slate-700 border-slate-200 hover:bg-emerald-50 hover:border-emerald-200 transition-colors'\n            }`;\n            span.textContent = name;\n            prophetsContainer.appendChild(span);\n        });\n\n        // İkonları oluştur\n        lucide.createIcons();\n    </script>\n</body>\n</html>"
}