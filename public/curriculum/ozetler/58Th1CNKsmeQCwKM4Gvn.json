{
  "title": "4.Ahiret Hayatının Aşamaları",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ahiret Yolculuğu: Ebedi Hayatın Aşamaları</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        /* Palet: Deep Night Sky (Dark Blue/Violet) with Cyan/Green Accents */\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #121223; /* Deep Dark Violet */\n        }\n        .flow-card {\n            background-color: #1D1D3A; /* Card Background */\n            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\n            border-bottom: 5px solid #4CAF50; /* Green Accent Bottom Border */\n            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -4px rgba(0, 0, 0, 0.2);\n        }\n        .flow-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6);\n            border-bottom-color: #00BCD4; /* Cyan on hover */\n        }\n        .final-card {\n             background-image: linear-gradient(135deg, #176B87, #053B50);\n             box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8);\n        }\n        .card-number {\n            font-weight: 900;\n            font-size: 1.5rem;\n            background-color: #00BCD4; /* Cyan Accent */\n            color: #121223;\n            width: 40px;\n            height: 40px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-radius: 50%;\n            flex-shrink: 0;\n            box-shadow: 0 0 10px rgba(0, 188, 212, 0.5);\n        }\n        /* SIRALAMA ETKİNLİĞİ STİLLERİ */\n        .sortable-item {\n            background-color: #1D1D3A;\n            border: 2px solid #4CAF50;\n            cursor: grab; /* Sürükleme imleci */\n            user-select: none; /* Metin seçimini engelle */\n            transition: all 0.2s;\n            transform: scale(1);\n        }\n        .sortable-item:nth-child(even) {\n            background-color: #1a1a33;\n        }\n        .sortable-item:active {\n            cursor: grabbing;\n        }\n        .sortable-item.dragging {\n            opacity: 0.5;\n            border-style: dashed;\n            border-color: #00BCD4;\n            transform: scale(1.01);\n        }\n        .nav-tab.active {\n            background-color: #1D1D3A; \n            color: #00BCD4;\n            border-bottom: 2px solid #00BCD4;\n        }\n        .nav-tab {\n            background-color: #121223;\n            color: #888;\n        }\n        .sort-number {\n            color: #00BCD4; /* Cyan Accent */\n            font-weight: 700;\n            font-size: 1.5rem;\n            width: 30px; /* Sabit genişlik */\n            text-align: right;\n        }\n    </style>\n</head>\n<body class=\"text-gray-200\">\n    <div class=\"container mx-auto p-4 md:p-8\">\n        <header class=\"text-center mb-10 pt-8\">\n            <h1 class=\"text-5xl md:text-7xl font-extrabold text-[#00BCD4] mb-4 tracking-tight\">Ebediyete Yolculuk</h1>\n            <p class=\"text-xl md:text-2xl text-[#E0E0E0] italic\">Ahiret Hayatının Yedi Ana Aşaması</p>\n        </header>\n\n        <main class=\"max-w-6xl mx-auto\">\n            <!-- Tab Navigasyonu (Sayfa Geçişi) -->\n            <nav class=\"flex justify-center space-x-4 mb-10 border-b border-[#1D1D3A]\">\n                <button id=\"tab-infographic\" onclick=\"switchView('infographic')\" class=\"nav-tab py-2 px-6 rounded-t-lg font-bold transition duration-300 active\">\n                    1. Sayfa: Infografik\n                </button>\n                <button id=\"tab-sorting\" onclick=\"switchView('sorting')\" class=\"nav-tab py-2 px-6 rounded-t-lg font-bold transition duration-300\">\n                    2. Sayfa: Sıralama Etkinliği\n                </button>\n            </nav>\n\n            <!-- 1. SAYFA: INFOGRAFİK -->\n            <div id=\"infographic-view\" class=\"view-content\">\n                <div class=\"text-center p-6 bg-[#1D1D3A] rounded-xl mb-12 shadow-lg border-b-4 border-[#4CAF50]\">\n                     <p class=\"text-lg text-gray-300\">İmtihan amacıyla gönderildiğimiz bu kısa dünya hayatı gelip geçicidir. İslam inancına göre ölüm bir son değil, sonsuzluğa giden yolculuğun ilk adımıdır. Aşağıdaki aşamalar, bu manevi serüvenin temel duraklarını göstermektedir.</p>\n                </div>\n\n                <!-- Aşamalar (Grid Düzeni) -->\n                <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12\">\n                    \n                    <!-- AŞAMA 1: ECEL VE ÖLÜM -->\n                    <div id=\"olum\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">1</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Ecel ve Ölüm</h2>\n                                <p class=\"text-sm text-gray-400\">Dünya Hayatının Perdesi Kapanıyor</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\">Her canlının belirli bir ömrü vardır. Ölüm, ruhun bedenden ayrılmasıyla gerçekleşir ve ahiret hayatına atılan ilk adımdır. <span class=\"font-semibold italic\">\"Her nefis ölümü tadacaktır.\"</span></p>\n                    </div>\n\n                    <!-- AŞAMA 2: KABİR HAYATI -->\n                    <div id=\"berzah\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">2</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Kabir Hayatı (Berzah)</h2>\n                                <p class=\"text-sm text-gray-400\">Ruhların Bekleyiş Durağı</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\">Ölümden sonra başlayıp yeniden dirilişe kadar süren ara bekleme dönemidir. Bu \"engel\" veya \"perde\" aleminde, ruhlar kıyameti bekler.</p>\n                    </div>\n\n                    <!-- AŞAMA 3: KIYAMET -->\n                    <div id=\"kiyamet\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">3</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Kıyamet</h2>\n                                <p class=\"text-sm text-gray-400\">Evrenin ve Tüm Canlıların Sonu</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\">İsrafil (a.s.)'ın Sûr'a ilk kez üflemesiyle evrenin düzeni bozulur ve dünya hayatı tüm varlıklar için toplu olarak son bulur.</p>\n                    </div>\n\n                    <!-- AŞAMA 4: BA'S -->\n                    <div id=\"bas\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">4</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Ba's (Yeniden Diriliş)</h2>\n                                <p class=\"text-sm text-gray-400\">İkinci Hayata Dönüş</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\">Sûr'a ikinci kez üflenmesiyle, ölen tüm insanlar ruh ve bedenleriyle birlikte yeniden hayata döndürülür. Hesap gününün başlangıcıdır.</p>\n                    </div>\n                    \n                    <!-- AŞAMA 5: HAŞR VE MAHŞER -->\n                    <div id=\"hasr\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">5</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Haşr ve Mahşer</h2>\n                                <p class=\"text-sm text-gray-400\">Büyük Hesaplaşma Meydanı</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\"><span class=\"font-semibold\">Haşr</span>, diriltilen insanların sorgulanmak üzere toplanma eylemidir. Bu toplanmanın gerçekleştiği geniş alana <span class=\"font-semibold\">Mahşer</span> denir.</p>\n                    </div>\n\n                    <!-- AŞAMA 6: HESAP, MİZAN, SIRAT -->\n                    <div id=\"hesap\" class=\"flow-card rounded-xl p-6 shadow-xl\">\n                        <div class=\"flex items-center mb-4\">\n                            <div class=\"card-number mr-3\">6</div>\n                            <div>\n                                <h2 class=\"text-xl font-bold text-[#00BCD4]\">Hesap, Mizan ve Sırat</h2>\n                                <p class=\"text-sm text-gray-400\">Adaletin Tezahürü</p>\n                            </div>\n                        </div>\n                        <p class=\"text-md text-gray-300\">Amel defterleri verilir, <span class=\"font-semibold\">Mizan</span> ile tartım yapılır ve sonrasında Cennet'e ulaşmak için cehennem üzerine kurulu <span class=\"font-semibold\">Sırat</span> köprüsünden geçiş denemesi yapılır.</p>\n                    </div>\n                </div>\n                \n                <!-- AŞAMA 7: EBEDİ YURT (Full Width Final Card) -->\n                <div id=\"sonuc\" class=\"final-card w-full rounded-xl shadow-2xl p-6 md:p-8 mt-10 mb-20\">\n                    <h2 class=\"text-4xl font-extrabold text-center text-white mb-8 tracking-wide\">7. Nihai Hedef: Sonsuz Yaşam (Cennet/Cehennem)</h2>\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 text-white\">\n                        <div class=\"p-6 rounded-lg border-2 border-[#4CAF50] bg-[#4CAF50]/30 transition duration-300 hover:bg-[#4CAF50]/50\">\n                            <h3 class=\"text-3xl font-semibold mb-3 text-[#4CAF50]\">Cennet (Mükâfat Yurdu) 🕌</h3>\n                            <p class=\"text-gray-200\">İman edip salih ameller işleyenlerin ebedî olarak kalacakları, içinden ırmaklar akan Adn cennetleridir. En büyük mükâfat, Allah'ın rızasına ulaşmaktır.</p>\n                        </div>\n                        <div class=\"p-6 rounded-lg border-2 border-red-400 bg-red-600/30 transition duration-300 hover:hover:bg-red-600/50\">\n                            <h3 class=\"text-3xl font-semibold mb-3 text-red-400\">Cehennem (Azap Yurdu) 🔥</h3>\n                            <p class=\"text-gray-200\">İman etmeyen ve kötü işler yapanların davranışlarının karşılığını göreceği azap yurdudur. Kur'an'da çeşitli şekillerde tasvir edilmiştir.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- 2. SAYFA: SIRALAMA ETKİNLİĞİ -->\n            <section id=\"sorting-view\" class=\"view-content hidden max-w-xl mx-auto py-12 px-4\">\n                <h2 class=\"text-4xl font-bold text-center text-[#00BCD4] mb-8\">Aşamaları Sıralayın</h2>\n                <p class=\"text-center text-gray-300 mb-6\">Kartları tutun ve sürükleyerek Ahiret yolculuğunun doğru sırasını oluşturun.</p>\n\n                <div id=\"sortable-list\" class=\"space-y-3\">\n                    <!-- Sıralanacak öğeler buraya JS ile yüklenecek -->\n                </div>\n\n                <div class=\"flex flex-col space-y-4 mt-8\">\n                    <button onclick=\"checkOrder()\" class=\"w-full bg-[#4CAF50] text-white font-bold py-3 px-4 rounded-xl shadow-lg hover:bg-green-700 transition duration-300\">\n                        Sıralamayı Kontrol Et\n                    </button>\n                    <button onclick=\"resetGame()\" class=\"w-full bg-gray-600 text-white font-bold py-3 px-4 rounded-xl shadow-lg hover:bg-gray-700 transition duration-300\">\n                        Yeniden Başlat\n                    </button>\n                </div>\n                \n                <div id=\"feedback\" class=\"text-center text-xl mt-6 font-semibold\">\n                    <!-- Geri bildirim buraya gelecek -->\n                </div>\n            </section>\n            <!-- SIRALAMA ETKİNLİĞİ BÖLÜMÜ SONU -->\n\n        </main>\n        \n        <footer class=\"text-center mt-16 py-6 border-t border-[#1D1D3A]\">\n            <p class=\"text-md text-[#00BCD4] italic\">\"Asıl hayat ahiret yurdundaki hayattır. Keşke bilseler!\" (Ankebût, 64)</p>\n            <p class=\"text-xs text-gray-500 mt-2\">Bu infografik, Kur'an ve Sünnet'te geçen temel ahiret inancı aşamalarına göre düzenlenmiştir.</p>\n        </footer>\n    </div>\n\n    <script>\n        // Ahiret Yolculuğu Aşamaları (Doğru Sıra)\n        const correctOrder = [\n            { id: 'ecel', name: 'Ecel ve Ölüm' },\n            { id: 'berzah', name: 'Kabir Hayatı (Berzah)' },\n            { id: 'kiyamet', name: 'Kıyamet' },\n            { id: 'bas', name: 'Ba\\'s (Yeniden Diriliş)' },\n            { id: 'hasr', name: 'Haşr ve Mahşer' },\n            { id: 'hesap', name: 'Hesap, Mizan ve Sırat' },\n            { id: 'ebedi', name: 'Ebedi Yurt (Cennet / Cehennem)' } // 7. ve son aşama eklendi\n        ];\n\n        const sortableList = document.getElementById('sortable-list');\n        const feedbackElement = document.getElementById('feedback');\n        let draggedItem = null;\n\n        // Sayfa/Görünüm Değiştirme Fonksiyonu\n        function switchView(viewId) {\n            document.getElementById('infographic-view').classList.add('hidden');\n            document.getElementById('sorting-view').classList.add('hidden');\n            \n            document.getElementById('tab-infographic').classList.remove('active');\n            document.getElementById('tab-sorting').classList.remove('active');\n\n            if (viewId === 'infographic') {\n                document.getElementById('infographic-view').classList.remove('hidden');\n                document.getElementById('tab-infographic').classList.add('active');\n            } else {\n                document.getElementById('sorting-view').classList.remove('hidden');\n                document.getElementById('tab-sorting').classList.add('active');\n                if (sortableList.children.length === 0) {\n                     resetGame(); // Etkinlik görünür olduğunda yükle\n                }\n            }\n        }\n        \n        // --- DRAG & DROP İŞLEMLERİ ---\n\n        function handleDragStart(e) {\n            draggedItem = this;\n            e.dataTransfer.effectAllowed = 'move';\n            e.dataTransfer.setData('text/html', this.innerHTML); \n            setTimeout(() => this.classList.add('dragging'), 0);\n            feedbackElement.textContent = '';\n            feedbackElement.className = 'text-center text-xl mt-6 font-semibold';\n        }\n\n        function handleDragEnd(e) {\n            this.classList.remove('dragging');\n            draggedItem = null;\n            // Sürükleme bittiğinde numaraları tekrar kontrol et ve güncelle (sadece gerektiğinde)\n            // Bu, handleDragOver içinde yapıldığı için burada sadece görsel temizlik yeterli.\n        }\n\n        function handleDragOver(e) {\n            e.preventDefault(); \n            e.dataTransfer.dropEffect = 'move';\n            const targetItem = e.target.closest('.sortable-item');\n            if (targetItem && targetItem !== draggedItem) {\n                // Sürüklenen öğeyi hedefin üstüne veya altına yerleştirme\n                const rect = targetItem.getBoundingClientRect();\n                const offsetY = e.clientY - rect.top;\n                \n                // Drop hedefinin hemen altında bir yer oluştur\n                if (offsetY > rect.height / 2) {\n                    sortableList.insertBefore(draggedItem, targetItem.nextSibling);\n                } else {\n                    sortableList.insertBefore(draggedItem, targetItem);\n                }\n                updateItemNumbers(); // DOM değiştiğinde numaraları güncelle\n            }\n        }\n\n        function handleDrop(e) {\n            e.stopPropagation(); // Bazı tarayıcılarda gereklidir\n            return false;\n        }\n\n        // --- YARDIMCI FONKSİYONLAR ---\n\n        // Sürükleme sonrası sıralama numaralarını günceller\n        function updateItemNumbers() {\n            const list = Array.from(sortableList.children);\n            list.forEach((item, index) => {\n                const numberElement = item.querySelector('.sort-number');\n                if (numberElement) {\n                    numberElement.textContent = (index + 1) + '.';\n                }\n            });\n        }\n\n        // Diziyi karıştırma fonksiyonu (Fisher-Yates)\n        function shuffleArray(array) {\n            let currentIndex = array.length, randomIndex;\n            while (currentIndex !== 0) {\n                randomIndex = Math.floor(Math.random() * currentIndex);\n                currentIndex--;\n                [array[currentIndex], array[randomIndex]] = [\n                    array[randomIndex], array[currentIndex]\n                ];\n            }\n            return array;\n        }\n\n        // Listeyi yeniden çizme fonksiyonu\n        function renderList(stages) {\n            sortableList.innerHTML = '';\n            stages.forEach((stage) => {\n                const itemDiv = document.createElement('div');\n                itemDiv.dataset.id = stage.id;\n                \n                itemDiv.className = 'sortable-item flex items-center p-4 rounded-lg shadow-md hover:bg-[#1D1D3A]/80';\n                itemDiv.setAttribute('draggable', 'true');\n                \n                // 1. Numara alanı oluşturma\n                const numberSpan = document.createElement('span');\n                numberSpan.className = 'sort-number mr-4 flex-shrink-0';\n\n                // 2. Metin alanı oluşturma\n                const nameSpan = document.createElement('span');\n                nameSpan.textContent = stage.name;\n                nameSpan.className = 'text-lg font-medium';\n                \n                itemDiv.appendChild(numberSpan);\n                itemDiv.appendChild(nameSpan);\n                \n                // Drag and drop event listeners\n                itemDiv.addEventListener('dragstart', handleDragStart);\n                itemDiv.addEventListener('dragover', handleDragOver);\n                itemDiv.addEventListener('drop', handleDrop);\n                itemDiv.addEventListener('dragend', handleDragEnd);\n\n                sortableList.appendChild(itemDiv);\n            });\n            updateItemNumbers(); // İlk numaralandırmayı yap\n        }\n\n        // Sıralamayı kontrol etme mantığı\n        function checkOrder() {\n            const currentList = Array.from(sortableList.children);\n            let isCorrect = true;\n\n            // correctOrder.length artık 7 olacak\n            if (currentList.length !== correctOrder.length) {\n                isCorrect = false; // Güvenlik kontrolü\n            } else {\n                for (let i = 0; i < correctOrder.length; i++) {\n                    if (currentList[i].dataset.id !== correctOrder[i].id) {\n                        isCorrect = false;\n                        break;\n                    }\n                }\n            }\n\n            if (isCorrect) {\n                feedbackElement.textContent = '✅ Tebrikler! Sıralama Doğru. Yolculuğun aşamalarını çok iyi biliyorsunuz.';\n                feedbackElement.className = 'text-center text-xl mt-6 font-semibold text-[#4CAF50]';\n            } else {\n                feedbackElement.textContent = '❌ Tekrar Deneyin. Kartların yerleşimi doğru değil.';\n                feedbackElement.className = 'text-center text-xl mt-6 font-semibold text-red-500';\n            }\n        }\n        \n        // Oyunu başlatma/sıfırlama fonksiyonu\n        function resetGame() {\n            const randomizedStages = shuffleArray([...correctOrder]); // Kopya oluştur ve karıştır\n            renderList(randomizedStages);\n            feedbackElement.textContent = '';\n            feedbackElement.className = 'text-center text-xl mt-6 font-semibold';\n        }\n\n        // Sayfa yüklendiğinde ilk görünümü ayarla\n        document.addEventListener('DOMContentLoaded', () => {\n             switchView('infographic');\n        });\n    </script>\n</body>\n</html>\n"
}