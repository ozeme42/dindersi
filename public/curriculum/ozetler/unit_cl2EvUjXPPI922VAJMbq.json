{
  "title": "2. ÜNİTE: HAC VE KURBAN",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>2. Ünite: Hac ve Kurban</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@300;400;500;700&display=swap');\n        @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap');\n\n        /* --- GENEL AYARLAR (Akıllı Tahta İçin Büyütülmüş) --- */\n        html {\n            font-size: 20px; /* Temel font boyutu artırıldı */\n        }\n\n        body {\n            margin: 0; padding: 0;\n            background: linear-gradient(135deg, #1c1917 0%, #78350f 100%);\n            font-family: 'Roboto', sans-serif;\n            color: #fff;\n            box-sizing: border-box;\n            height: 100vh; width: 100vw;\n            overflow: hidden; \n        }\n\n        /* --- KONTROL BUTONLARI (SAĞ ÜST) --- */\n        #display-controls {\n            position: fixed;\n            top: 20px;\n            right: 20px;\n            z-index: 9999;\n            display: flex;\n            gap: 10px;\n            background: rgba(0,0,0,0.6);\n            padding: 10px;\n            border-radius: 15px;\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255,255,255,0.2);\n        }\n        .ctrl-btn {\n            background: #fbbf24;\n            color: #0f172a;\n            border: none;\n            width: 50px;\n            height: 50px;\n            border-radius: 10px;\n            font-size: 1.8rem;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: transform 0.2s;\n            font-weight: bold;\n        }\n        .ctrl-btn:hover { transform: scale(1.1); background: #f59e0b; }\n        .ctrl-btn-blue { background: #3b82f6; color: white; }\n\n        /* --- ANA KAPLAYICI --- */\n        #app-wrapper {\n            width: 100%; height: 100%;\n            display: flex; justify-content: center; align-items: center;\n            transition: transform 0.3s ease;\n        }\n\n        #app-container {\n            width: 1500px; height: 850px;\n            background: rgba(28, 25, 23, 0.95); /* Koyu Taş Rengi */\n            border: 4px solid #fbbf24; /* Altın Çerçeve */\n            border-radius: 30px;\n            box-shadow: 0 40px 80px rgba(0,0,0,0.9);\n            position: relative;\n            display: flex; flex-direction: column;\n            overflow: hidden;\n            transform-origin: center center;\n        }\n\n        /* --- MENÜ EKRANI --- */\n        #menu-screen {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(28, 25, 23, 0.98);\n            z-index: 50;\n            display: flex; flex-direction: column; align-items: center; justify-content: center;\n            overflow-y: auto;\n        }\n        .menu-title { font-family: 'Playfair Display', serif; font-size: 4rem; color: #fbbf24; margin-bottom: 40px; text-align: center; text-shadow: 0 4px 10px rgba(0,0,0,0.5); }\n        .menu-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 30px; width: 90%; max-width: 1300px; }\n        .menu-btn {\n            background: rgba(255, 255, 255, 0.08); border: 2px solid #fbbf24;\n            padding: 30px; border-radius: 20px; cursor: pointer;\n            transition: transform 0.2s, background 0.2s; text-align: left;\n            display: flex; flex-direction: column; align-items: center; gap: 15px; text-align: center;\n        }\n        .menu-btn:hover { transform: scale(1.03); background: rgba(251, 191, 36, 0.15); }\n        .menu-icon { font-size: 3.5rem; }\n        .menu-text h3 { margin: 0; font-size: 1.6rem; color: #fbbf24; }\n        .menu-text p { margin: 5px 0 0 0; color: #d6d3d1; font-size: 1rem; }\n\n        /* --- ÜNİTE ARAYÜZÜ --- */\n        .header-bar {\n            height: 90px; border-bottom: 2px solid rgba(251, 191, 36, 0.3);\n            display: flex; align-items: center; justify-content: space-between;\n            padding: 0 50px; background: rgba(0,0,0,0.3); flex-shrink: 0;\n        }\n        .header-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #fbbf24; }\n        .home-btn { background: none; border: 2px solid #fbbf24; color: #fbbf24; padding: 10px 25px; border-radius: 10px; cursor: pointer; font-size: 1.2rem; font-weight: bold; }\n\n        .slide-content {\n            flex: 1; padding: 50px 60px; display: flex; gap: 50px;\n            overflow-y: auto; position: relative; animation: fadeIn 0.5s ease-out;\n        }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }\n\n        .text-panel { flex: 1.4; padding-right: 30px; font-size: 1.4rem; line-height: 1.7; color: #e7e5e4; }\n        .text-panel h2 {\n            font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #fff;\n            margin-top: 0; margin-bottom: 25px; border-bottom: 4px solid #fbbf24; display: inline-block;\n        }\n\n        .visual-panel {\n            flex: 0.6; display: flex; flex-direction: column; justify-content: center; align-items: center;\n            background: rgba(255,255,255,0.03); border-radius: 20px; padding: 30px; border: 2px dashed rgba(251, 191, 36, 0.3);\n        }\n        .visual-icon { font-size: 8rem; margin-bottom: 30px; filter: drop-shadow(0 0 15px rgba(251,191,36,0.4)); }\n        \n        .activity-btn {\n            background: linear-gradient(45deg, #fbbf24, #d97706); border: none; padding: 20px 40px;\n            font-size: 1.6rem; font-weight: bold; color: #0f172a; border-radius: 50px; cursor: pointer;\n            width: 100%; box-shadow: 0 10px 20px rgba(251, 191, 36, 0.3); animation: pulse 2s infinite;\n        }\n        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.03); } 100% { transform: scale(1); } }\n\n        .controls-bar {\n            height: 90px; padding: 0 50px; display: flex; justify-content: space-between; align-items: center;\n            background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.1); flex-shrink: 0;\n        }\n        .nav-btn {\n            background: transparent; border: 3px solid #fbbf24; color: #fbbf24; padding: 15px 40px;\n            font-size: 1.4rem; border-radius: 12px; cursor: pointer; font-weight: bold;\n        }\n        .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; border-color: #777; color: #777; }\n\n        /* --- ÖZEL İÇERİK STİLLERİ --- */\n        .concept-table { width: 100%; border-collapse: collapse; margin-top: 25px; background: rgba(255,255,255,0.05); font-size: 1.3rem; }\n        .concept-table th { text-align: left; padding: 15px; color: #fbbf24; background: rgba(0,0,0,0.2); }\n        .concept-table td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); }\n        \n        .info-card { background: rgba(255, 255, 255, 0.05); border-left: 6px solid #fbbf24; padding: 20px; margin-bottom: 20px; border-radius: 0 15px 15px 0; font-size: 1.3rem; }\n        .quote { font-style: italic; background: rgba(251, 191, 36, 0.1); padding: 20px; border-left: 5px solid #fbbf24; margin: 20px 0; color: #fcd34d; font-size: 1.4rem; }\n        .arabic-text { font-family: 'Amiri', serif; font-size: 2.5rem; color: #fbbf24; display: block; margin-bottom: 10px; direction: rtl; }\n\n        /* OYUN MODALI */\n        #activity-overlay {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n            background: rgba(28, 25, 23, 0.98); z-index: 100; display: none;\n            flex-direction: column; align-items: center; padding: 40px; box-sizing: border-box;\n        }\n        .activity-header { font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #fbbf24; margin-bottom: 30px; text-align: center; }\n        .close-activity { position: absolute; top: 30px; right: 40px; background: transparent; border: none; color: #fff; font-size: 3rem; cursor: pointer; }\n        .game-area { width: 90%; height: 80%; background: rgba(255,255,255,0.05); border-radius: 25px; padding: 40px; display: flex; flex-direction: column; align-items: center; overflow-y: auto; }\n        .feedback-msg { margin-top: 20px; font-size: 2rem; height: 40px; font-weight: bold; text-align: center; }\n        .success { color: #34d399; } .error { color: #f87171; }\n\n        /* OYUNLAR */\n        .match-container { \n            display: flex; \n            justify-content: space-between; \n            width: 100%; \n            gap: 50px; \n            flex-direction: row; /* Yan yana */\n        }\n        .match-col { \n            flex: 1; \n            display: flex; \n            flex-direction: column; \n            gap: 20px; \n        }\n        .match-item { \n            background: #451a03; \n            padding: 25px; \n            text-align: center; \n            border-radius: 15px; \n            cursor: pointer; \n            border: 4px solid transparent; \n            display: flex; \n            align-items: center; \n            justify-content: center; \n            min-height: 80px; \n            font-size: 1.6rem;\n        }\n        .match-item.selected { border-color: #fbbf24; background: #78350f; }\n        .match-item.matched { background: #059669; opacity: 0.6; pointer-events: none; }\n        .match-item.wrong { background: #dc2626; animation: shake 0.4s; }\n        \n        .quiz-option { width: 90%; padding: 25px; margin: 15px 0; background: #451a03; border: 3px solid #78350f; border-radius: 15px; cursor: pointer; text-align: left; font-size: 1.6rem; color: white; }\n        \n        .sort-container { width: 80%; display: flex; flex-direction: column; gap: 20px; }\n        .sort-item { background: #451a03; padding: 25px; border-radius: 15px; border-left: 8px solid #fbbf24; cursor: pointer; font-size: 1.5rem; }\n\n        .anagram-container { text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center; }\n        .anagram-slots { display: flex; gap: 20px; margin-bottom: 40px; flex-wrap: wrap; justify-content: center; }\n        .anagram-slot { width: 60px; height: 80px; border-bottom: 6px solid #fbbf24; font-size: 3rem; color: #fbbf24; display: flex; justify-content: center; align-items: center; }\n        .letter-pool { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }\n        .letter-btn { width: 70px; height: 70px; background: #451a03; color: #fff; border: 3px solid #78350f; border-radius: 15px; font-size: 2rem; cursor: pointer; }\n        .letter-btn.correct { opacity: 0; pointer-events: none; }\n        .letter-btn.wrong { background: #dc2626; animation: shake 0.4s; }\n\n        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } 100% { transform: translateX(0); } }\n\n        /* MOBİL UYUMLULUK */\n        @media screen and (max-width: 1024px) {\n            body { overflow-y: auto; height: auto; }\n            #app-wrapper { display: block; height: auto; }\n            #app-container { width: 100%; height: auto; min-height: 100vh; border: none; border-radius: 0; transform: none !important; box-shadow: none; }\n            #display-controls { display: none; }\n            \n            #menu-screen { position: relative; height: auto; min-height: 100vh; padding: 40px 20px; justify-content: flex-start; }\n            .menu-title { font-size: 2.5rem; margin-bottom: 30px; line-height: 1.2; }\n            .menu-grid { grid-template-columns: 1fr; width: 100%; gap: 15px; }\n            .menu-btn { flex-direction: row; padding: 20px; text-align: left; }\n            \n            .header-bar { padding: 10px 20px; flex-direction: column; height: auto; gap: 10px; }\n            .slide-content { flex-direction: column; padding: 20px; overflow: visible; }\n            .text-panel, .visual-panel { width: 100%; flex: none; padding-right: 0; }\n            .visual-panel { margin-top: 20px; }\n            .visual-icon { font-size: 4rem; }\n            \n            #activity-overlay { position: fixed; height: 100%; padding: 10px; z-index: 9999; }\n            .game-area { width: 95%; height: 85%; padding: 10px; justify-content: flex-start; }\n            \n            .match-container { flex-direction: column; gap: 15px; }\n            .match-item { font-size: 1rem; min-height: auto; padding: 15px; }\n            .quiz-option { width: 100%; font-size: 1.1rem; }\n            .letter-btn { width: 45px; height: 45px; font-size: 1.3rem; }\n            .anagram-slot { width: 35px; height: 45px; font-size: 1.8rem; }\n            .controls-bar { padding: 10px 20px; position: sticky; bottom: 0; background: #1c1917; z-index: 50; }\n            html { font-size: 16px; }\n        }\n    </style>\n</head>\n<body>\n\n<!-- KONTROL BUTONLARI -->\n<div id=\"display-controls\">\n    <button class=\"ctrl-btn ctrl-btn-blue\" onclick=\"toggleFullScreen()\" title=\"Tam Ekran\">⛶</button>\n    <button class=\"ctrl-btn\" onclick=\"zoomOut()\" title=\"Küçült\">-</button>\n    <button class=\"ctrl-btn\" onclick=\"zoomIn()\" title=\"Büyüt\">+</button>\n</div>\n\n<div id=\"app-wrapper\">\n    <div id=\"app-container\">\n        <!-- MENÜ EKRANI -->\n        <div id=\"menu-screen\">\n            <h1 class=\"menu-title\">2. Ünite: Hac ve Kurban</h1>\n            <div class=\"menu-grid\">\n                <div class=\"menu-btn\" onclick=\"selectUnit(0)\">\n                    <span class=\"menu-icon\">🕋</span>\n                    <div class=\"menu-text\"><h3>2.1 İslam'da Hac İbadeti</h3><p>Hac nedir, önemi ve kimlere farzdır.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(1)\">\n                    <span class=\"menu-icon\">🔄</span>\n                    <div class=\"menu-text\"><h3>2.2 Haccın Yapılışı</h3><p>İhram, Tavaf, Say, Vakfe ve Mekânlar.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(2)\">\n                    <span class=\"menu-icon\">🌍</span>\n                    <div class=\"menu-text\"><h3>2.3 Umre ve Önemi</h3><p>Hac ile Umre arasındaki farklar.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(3)\">\n                    <span class=\"menu-icon\">🐑</span>\n                    <div class=\"menu-text\"><h3>2.4 Kurban İbadeti</h3><p>Kurbanın anlamı, çeşitleri ve faydaları.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(4)\">\n                    <span class=\"menu-icon\">💧</span>\n                    <div class=\"menu-text\"><h3>2.5 Hz. İsmail (as)</h3><p>Zemzem, Kurban kıssası ve Kâbe.</p></div>\n                </div>\n                <div class=\"menu-btn\" onclick=\"selectUnit(5)\">\n                    <span class=\"menu-icon\">📖</span>\n                    <div class=\"menu-text\"><h3>2.6 Bir Ayet: Enam 162</h3><p>Okunuşu, anlamı ve mesajları.</p></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- ÜNİTE EKRANI -->\n        <div id=\"unit-screen\" style=\"display:none; flex-direction:column; height:100%;\">\n            <div class=\"header-bar\">\n                <div style=\"display:flex; align-items:center; gap:15px; width:100%; justify-content:space-between;\">\n                    <button class=\"home-btn\" onclick=\"returnToMenu()\">🏠 Menü</button>\n                    <div class=\"header-title\" id=\"unit-title\">Başlık</div>\n                    <div class=\"progress-indicator\" style=\"font-size:1.1rem;\">Sf <span id=\"current-page\">1</span></div>\n                </div>\n            </div>\n\n            <div id=\"slide-container\" class=\"slide-content\"></div>\n\n            <div class=\"controls-bar\">\n                <button id=\"prev-btn\" class=\"nav-btn\" onclick=\"prevSlide()\">❮ Geri</button>\n                <button id=\"next-btn\" class=\"nav-btn\" onclick=\"nextSlide()\">İleri ❯</button>\n            </div>\n        </div>\n\n        <!-- OYUN MODALI -->\n        <div id=\"activity-overlay\">\n            <button class=\"close-activity\" onclick=\"closeActivity()\">✕</button>\n            <div class=\"activity-header\" id=\"activity-title\">Etkinlik</div>\n            <div class=\"game-area\" id=\"game-board\"></div>\n            <div class=\"feedback-msg\" id=\"feedback\"></div>\n        </div>\n    </div>\n</div>\n\n<script>\n    /* --- EKRAN AYARLARI VE ZOOM --- */\n    let currentScale = 1;\n    let manualZoom = 0;\n\n    function fitScreen() {\n        if(window.innerWidth > 1024) {\n            const container = document.getElementById('app-container');\n            const targetWidth = 1540;\n            const targetHeight = 890;\n            const winWidth = window.innerWidth;\n            const winHeight = window.innerHeight;\n            \n            let scale = Math.min(winWidth / targetWidth, winHeight / targetHeight);\n            currentScale = scale + manualZoom;\n            \n            container.style.transform = `scale(${currentScale})`;\n        } else {\n            document.getElementById('app-container').style.transform = 'none';\n        }\n    }\n\n    function zoomIn() { manualZoom += 0.1; fitScreen(); }\n    function zoomOut() { if(currentScale > 0.3) { manualZoom -= 0.1; fitScreen(); } }\n    function toggleFullScreen() {\n        if (!document.fullscreenElement) { document.documentElement.requestFullscreen(); }\n        else { if (document.exitFullscreen) { document.exitFullscreen(); } }\n    }\n\n    window.addEventListener('resize', fitScreen);\n    window.addEventListener('load', fitScreen);\n\n    /* --- İÇERİK VERİSİ --- */\n    const units = [\n        // 2.1 HAC İBADETİ\n        {\n            title: \"2.1 İslam'da Hac İbadeti\",\n            slides: [\n                {\n                    title: \"Hac Nedir?\",\n                    content: `<p><strong>Hac:</strong> İmkânı olan Müslümanların zilhicce ayında ihram giyerek, Arafat'ta vakfe yaparak ve Kâbe'yi tavaf ederek yaptıkları <strong>farz</strong> ibadettir.</p>\n                    <p>Hicretin 9. yılında farz kılınmıştır. Hem mal hem de beden ile yapılan bir ibadettir.</p>\n                    <div class=\"quote\">\"Yolculuğuna gücü yetenlerin haccetmesi, Allah'ın insanlar üzerinde bir hakkıdır.\" (Al-i İmran, 97)</div>`,\n                    icon: \"🕋\", activityType: \"quiz\", activityTitle: \"Hac Bilgisi\",\n                    activityData: [{q:\"Hac ne zaman yapılır?\", options:[\"Ramazan Ayında\", \"Zilhicce Ayında\"], a:\"Zilhicce Ayında\"}, {q:\"Hac nasıl bir ibadettir?\", options:[\"Sadece bedenle\", \"Hem mal hem bedenle\"], a:\"Hem mal hem bedenle\"}]\n                },\n                {\n                    title: \"Haccın Önemi\",\n                    content: `<ul style=\"line-height:1.8;\">\n                    <li>Allah'ın rızasını kazanmak için yapılır.</li>\n                    <li>Mahşer gününün provasıdır (Arafat'ta toplanma).</li>\n                    <li>Günahlardan arınma vesilesidir.</li>\n                    <li>Dünya Müslümanlarının kardeşlik buluşmasıdır.</li>\n                    <li>İhram ile makam ve mevkilerin geçiciliği anlaşılır.</li></ul>`,\n                    icon: \"🤝\", activityType: \"none\", activityTitle: \"\", activityData: null\n                }\n            ]\n        },\n        // 2.2 HACCIN YAPILIŞI\n        {\n            title: \"2.2 Haccın Yapılışı ve Kavramlar\",\n            slides: [\n                {\n                    title: \"Kavramları Öğrenelim\",\n                    content: `<p><strong>İhram:</strong> Hac için giyilen dikişsiz beyaz kıyafet ve yasaklar bütünü.<br>\n                    <strong>Tavaf:</strong> Kâbe'nin etrafında 7 kez dönmek (Her dönüşe Şavt denir).<br>\n                    <strong>Say:</strong> Safa ve Merve tepeleri arasında 7 kez gidip gelmek.<br>\n                    <strong>Vakfe:</strong> Arafat'ta bir süre durmak ve dua etmek.</p>`,\n                    icon: \"📖\", activityType: \"matching\", activityTitle: \"Kavram Eşleştirme\",\n                    activityData: [{term:\"Tavaf\", def:\"Kâbe etrafında dönmek\"}, {term:\"Say\", def:\"Safa-Merve arası yürüyüş\"}, {term:\"Vakfe\", def:\"Arafat'ta beklemek\"}, {term:\"Şavt\", def:\"Kâbe etrafında 1 tur\"}]\n                },\n                {\n                    title: \"Haccın Mekânları\",\n                    content: `<p><strong>Mikat:</strong> İhrama girilen sınırlar.<br>\n                    <strong>Arafat:</strong> Arife günü vakfe yapılan yer.<br>\n                    <strong>Müzdelife:</strong> Arafat ile Mina arasında vakfe yapılan ve taş toplanan yer.<br>\n                    <strong>Mina:</strong> Şeytan taşlanan ve kurban kesilen yer.</p>`,\n                    icon: \"📍\", activityType: \"matching\", activityTitle: \"Mekânları Tanı\",\n                    activityData: [{term:\"Mina\", def:\"Şeytan taşlama yeri\"}, {term:\"Arafat\", def:\"Vakfe yeri\"}, {term:\"Mikat\", def:\"İhram sınırı\"}, {term:\"Müzdelife\", def:\"Taş toplama yeri\"}]\n                },\n                {\n                    title: \"Haccın Yapılış Sırası\",\n                    content: `<p>Hac ibadeti belirli bir sıra ile yapılır:</p>\n                    1. Mikat sınırında İhrama girilir.<br>\n                    2. Arife günü Arafat Vakfesi yapılır (Farz).<br>\n                    3. Müzdelife Vakfesi yapılır.<br>\n                    4. Mina'da Şeytan taşlanır ve Kurban kesilir.<br>\n                    5. Tıraş olunup ihramdan çıkılır.<br>\n                    6. Kâbe'de Ziyaret Tavafı yapılır (Farz).`,\n                    icon: \"🔢\", activityType: \"ordering\", activityTitle: \"Sıralama Yap\",\n                    activityData: [\"İhrama Girmek\", \"Arafat Vakfesi\", \"Müzdelife Vakfesi\", \"Şeytan Taşlama/Kurban\", \"Ziyaret Tavafı\"]\n                }\n            ]\n        },\n        // 2.3 UMRE\n        {\n            title: \"2.3 Umre ve Önemi\",\n            slides: [\n                {\n                    title: \"Umre Nedir?\",\n                    content: `<p>Hac mevsimi dışında, ihramlı olarak Kâbe'yi tavaf edip Safa-Merve arasında say yaptıktan sonra tıraş olarak yapılan ibadettir. <strong>Sünnettir.</strong></p>\n                    <p>Umreye \"Küçük Hac\" da denir.</p>`,\n                    icon: \"🌍\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Hac ve Umre Farkı\",\n                    content: `<table class=\"concept-table\"><tr><th>HAC</th><th>UMRE</th></tr>\n                    <tr><td>Yılda 1 kez (Zilhicce)</td><td>Her zaman yapılabilir</td></tr>\n                    <tr><td>Farzdır</td><td>Sünnettir</td></tr>\n                    <tr><td>Vakfe, Şeytan Taşlama, Kurban VAR</td><td>Vakfe, Şeytan Taşlama, Kurban YOK</td></tr>\n                    </table>`,\n                    icon: \"⚖️\", activityType: \"quiz\", activityTitle: \"Farkları Bul\",\n                    activityData: [{q:\"Hangisi sadece Hac'da vardır?\", options:[\"Tavaf\", \"Vakfe\"], a:\"Vakfe\"}, {q:\"Umre ne zaman yapılır?\", options:[\"Sadece Ramazanda\", \"Her zaman\"], a:\"Her zaman\"}]\n                }\n            ]\n        },\n        // 2.4 KURBAN\n        {\n            title: \"2.4 Kurban İbadeti\",\n            slides: [\n                {\n                    title: \"Kurban Nedir?\",\n                    content: `<p>Allah'a yaklaşmak ve rızasını kazanmak amacıyla belirli günlerde (Kurban Bayramı) belirli hayvanları kesmektir. Hükmü <strong>Vacip</strong>tir.</p>\n                    <div class=\"quote\">\"Onların ne etleri ne de kanları Allah'a ulaşır; fakat O'na sadece sizin takvanız ulaşır.\" (Hac, 37)</div>`,\n                    icon: \"🐑\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Kurbanlık Hayvanlar\",\n                    content: `<ul style=\"line-height:1.8;\">\n                    <li><strong>Koyun/Keçi:</strong> 1 yaşını doldurmuş olmalı. 1 kişi adına kesilir.</li>\n                    <li><strong>Sığır/Manda:</strong> 2 yaşını doldurmuş olmalı. 1-7 kişi ortak olabilir.</li>\n                    <li><strong>Deve:</strong> 5 yaşını doldurmuş olmalı. 1-7 kişi ortak olabilir.</li></ul>\n                    <p>Tavuk, horoz gibi hayvanlardan kurban olmaz.</p>`,\n                    icon: \"🐄\", activityType: \"matching\", activityTitle: \"Hayvan Yaşları\",\n                    activityData: [{term:\"Koyun\", def:\"1 Yaş\"}, {term:\"Sığır\", def:\"2 Yaş\"}, {term:\"Deve\", def:\"5 Yaş\"}, {term:\"Tavuk\", def:\"Kurban Olmaz\"}]\n                },\n                {\n                    title: \"Kurban Çeşitleri ve Faydaları\",\n                    content: `<p><strong>Adak (Nezir):</strong> Bir dilek gerçekleşince kesilen kurban.<br>\n                    <strong>Akika:</strong> Çocuk doğunca şükür için kesilen kurban.</p>\n                    <p><strong>Faydaları:</strong> Allah'a yakınlaşma, cimrilikten kurtulma, toplumsal yardımlaşma (et dağıtımı).</p>`,\n                    icon: \"❤️\", activityType: \"quiz\", activityTitle: \"Kurban Bilgisi\",\n                    activityData: [{q:\"Yeni doğan çocuk için kesilen kurban?\", options:[\"Adak\", \"Akika\"], a:\"Akika\"}, {q:\"Kurban etinin dağıtılması neyi sağlar?\", options:[\"Yardımlaşmayı\", \"İsrafı\"], a:\"Yardımlaşmayı\"}]\n                }\n            ]\n        },\n        // 2.5 HZ. İSMAİL\n        {\n            title: \"2.5 Bir Peygamber: Hz. İsmail (as)\",\n            slides: [\n                {\n                    title: \"Hacer ve İsmail\",\n                    content: `<p>Hz. İbrahim, eşi Hacer ve oğlu İsmail'i Mekke'nin ıssız çölüne bıraktı. Su bitince Hz. Hacer, Safa ve Merve arasında 7 kez koştu (Say ibadeti buradan gelir). Sonunda İsmail'in ayağının dibinden <strong>Zemzem</strong> suyu çıktı.</p>`,\n                    icon: \"💧\", activityType: \"none\", activityTitle: \"\", activityData: null\n                },\n                {\n                    title: \"Kurban İmtihanı ve Kâbe\",\n                    content: `<p>Hz. İbrahim rüyasında oğlunu kurban etmesi istendi. İkisi de buna teslim oldu. Allah, sadakatleri karşılığında onlara bir kurbanlık gönderdi.</p>\n                    <p>Daha sonra baba-oğul birlikte Allah'ın emriyle <strong>Kâbe'yi inşa ettiler</strong>.</p>`,\n                    icon: \"🏗️\", activityType: \"ordering\", activityTitle: \"Hikayeyi Sırala\",\n                    activityData: [\"Mekke çölüne bırakılmaları\", \"Zemzem suyunun çıkması\", \"Kurban imtihanı\", \"Kâbe'nin inşası\"]\n                }\n            ]\n        },\n        // 2.6 ENAM SURESİ 162\n        {\n            title: \"2.6 Bir Ayet: Enam 162\",\n            slides: [\n                {\n                    title: \"Ayet ve Anlamı\",\n                    content: `<div class=\"info-card\"><span class=\"arabic-text\">قُلْ اِنَّ صَلَات۪ي وَنُسُك۪ي وَمَحْيَايَ وَمَمَات۪ي لِلّٰهِ رَبِّ الْعَالَم۪ينَۙ</span></div>\n                    <p><strong>Okunuşu:</strong> Kul inne salâtî ve nüsukî ve mahyâye ve memâtî lillâhi rabbil âlemîn.</p>\n                    <p><strong>Anlamı:</strong> De ki: \"Şüphesiz benim namazım, kurbanım (ibadetlerim), hayatım ve ölümüm hepsi âlemlerin Rabbi Allah içindir.\"</p>`,\n                    icon: \"🤲\", activityType: \"ordering\", activityTitle: \"Anlamı Sırala\",\n                    activityData: [\"Benim namazım,\", \"ibadetlerim,\", \"hayatım ve ölümüm\", \"âlemlerin Rabbi Allah içindir.\"]\n                }\n            ]\n        }\n    ];\n\n    /* --- DURUM YÖNETİMİ --- */\n    let currentUnitIdx = 0;\n    let currentSlideIdx = 0;\n    \n    // Oyun Değişkenleri\n    let currentData = null;\n    let selectedItem = null;\n    let anagramIndex = 0;\n    let currentAnagramState = { word:\"\", pos:0 };\n\n    /* --- GÖRÜNÜM KONTROLÜ --- */\n    function init() {\n        fitScreen();\n        window.addEventListener('resize', fitScreen);\n    }\n\n    function selectUnit(index) {\n        currentUnitIdx = index;\n        currentSlideIdx = 0;\n        document.getElementById('menu-screen').style.display = 'none';\n        document.getElementById('unit-screen').style.display = 'flex';\n        document.getElementById('unit-title').textContent = units[index].title;\n        renderSlide();\n    }\n\n    function returnToMenu() {\n        document.getElementById('unit-screen').style.display = 'none';\n        document.getElementById('menu-screen').style.display = 'flex';\n    }\n\n    function renderSlide() {\n        const slide = units[currentUnitIdx].slides[currentSlideIdx];\n        const container = document.getElementById('slide-container');\n        document.getElementById('current-page').innerText = currentSlideIdx + 1;\n        document.getElementById('prev-btn').disabled = currentSlideIdx === 0;\n        document.getElementById('next-btn').disabled = currentSlideIdx === units[currentUnitIdx].slides.length - 1;\n\n        let btnHtml = slide.activityType !== \"none\"\n            ? `<button class=\"activity-btn\" onclick=\"openActivity()\">🎮 ETKİNLİK BAŞLAT</button>` \n            : `<div style=\"text-align:center; color:#fbbf24; font-size:1.4rem; margin-top:20px;\">Okudum, Anladım ✅</div>`;\n\n        container.innerHTML = `\n            <div class=\"text-panel\"><h2>${slide.title}</h2>${slide.content}</div>\n            <div class=\"visual-panel\"><div class=\"visual-icon\">${slide.icon}</div>${btnHtml}</div>\n        `;\n    }\n\n    function nextSlide() { if(currentSlideIdx < units[currentUnitIdx].slides.length-1) { currentSlideIdx++; renderSlide(); } }\n    function prevSlide() { if(currentSlideIdx > 0) { currentSlideIdx--; renderSlide(); } }\n\n    /* --- ETKİNLİK MOTORU --- */\n    function openActivity() {\n        const slide = units[currentUnitIdx].slides[currentSlideIdx];\n        const board = document.getElementById('game-board');\n        document.getElementById('activity-overlay').style.display = 'flex';\n        document.getElementById('activity-title').textContent = slide.activityTitle;\n        document.getElementById('feedback').textContent = \"\";\n        board.innerHTML = \"\";\n        currentData = slide.activityData;\n\n        if(slide.activityType === 'quiz') loadQuiz(board, currentData);\n        else if(slide.activityType === 'matching') loadMatching(board, currentData);\n        else if(slide.activityType === 'ordering') loadOrdering(board, currentData);\n        else if(slide.activityType === 'anagram') { anagramIndex=0; loadAnagram(board, currentData); }\n    }\n\n    function closeActivity() { document.getElementById('activity-overlay').style.display = 'none'; }\n\n    // 1. QUIZ\n    function loadQuiz(board, data) {\n        const show = (idx) => {\n            if(idx >= data.length) { board.innerHTML=\"<h2 class='success'>Tamamladın! 🎉</h2>\"; return; }\n            let q = data[idx];\n            board.innerHTML = `<h3 style=\"font-size:1.8rem; text-align:center;\">${q.q}</h3><div id=\"opts\" style=\"width:100%; display:flex; flex-direction:column; align-items:center;\"></div>`;\n            q.options.forEach(opt => {\n                let btn = document.createElement(\"div\"); btn.className = \"quiz-option\"; btn.textContent = opt;\n                btn.onclick = function() { \n                    if(opt === q.a) { this.style.background=\"#059669\"; setTimeout(()=>show(idx+1), 600); }\n                    else { this.style.background=\"#dc2626\"; }\n                };\n                document.getElementById('opts').appendChild(btn);\n            });\n        };\n        show(0);\n    }\n\n    // 2. EŞLEŞTİRME (YATAY DÜZEN)\n    function loadMatching(board, data) {\n        board.innerHTML = `<div class=\"match-container\"><div class=\"match-col\" id=\"left\"></div><div class=\"match-col\" id=\"right\"></div></div>`;\n        let leftCol = document.getElementById('left');\n        let rightCol = document.getElementById('right');\n        \n        let rightItems = [...data].sort(() => Math.random() - 0.5);\n\n        data.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.term; btn.dataset.pair = item.def;\n            btn.onclick = () => selectLeft(btn); leftCol.appendChild(btn);\n        });\n\n        rightItems.forEach(item => {\n            let btn = document.createElement('div'); btn.className = 'match-item'; \n            btn.textContent = item.def;\n            btn.onclick = () => checkMatch(btn); rightCol.appendChild(btn);\n        });\n    }\n\n    function selectLeft(elem) {\n        if(elem.classList.contains('matched')) return;\n        document.querySelectorAll('#col-left .match-item').forEach(e => e.classList.remove('selected'));\n        elem.classList.add('selected'); selectedItem = elem;\n    }\n\n    function checkMatch(elem) {\n        if(!selectedItem || elem.classList.contains('matched')) return;\n        const feedback = document.getElementById('feedback');\n        if(selectedItem.dataset.pair === elem.textContent) {\n            elem.classList.add('matched'); selectedItem.classList.add('matched'); selectedItem.classList.remove('selected'); selectedItem = null;\n            feedback.innerHTML = \"<span class='success'>Doğru!</span>\";\n            if(document.querySelectorAll('#col-left .match-item:not(.matched)').length === 0) feedback.innerHTML = \"<span class='success'>Tebrikler!</span>\";\n        } else {\n            elem.classList.add('wrong'); setTimeout(() => elem.classList.remove('wrong'), 500);\n            feedback.innerHTML = \"<span class='error'>Yanlış!</span>\";\n        }\n    }\n\n    // 3. SIRALAMA\n    function loadOrdering(board, data) {\n        board.innerHTML = `<p style=\"text-align:center; font-size:1.5rem;\">Sırasıyla seç:</p><div id=\"sort-area\" class=\"sort-container\"></div>`;\n        let area = document.getElementById('sort-area');\n        let shuffled = [...data].sort(()=>Math.random()-0.5);\n        let step = 0;\n\n        shuffled.forEach(txt => {\n            let div = document.createElement('div'); div.className = 'sort-item'; div.textContent = txt;\n            div.onclick = function() {\n                if(txt === data[step]) {\n                    this.style.background = '#059669'; this.style.pointerEvents='none'; step++;\n                    if(step === data.length) document.getElementById('feedback').innerHTML=\"<span class='success'>Tebrikler!</span>\";\n                } else {\n                    this.style.background = '#dc2626'; setTimeout(()=>this.style.background='#451a03', 500);\n                }\n            };\n            area.appendChild(div);\n        });\n    }\n\n    // 4. ANAGRAM\n    function loadAnagram(board, data) {\n        if(anagramIndex >= data.length) { board.innerHTML=\"<h2 class='success'>Bitti! 🎉</h2>\"; return; }\n        let item = data[anagramIndex];\n        currentAnagramState = { word: item.answer, pos: 0 };\n        board.innerHTML = `<div class=\"anagram-container\"><div style=\"margin-bottom:20px; color:#93c5fd; font-size:1.5rem;\">İpucu: ${item.hint}</div><div id=\"slots\" class=\"anagram-slots\"></div><div id=\"pool\" class=\"letter-pool\"></div></div>`;\n        \n        for(let i=0; i<item.answer.length; i++) {\n            let s = document.createElement('div'); s.className='anagram-slot'; s.id=`s-${i}`; document.getElementById('slots').appendChild(s);\n        }\n        item.scrambled.split('').forEach(char => {\n            let btn = document.createElement('button'); btn.className='letter-btn'; btn.textContent=char;\n            btn.onclick = function() {\n                if(char === currentAnagramState.word[currentAnagramState.pos]) {\n                    document.getElementById(`s-${currentAnagramState.pos}`).textContent = char;\n                    this.classList.add('correct'); currentAnagramState.pos++;\n                    if(currentAnagramState.pos >= item.answer.length) { anagramIndex++; setTimeout(()=>loadAnagram(board, data), 1000); }\n                } else {\n                    this.classList.add('wrong'); setTimeout(()=>this.classList.remove('wrong'), 400);\n                }\n            };\n            document.getElementById('pool').appendChild(btn);\n        });\n    }\n\n    // Başlat\n    init();\n</script>\n</body>\n</html>"
}