{
  "title": "2.Haccın Yapılışı",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Haccın Yapılışı ve Aşamaları</title>\n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Lucide Icons -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        body { font-family: 'Inter', sans-serif; }\n        .font-arabic { font-family: 'Amiri', serif; }\n        \n        /* Animasyonlar */\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-fade-in-up {\n            animation: fadeInUp 0.5s ease-out forwards;\n        }\n\n        /* Sekme İçerik Yönetimi */\n        .tab-content { display: none; }\n        .tab-content.active { display: block; }\n\n        /* Timeline Çizgisi */\n        .timeline-line::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            bottom: 0;\n            left: 24px;\n            width: 4px;\n            background: #e2e8f0;\n            z-index: 0;\n        }\n        \n        /* Özel Kaydırma Çubuğu Gizleme */\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n</head>\n<body class=\"min-h-screen bg-slate-50 text-slate-800 selection:bg-emerald-200\">\n\n    <!-- Header Section -->\n    <header class=\"bg-gradient-to-r from-emerald-900 to-teal-800 text-white py-12 px-4 relative overflow-hidden shadow-xl\">\n        <div class=\"absolute inset-0 opacity-10\" style=\"background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 30px 30px;\"></div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <div class=\"inline-flex items-center gap-2 bg-white/10 px-4 py-1 rounded-full mb-4 border border-white/20\">\n                <i data-lucide=\"calendar\" size=\"16\"></i>\n                <span class=\"text-sm font-medium\">Zilhicce 9-13</span>\n            </div>\n            <h1 class=\"text-4xl md:text-6xl font-bold mb-4 tracking-tight\">HACCIN YAPILIŞI</h1>\n            <p class=\"text-emerald-100 text-lg max-w-2xl mx-auto\">\"Hac Arafat'tır.\" (Hadis-i Şerif)</p>\n        </div>\n    </header>\n\n    <!-- Navigation Tabs -->\n    <div class=\"sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm border-b border-slate-200\">\n        <div class=\"max-w-6xl mx-auto flex overflow-x-auto p-2 gap-2 md:gap-4 no-scrollbar justify-start md:justify-center\">\n            <button onclick=\"openTab('yolculuk', this)\" class=\"tab-btn active flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-bold bg-emerald-600 text-white shadow-lg transform scale-105 transition-all whitespace-nowrap\">\n                <i data-lucide=\"map\"></i> Adım Adım Hac\n            </button>\n            <button onclick=\"openTab('ihram', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-emerald-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"shirt\"></i> İhram & Yasaklar\n            </button>\n            <button onclick=\"openTab('kavramlar', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-emerald-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"book-open\"></i> Tavaf & Say\n            </button>\n            <button onclick=\"openTab('hukuk', this)\" class=\"tab-btn flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-emerald-50 transition-all whitespace-nowrap\">\n                <i data-lucide=\"scale\"></i> Farz & Vacip\n            </button>\n        </div>\n    </div>\n\n    <main class=\"max-w-5xl mx-auto p-4 md:p-8 min-h-[600px]\">\n\n        <!-- TAB 1: ADIM ADIM HAC (TIMELINE) -->\n        <div id=\"yolculuk\" class=\"tab-content active animate-fade-in-up\">\n            <div class=\"text-center mb-10\">\n                <h2 class=\"text-2xl font-bold text-slate-800\">Hac İbadetinin Sıralaması</h2>\n                <p class=\"text-slate-500\">Mikat sınırından başlayıp Kabe'de son bulan manevi yolculuk.</p>\n            </div>\n\n            <div class=\"relative timeline-line pl-2 md:pl-4 space-y-8\">\n                \n                <!-- Step 1 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-emerald-600 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-emerald-800\">1. Mikat Sınırı & İhram</h3>\n                            <span class=\"bg-emerald-100 text-emerald-800 text-xs px-2 py-1 rounded-md font-bold\">Başlangıç</span>\n                        </div>\n                        <p class=\"text-slate-600 mb-3\">Hac niyeti edilir, ihrama girilir ve Telbiye getirilmeye başlanır.</p>\n                        <div class=\"bg-emerald-50 p-3 rounded-lg border-l-4 border-emerald-500 italic text-sm text-emerald-900\">\n                            \"Lebbeyk Allâhümme lebbeyk...\" (Buyur Allah'ım buyur...)\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Step 2 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-blue-500 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-slate-800\">2. Kudüm Tavafı</h3>\n                            <span class=\"bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-md font-bold\">Sünnet</span>\n                        </div>\n                        <p class=\"text-slate-600\">Mekke'ye varınca yapılan ilk selamlama tavafıdır.</p>\n                    </div>\n                </div>\n\n                <!-- Step 3 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[10px] top-0 w-7 h-7 bg-red-600 rounded-full border-4 border-white shadow z-10 animate-pulse\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border-l-4 border-red-500 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-red-700\">3. Arafat Vakfesi</h3>\n                            <span class=\"bg-red-100 text-red-800 text-xs px-2 py-1 rounded-md font-bold\">FARZ</span>\n                        </div>\n                        <div class=\"text-sm text-slate-500 mb-2 flex items-center gap-1\"><i data-lucide=\"clock\" size=\"14\"></i> Zilhicce 9 (Arefe Günü) - Öğle/İkindi</div>\n                        <p class=\"text-slate-700\">Haccın en önemli rüknüdür. \"Hac Arafat'tır.\" Burada öğle ve ikindi namazı birleştirilir, dua edilir.</p>\n                    </div>\n                </div>\n\n                <!-- Step 4 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-orange-500 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-slate-800\">4. Müzdelife Vakfesi</h3>\n                            <span class=\"bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded-md font-bold\">Vacip</span>\n                        </div>\n                        <p class=\"text-slate-600 mb-2\">Arefe akşamı yapılır. Akşam ve yatsı namazı birleştirilir. Şeytan taşlamak için taş toplanır.</p>\n                    </div>\n                </div>\n\n                <!-- Step 5 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-orange-500 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-slate-800\">5. Mina (Şeytan Taşlama)</h3>\n                            <span class=\"bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded-md font-bold\">Vacip</span>\n                        </div>\n                        <p class=\"text-slate-600\">Bayram günlerinde cemrelere taş atılır. Kötülüğü reddetmeyi sembolize eder.</p>\n                    </div>\n                </div>\n\n                <!-- Step 6 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-orange-500 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-slate-800\">6. Kurban & Tıraş</h3>\n                            <span class=\"bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded-md font-bold\">Vacip</span>\n                        </div>\n                        <p class=\"text-slate-600\">Hedy kurbanı kesilir ve saç tıraşı olunarak İhramdan çıkılır.</p>\n                    </div>\n                </div>\n\n                <!-- Step 7 -->\n                <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[10px] top-0 w-7 h-7 bg-red-600 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border-l-4 border-red-500 w-full hover:shadow-xl transition-shadow ml-8\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-red-700\">7. Ziyaret Tavafı & Say</h3>\n                            <span class=\"bg-red-100 text-red-800 text-xs px-2 py-1 rounded-md font-bold\">FARZ / VACİP</span>\n                        </div>\n                        <p class=\"text-slate-700\">Haccın farz olan son tavafı yapılır. Ardından Safa ve Merve arasında Say (Vacip) yapılır.</p>\n                    </div>\n                </div>\n\n                 <!-- Step 8 -->\n                 <div class=\"relative flex items-start gap-6 group\">\n                    <div class=\"absolute left-[14px] top-0 w-5 h-5 bg-blue-500 rounded-full border-4 border-white shadow z-10\"></div>\n                    <div class=\"bg-white p-6 rounded-2xl shadow-md border border-slate-100 w-full hover:shadow-xl transition-shadow ml-8 opacity-75\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h3 class=\"text-xl font-bold text-slate-800\">8. Veda Tavafı</h3>\n                            <span class=\"bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-md font-bold\">Sünnet/Vacip</span>\n                        </div>\n                        <p class=\"text-slate-600\">Mekke'den ayrılmadan önce yapılan son tavaftır.</p>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n\n        <!-- TAB 2: İHRAM VE YASAKLAR -->\n        <div id=\"ihram\" class=\"tab-content animate-fade-in-up\">\n            \n            <!-- Telbiye Kartı -->\n            <div class=\"bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-6 mb-8 text-center relative overflow-hidden\">\n                <i data-lucide=\"mic\" class=\"absolute top-4 right-4 text-amber-200 opacity-50\" width=\"64\" height=\"64\"></i>\n                <h3 class=\"text-xl font-bold text-amber-800 mb-2\">Telbiye Duası</h3>\n                <p class=\"text-slate-600 text-sm mb-4\">Hac ve Umrede okunan ortak dua (Söz)</p>\n                <div class=\"bg-white/60 p-4 rounded-xl backdrop-blur-sm\">\n                    <p class=\"font-arabic text-2xl text-slate-800 mb-2\">Lebbeyk Allâhümme lebbeyk...</p>\n                    <p class=\"text-slate-600 italic\">\"Buyur Allah’ım buyur! Emrindeyim buyur! Senin hiçbir ortağın yoktur...\"</p>\n                </div>\n            </div>\n\n            <div class=\"grid md:grid-cols-2 gap-6\">\n                <!-- Serbest Olanlar -->\n                <div class=\"bg-white rounded-2xl shadow-lg border-t-4 border-emerald-500 overflow-hidden\">\n                    <div class=\"bg-emerald-50 p-4 border-b border-emerald-100\">\n                        <h3 class=\"font-bold text-emerald-800 flex items-center gap-2\">\n                            <i data-lucide=\"check-circle\"></i> İhramlıyken Yapılabilir\n                        </h3>\n                    </div>\n                    <ul class=\"p-6 space-y-4\">\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-emerald-100 p-2 rounded-full\"><i data-lucide=\"watch\" size=\"18\" class=\"text-emerald-600\"></i></div>\n                            Kol saati, yüzük ve bilezik takmak\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-emerald-100 p-2 rounded-full\"><i data-lucide=\"briefcase\" size=\"18\" class=\"text-emerald-600\"></i></div>\n                            Kemer ve çanta kullanmak\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-emerald-100 p-2 rounded-full\"><i data-lucide=\"smile\" size=\"18\" class=\"text-emerald-600\"></i></div>\n                            Diş fırçalamak\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-emerald-100 p-2 rounded-full\"><i data-lucide=\"droplet\" size=\"18\" class=\"text-emerald-600\"></i></div>\n                            Parfümsüz sabun kullanmak\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Yasak Olanlar -->\n                <div class=\"bg-white rounded-2xl shadow-lg border-t-4 border-red-500 overflow-hidden\">\n                    <div class=\"bg-red-50 p-4 border-b border-red-100\">\n                        <h3 class=\"font-bold text-red-800 flex items-center gap-2\">\n                            <i data-lucide=\"x-circle\"></i> İhram Yasakları\n                        </h3>\n                    </div>\n                    <ul class=\"p-6 space-y-4\">\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-red-100 p-2 rounded-full\"><i data-lucide=\"scissors\" size=\"18\" class=\"text-red-600\"></i></div>\n                            Tırnak kesmek, tıraş olmak\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-red-100 p-2 rounded-full\"><i data-lucide=\"flower\" size=\"18\" class=\"text-red-600\"></i></div>\n                            Parfüm sürmek, kokulu sabun\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-red-100 p-2 rounded-full\"><i data-lucide=\"sprout\" size=\"18\" class=\"text-red-600\"></i></div>\n                            Bitkileri koparmak, hayvanları incitmek\n                        </li>\n                        <li class=\"flex items-center gap-3 text-slate-700\">\n                            <div class=\"bg-red-100 p-2 rounded-full\"><i data-lucide=\"message-square-off\" size=\"18\" class=\"text-red-600\"></i></div>\n                            Kavga etmek, kötü söz söylemek\n                        </li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n\n        <!-- TAB 3: KAVRAMLAR (TAVAF & SAY) -->\n        <div id=\"kavramlar\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"grid md:grid-cols-2 gap-8\">\n                \n                <!-- TAVAF KARTI -->\n                <div class=\"bg-white p-8 rounded-3xl shadow-xl border border-slate-100 relative\">\n                    <div class=\"absolute top-0 right-0 bg-slate-800 text-white px-4 py-2 rounded-bl-2xl rounded-tr-2xl font-bold\">Kabe</div>\n                    <h3 class=\"text-2xl font-bold text-slate-800 mb-6 flex items-center gap-2\">\n                        <i data-lucide=\"rotate-ccw\" class=\"text-emerald-600\"></i> Tavaf\n                    </h3>\n                    \n                    <div class=\"space-y-6\">\n                        <div class=\"flex gap-4\">\n                            <div class=\"w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center shrink-0 font-bold text-emerald-700\">7</div>\n                            <div>\n                                <h4 class=\"font-bold text-slate-800\">Şavt</h4>\n                                <p class=\"text-sm text-slate-600\">Kabe'nin etrafında her bir dönüşe şavt denir. 7 şavt = 1 Tavaf eder.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\">\n                            <div class=\"w-12 h-12 bg-black rounded-full flex items-center justify-center shrink-0 border-2 border-slate-200\">\n                                <div class=\"w-3 h-3 bg-slate-600 rounded-full\"></div>\n                            </div>\n                            <div>\n                                <h4 class=\"font-bold text-slate-800\">Hacerülesved</h4>\n                                <p class=\"text-sm text-slate-600\">Tavafın başlangıç noktasıdır (Siyah Taş). Hz. İbrahim tarafından konulmuştur.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\">\n                            <div class=\"w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0 text-blue-600\">\n                                <i data-lucide=\"droplet\"></i>\n                            </div>\n                            <div>\n                                <h4 class=\"font-bold text-slate-800\">Zemzem</h4>\n                                <p class=\"text-sm text-slate-600\">Hacerülesved'in karşısından çıkan kutsal su.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- SAY KARTI -->\n                <div class=\"bg-white p-8 rounded-3xl shadow-xl border border-slate-100 relative\">\n                    <div class=\"absolute top-0 right-0 bg-orange-600 text-white px-4 py-2 rounded-bl-2xl rounded-tr-2xl font-bold\">Vacip</div>\n                    <h3 class=\"text-2xl font-bold text-slate-800 mb-6 flex items-center gap-2\">\n                        <i data-lucide=\"footprints\" class=\"text-orange-600\"></i> Say\n                    </h3>\n                    \n                    <div class=\"flex items-center justify-between bg-slate-50 p-4 rounded-xl mb-6\">\n                        <div class=\"text-center\">\n                            <div class=\"font-bold text-slate-800\">Safa Tepesi</div>\n                            <div class=\"text-xs text-green-600 font-bold\">Başlangıç</div>\n                        </div>\n                        <div class=\"flex-1 mx-4 h-1 bg-slate-300 relative\">\n                            <div class=\"absolute -top-3 left-1/2 -translate-x-1/2 bg-white border border-slate-300 px-2 py-0.5 rounded text-xs\">\n                                4 Gidiş - 3 Dönüş\n                            </div>\n                        </div>\n                        <div class=\"text-center\">\n                            <div class=\"font-bold text-slate-800\">Merve Tepesi</div>\n                            <div class=\"text-xs text-red-600 font-bold\">Bitiş</div>\n                        </div>\n                    </div>\n                    <p class=\"text-slate-600 leading-relaxed\">\n                        Safa ve Merve tepeleri arasında toplam 7 kez yürümektir. Ziyaret tavafından sonra yapılır.\n                    </p>\n                </div>\n\n            </div>\n        </div>\n\n        <!-- TAB 4: HUKUK (FARZ & VACİP) -->\n        <div id=\"hukuk\" class=\"tab-content animate-fade-in-up\">\n            <div class=\"bg-white rounded-2xl shadow-lg overflow-hidden\">\n                <div class=\"p-6 bg-slate-800 text-white text-center\">\n                    <h2 class=\"text-2xl font-bold\">Haccın Hükümleri</h2>\n                    <p class=\"text-slate-300 text-sm mt-2\">İbadetin geçerli olması için bilinmesi gerekenler</p>\n                </div>\n                \n                <div class=\"grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-slate-200\">\n                    <!-- FARZLAR -->\n                    <div class=\"p-8 hover:bg-red-50/50 transition-colors\">\n                        <div class=\"flex items-center gap-3 mb-6\">\n                            <div class=\"bg-red-100 p-3 rounded-lg text-red-600\"><i data-lucide=\"alert-circle\" size=\"24\"></i></div>\n                            <h3 class=\"text-2xl font-bold text-red-700\">Haccın Farzları</h3>\n                        </div>\n                        <p class=\"text-sm text-slate-500 mb-4 italic\">Bunlardan biri eksik olursa hac geçerli olmaz.</p>\n                        <ul class=\"space-y-4\">\n                            <li class=\"flex items-center gap-3 font-semibold text-slate-700\">\n                                <span class=\"w-6 h-6 rounded-full bg-red-600 text-white flex items-center justify-center text-xs\">1</span>\n                                İhram (Şart)\n                            </li>\n                            <li class=\"flex items-center gap-3 font-semibold text-slate-700\">\n                                <span class=\"w-6 h-6 rounded-full bg-red-600 text-white flex items-center justify-center text-xs\">2</span>\n                                Arafat'ta Vakfe (Rükün)\n                            </li>\n                            <li class=\"flex items-center gap-3 font-semibold text-slate-700\">\n                                <span class=\"w-6 h-6 rounded-full bg-red-600 text-white flex items-center justify-center text-xs\">3</span>\n                                Ziyaret Tavafı (Rükün)\n                            </li>\n                        </ul>\n                    </div>\n\n                    <!-- VACİPLER -->\n                    <div class=\"p-8 hover:bg-orange-50/50 transition-colors\">\n                        <div class=\"flex items-center gap-3 mb-6\">\n                            <div class=\"bg-orange-100 p-3 rounded-lg text-orange-600\"><i data-lucide=\"check-square\" size=\"24\"></i></div>\n                            <h3 class=\"text-2xl font-bold text-orange-700\">Haccın Vacipleri</h3>\n                        </div>\n                        <p class=\"text-sm text-slate-500 mb-4 italic\">Eksikliğinde ceza (kurban) gerekir ama hac bozulmaz.</p>\n                        <ul class=\"space-y-3\">\n                            <li class=\"flex items-center gap-2 text-slate-700\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Say Yapmak</li>\n                            <li class=\"flex items-center gap-2 text-slate-700\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Müzdelife Vakfesi</li>\n                            <li class=\"flex items-center gap-2 text-slate-700\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Şeytan Taşlamak</li>\n                            <li class=\"flex items-center gap-2 text-slate-700\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Kurban Kesmek & Tıraş</li>\n                            <li class=\"flex items-center gap-2 text-slate-700\"><i data-lucide=\"check\" size=\"16\" class=\"text-orange-500\"></i> Veda Tavafı</li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n    </main>\n\n    <footer class=\"py-8 text-center text-slate-400 text-sm mt-12 border-t border-slate-200\">\n        <p>2. Ünite: Hac ve Kurban | Görsel 2.4, Grafik Bilgi 2.2, 2.3, 2.4 ve 2.5 referans alınmıştır.</p>\n    </footer>\n\n    <script>\n        // İkonları oluştur\n        lucide.createIcons();\n\n        function openTab(tabName, btnElement) {\n            // İçerikleri gizle\n            const contents = document.getElementsByClassName(\"tab-content\");\n            for (let i = 0; i < contents.length; i++) {\n                contents[i].classList.remove(\"active\");\n            }\n            \n            // Buton stillerini sıfırla\n            const buttons = document.getElementsByClassName(\"tab-btn\");\n            for (let i = 0; i < buttons.length; i++) {\n                buttons[i].classList.remove(\"active\", \"bg-emerald-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n                buttons[i].classList.add(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-emerald-50\");\n            }\n\n            // Seçileni aç ve stillendir\n            document.getElementById(tabName).classList.add(\"active\");\n            \n            // Animasyon tekrarı için reflow\n            const activeContent = document.getElementById(tabName);\n            activeContent.classList.remove('animate-fade-in-up');\n            void activeContent.offsetWidth; \n            activeContent.classList.add('animate-fade-in-up');\n\n            // Aktif buton stili\n            btnElement.classList.remove(\"bg-slate-100\", \"text-slate-600\", \"hover:bg-emerald-50\");\n            btnElement.classList.add(\"active\", \"bg-emerald-600\", \"text-white\", \"shadow-lg\", \"scale-105\");\n        }\n    </script>\n</body>\n</html>"
}