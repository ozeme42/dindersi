  {
    "type": "htmlSlide",
    "title": "İnteraktif Sunum",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bir Dua Öğreniyorum: İftar Duası</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600;800&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            background-color: #f8fafc;\n            font-family: 'Inter', sans-serif;\n            height: 100vh;\n            width: 100vw;\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        /* Arkaplan Deseni */\n        .islamic-bg {\n            position: absolute;\n            top: 0; left: 0; width: 100%; height: 100%;\n            background-color: #0f172a; /* Slate 900 */\n            background-image: \n                radial-gradient(circle at 50% 50%, #1e293b 0%, #0f172a 100%),\n                url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23fbbf24' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n            z-index: -1;\n        }\n\n        .main-container {\n            width: 95%;\n            height: 90%;\n            background: rgba(255, 255, 255, 0.95);\n            backdrop-filter: blur(10px);\n            border-radius: 20px;\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n            display: flex;\n            flex-direction: column;\n            overflow: hidden;\n        }\n\n        /* Tab Butonları */\n        .tab-btn {\n            transition: all 0.3s ease;\n            position: relative;\n        }\n        .tab-btn.active {\n            background-color: #fff;\n            color: #d97706; /* Amber 600 */\n            border-bottom: 4px solid #d97706;\n        }\n        .tab-btn:hover:not(.active) {\n            background-color: rgba(255,255,255,0.1);\n            color: #fbbf24;\n        }\n\n        /* İçerik Alanı */\n        .content-area {\n            flex-grow: 1;\n            padding: 0;\n            overflow-y: hidden; /* Scroll içerideki tab-content'te olacak */\n            position: relative;\n            background-color: #f1f5f9;\n        }\n\n        .tab-content {\n            display: none;\n            height: 100%;\n            width: 100%;\n            overflow-y: auto; /* Uzun içerik kaydırılabilsin */\n            padding: 2rem;\n            animation: fadeIn 0.5s ease;\n        }\n        \n        .tab-content.active {\n            display: block;\n        }\n\n        /* Bölüm Başlıkları */\n        .section-header {\n            display: flex;\n            align-items: center;\n            margin-bottom: 1.5rem;\n            margin-top: 2rem;\n            padding-bottom: 0.5rem;\n            border-bottom: 2px solid #e2e8f0;\n        }\n        .section-header:first-child { margin-top: 0; }\n        \n        .section-number {\n            background-color: #d97706;\n            color: white;\n            width: 32px;\n            height: 32px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            margin-right: 1rem;\n        }\n        .section-title {\n            font-size: 1.5rem;\n            font-weight: 700;\n            color: #1e293b;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(10px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        h1, .arabic-text { font-family: 'Amiri', serif; }\n\n        /* Oyun Butonları */\n        .word-piece {\n            transition: transform 0.2s, background-color 0.2s;\n            cursor: pointer;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n        }\n        .word-piece:hover { transform: scale(1.05); }\n        .word-piece.used {\n            opacity: 0.5;\n            pointer-events: none;\n            background-color: #cbd5e1;\n            border-color: #94a3b8;\n        }\n\n        /* Scrollbar Özelleştirme */\n        .tab-content::-webkit-scrollbar {\n            width: 8px;\n        }\n        .tab-content::-webkit-scrollbar-track {\n            background: #f1f5f9; \n        }\n        .tab-content::-webkit-scrollbar-thumb {\n            background: #cbd5e1; \n            border-radius: 4px;\n        }\n        .tab-content::-webkit-scrollbar-thumb:hover {\n            background: #94a3b8; \n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"islamic-bg\"></div>\n\n    <div class=\"main-container\">\n        <!-- Üst Başlık ve Navigasyon -->\n        <header class=\"bg-slate-800 text-slate-200 shrink-0\">\n            <div class=\"flex justify-between items-center px-6 py-4 border-b border-slate-700\">\n                <div class=\"flex items-center gap-3\">\n                    <div class=\"bg-amber-500 text-slate-900 w-10 h-10 rounded-full flex items-center justify-center font-bold text-xl\">\n                        <i class=\"fas fa-moon\"></i>\n                    </div>\n                    <div>\n                        <h1 class=\"text-xl font-bold text-white\">Bir Dua Öğreniyorum</h1>\n                        <p class=\"text-xs text-slate-400\">2. Ünite: Ramazan ve Oruç</p>\n                    </div>\n                </div>\n            </div>\n            \n            <!-- Sekmeler: Sadece 2 Tane Kaldı -->\n            <nav class=\"flex text-lg font-bold\">\n                <button onclick=\"switchTab('konu-anlatimi')\" class=\"tab-btn active flex-1 py-4 text-center hover:bg-slate-700\" id=\"btn-konu-anlatimi\">\n                    <i class=\"fas fa-book-reader mr-2\"></i> Konu Anlatımı\n                </button>\n                <button onclick=\"switchTab('etkinlik')\" class=\"tab-btn flex-1 py-4 text-center hover:bg-slate-700\" id=\"btn-etkinlik\">\n                    <i class=\"fas fa-gamepad mr-2\"></i> Sıralama Oyunu\n                </button>\n            </nav>\n        </header>\n\n        <!-- İçerik Alanı -->\n        <div class=\"content-area\">\n\n            <!-- TAB 1: KONU ANLATIMI (BİRLEŞTİRİLMİŞ) -->\n            <div id=\"konu-anlatimi\" class=\"tab-content active\">\n                <div class=\"max-w-5xl mx-auto space-y-12 pb-12\">\n                    \n                    <!-- BÖLÜM 1: GİRİŞ -->\n                    <section>\n                        <div class=\"section-header\">\n                            <div class=\"section-number\">1</div>\n                            <h2 class=\"section-title\">Konuya Başlarken</h2>\n                        </div>\n\n                        <div class=\"bg-amber-50 border-l-4 border-amber-500 p-4 rounded shadow-sm mb-6\">\n                            <h3 class=\"font-bold text-amber-800 flex items-center\"><i class=\"fas fa-info-circle mr-2\"></i> Bilgi Notu</h3>\n                            <p class=\"text-gray-700 mt-1\">\n                                Oruç açılırken dua edilmesi <strong>sünnettir</strong>. Hz. Peygamber, orucunu açarken iftar duası ederek verdiği nimetler için Allah’a (cc) şükretmiş ve iftar vaktinde yapılan duanın geri çevrilmeyeceğini müjdelemiştir.\n                            </p>\n                        </div>\n                    </section>\n\n                    <!-- BÖLÜM 2: İFTAR DUASI -->\n                    <section>\n                        <div class=\"section-header\">\n                            <div class=\"section-number\">2</div>\n                            <h2 class=\"section-title\">İftar Duası</h2>\n                        </div>\n                        \n                        <div class=\"bg-white p-8 rounded-2xl shadow-lg border-2 border-amber-100 relative overflow-hidden text-center\">\n                            <div class=\"absolute top-0 right-0 p-4 opacity-10 text-amber-600 text-6xl font-serif\">❝</div>\n                            <!-- Arapça Metin Kaldırıldı -->\n                            <div class=\"bg-slate-100 py-3 px-6 rounded-full inline-block mb-4 mt-8\">\n                                <h3 class=\"text-lg md:text-xl font-bold text-amber-700\">\"Allâhümme leke sumtü ve bike âmentü ve aleyke tevekkeltü ve alâ rızkıke eftartü\"</h3>\n                            </div>\n                            <p class=\"text-xl md:text-2xl text-slate-600 italic font-serif mt-4\">\n                                “Allah’ım! Senin rızan için oruç tuttum, sana inandım, sana güvendim. Senin rızkınla orucumu açtım.”\n                            </p>\n                        </div>\n                    </section>\n\n                    <!-- BÖLÜM 3: ÖZET BİLGİ -->\n                    <section>\n                        <div class=\"section-header\">\n                            <div class=\"section-number\">3</div>\n                            <h2 class=\"section-title\">Önemli Noktalar</h2>\n                        </div>\n\n                        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                            <div class=\"bg-white p-6 rounded-xl shadow-sm border-l-4 border-emerald-500\">\n                                <h3 class=\"font-bold text-lg text-emerald-800 mb-3\">Duanın Anlamı ve Yeri</h3>\n                                <ul class=\"space-y-3\">\n                                    <li class=\"flex items-start gap-3\">\n                                        <i class=\"fas fa-check-circle text-emerald-500 mt-1\"></i>\n                                        <span class=\"text-slate-600\"><strong>İman ve Güven:</strong> Allah'a olan bağlılığımızı ve güvenimizi ifade eder.</span>\n                                    </li>\n                                    <li class=\"flex items-start gap-3\">\n                                        <i class=\"fas fa-check-circle text-emerald-500 mt-1\"></i>\n                                        <span class=\"text-slate-600\"><strong>Şükür:</strong> Nimetlerin sahibinin Allah olduğunu hatırlayarak şükrederiz.</span>\n                                    </li>\n                                </ul>\n                            </div>\n                            <div class=\"bg-slate-800 text-white p-6 rounded-xl flex flex-col justify-center items-center text-center shadow-lg\">\n                                <i class=\"fas fa-star text-amber-400 mb-3 text-3xl\"></i>\n                                <p class=\"font-serif italic text-lg\">\"Oruçlunun iftar vaktinde yaptığı dua geri çevrilmez.\"</p>\n                                <span class=\"text-xs text-slate-400 mt-2 block\">— Hz. Muhammed (sav)</span>\n                            </div>\n                        </div>\n                    </section>\n\n                    <!-- BÖLÜM 4: DÜŞÜNCE DÜNYASI -->\n                    <section>\n                        <div class=\"section-header\">\n                            <div class=\"section-number\">4</div>\n                            <h2 class=\"section-title\">Düşünce Dünyası</h2>\n                        </div>\n\n                        <div class=\"bg-[url('https://www.transparenttextures.com/patterns/cream-paper.png')] bg-[#fffdf5] p-8 rounded-xl shadow-lg border border-amber-200 relative\">\n                            <i class=\"fas fa-pray absolute top-6 right-6 text-amber-300 text-3xl\"></i>\n                            <h3 class=\"text-2xl font-serif text-amber-800 mb-2 border-b-2 border-amber-200 pb-2 inline-block\">Benim Duam</h3>\n                            <p class=\"text-sm text-slate-500 mb-4\">İftar duasını devam ettirecek olsanız Yüce Allah'tan başka neler isterdiniz?</p>\n                            \n                            <textarea class=\"w-full h-40 bg-transparent border-none outline-none text-lg font-serif text-slate-700 leading-loose resize-none\" \n                            style=\"background-image: linear-gradient(transparent, transparent 31px, #e2e8f0 31px); background-size: 100% 32px; line-height: 32px;\"\n                            placeholder=\"Ey Yüce Rabb'im! ...\"></textarea>\n                        </div>\n                    </section>\n\n                </div>\n            </div>\n\n            <!-- TAB 2: ETKİNLİK (OYUN) -->\n            <div id=\"etkinlik\" class=\"tab-content items-center justify-center\">\n                <div class=\"max-w-5xl mx-auto h-full flex flex-col justify-center\">\n                    <div class=\"bg-white p-6 rounded-2xl shadow-xl border border-slate-200\">\n                        <div class=\"text-center mb-6\">\n                            <h2 class=\"text-2xl font-bold text-slate-800\">Kontrol Noktası: Sıralama Oyunu</h2>\n                            <p class=\"text-slate-500\">Aşağıdaki karışık verilmiş dua parçalarına <strong>doğru sırayla</strong> tıklayarak duayı tamamlayınız.</p>\n                        </div>\n\n                        <!-- Cevap Alanı (Boşluklar) -->\n                        <div id=\"answer-area\" class=\"flex flex-wrap justify-center gap-3 mb-8 min-h-[100px] bg-slate-100 p-4 rounded-xl border-2 border-dashed border-slate-300 items-center transition-all\">\n                            <span class=\"text-slate-400 italic text-sm\" id=\"placeholder-text\">Parçaları buraya dizmek için aşağıdan seçiniz...</span>\n                        </div>\n\n                        <!-- Parça Havuzu -->\n                        <div id=\"pieces-pool\" class=\"flex flex-wrap justify-center gap-4 mb-6\">\n                            <!-- JS ile doldurulacak -->\n                        </div>\n\n                        <!-- Kontrol ve Sonuç -->\n                        <div class=\"text-center h-12\">\n                            <div id=\"feedback-msg\" class=\"hidden text-lg font-bold\"></div>\n                            <button onclick=\"resetGame()\" id=\"reset-btn\" class=\"hidden bg-slate-600 text-white px-4 py-2 rounded hover:bg-slate-700 text-sm mt-2\">\n                                <i class=\"fas fa-redo\"></i> Tekrar Dene\n                            </button>\n                        </div>\n\n                        <!-- İpucu Tablosu (Gizlenebilir/Yardımcı) -->\n                        <div class=\"mt-8 border-t pt-4\">\n                            <details class=\"text-slate-500 text-sm cursor-pointer\">\n                                <summary class=\"hover:text-amber-600 font-bold\">İpucu: Anlam Sıralaması</summary>\n                                <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2 bg-amber-50 p-4 rounded text-left\">\n                                    <ol class=\"list-decimal list-inside space-y-1\">\n                                        <li>Allah'ım!</li>\n                                        <li>Senin rızan için oruç tuttum.</li>\n                                        <li>Sana inandım.</li>\n                                        <li>Sana güvendim.</li>\n                                        <li>Senin rızkınla orucumu açtım.</li>\n                                    </ol>\n                                </div>\n                            </details>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n\n    <script>\n        // --- SEKME YÖNETİMİ ---\n        function switchTab(tabId) {\n            // Tüm içerikleri gizle\n            document.querySelectorAll('.tab-content').forEach(el => {\n                el.classList.remove('active');\n            });\n            // Tüm butonların aktifliğini kaldır (ve stilini sıfırla)\n            document.querySelectorAll('.tab-btn').forEach(el => {\n                el.classList.remove('active');\n                el.classList.add('text-slate-400'); // Pasif renk\n                el.classList.remove('text-amber-600', 'bg-white', 'border-b-4', 'border-amber-600');\n            });\n\n            // Seçilen içeriği göster\n            document.getElementById(tabId).classList.add('active');\n            \n            // Seçilen butonu aktif yap\n            const activeBtn = document.getElementById('btn-' + tabId);\n            activeBtn.classList.add('active');\n            \n            // Eğer etkinlik sekmesi açıldıysa oyunu sıfırla\n            if(tabId === 'etkinlik') {\n                resetGame();\n            }\n        }\n\n        // --- OYUN MANTIĞI ---\n        const correctOrder = [\n            { text: \"Allâhümme\", arabic: \"اَللّٰهُمَّ\", id: 1 },\n            { text: \"leke sumtü\", arabic: \"لَكَ صُمْتُ\", id: 2 },\n            { text: \"ve bike âmentü\", arabic: \"وَ بِكَ اٰمَنْتُ\", id: 3 },\n            { text: \"ve aleyke tevekkeltü\", arabic: \"وَ عَلَيْكَ تَوَكَّلْتُ\", id: 4 },\n            { text: \"ve alâ rızkıke eftartü\", arabic: \"وَ عَلٰى رِزْقِكَ اَفْطَرْتُ\", id: 5 }\n        ];\n\n        let currentStep = 0;\n        let gameActive = true;\n\n        // Parçaları karıştır ve ekrana bas\n        function initGame() {\n            const pool = document.getElementById('pieces-pool');\n            pool.innerHTML = '';\n            document.getElementById('answer-area').innerHTML = '<span class=\"text-slate-400 italic text-sm\" id=\"placeholder-text\">Parçaları buraya dizmek için aşağıdan seçiniz...</span>';\n            document.getElementById('feedback-msg').className = 'hidden';\n            document.getElementById('reset-btn').classList.add('hidden');\n            document.getElementById('answer-area').className = 'flex flex-wrap justify-center gap-3 mb-8 min-h-[100px] bg-slate-100 p-4 rounded-xl border-2 border-dashed border-slate-300 items-center transition-all';\n            \n            currentStep = 0;\n            gameActive = true;\n\n            let shuffled = [...correctOrder].sort(() => Math.random() - 0.5);\n\n            shuffled.forEach(item => {\n                const btn = document.createElement('button');\n                btn.className = 'word-piece bg-white border-2 border-amber-500 text-amber-800 py-2 px-4 rounded-xl shadow-md transition-all hover:-translate-y-1';\n                // HTML içeriği: Sadece Türkçe\n                btn.innerHTML = `\n                    <span class=\"block text-lg font-bold pointer-events-none\">${item.text}</span>\n                `;\n                btn.dataset.id = item.id;\n                btn.onclick = () => handlePieceClick(btn, item.id);\n                pool.appendChild(btn);\n            });\n        }\n\n        function handlePieceClick(btn, id) {\n            if (!gameActive) return;\n\n            const correctItem = correctOrder[currentStep];\n\n            if (id === correctItem.id) {\n                const placeholder = document.getElementById('placeholder-text');\n                if (placeholder) placeholder.remove();\n\n                btn.classList.add('used');\n                btn.classList.remove('bg-white', 'border-amber-500', 'text-amber-800');\n                btn.classList.add('bg-slate-200', 'border-slate-300', 'text-slate-400');\n\n                const answerArea = document.getElementById('answer-area');\n                const span = document.createElement('div');\n                span.className = 'bg-emerald-500 text-white py-2 px-4 rounded-lg shadow-lg flex flex-col items-center animate-bounce-short cursor-default';\n                // HTML içeriği: Sadece Türkçe\n                span.innerHTML = `\n                    <span class=\"text-sm font-bold uppercase tracking-wider\">${correctItem.text}</span>\n                `;\n                answerArea.appendChild(span);\n\n                currentStep++;\n\n                if (currentStep === correctOrder.length) {\n                    gameActive = false;\n                    showFeedback(true);\n                }\n\n            } else {\n                btn.classList.add('bg-red-500', 'text-white', 'border-red-600');\n                setTimeout(() => {\n                    btn.classList.remove('bg-red-500', 'text-white', 'border-red-600');\n                }, 400);\n            }\n        }\n\n        function showFeedback(success) {\n            const msg = document.getElementById('feedback-msg');\n            const box = document.getElementById('answer-area');\n            const resetBtn = document.getElementById('reset-btn');\n\n            msg.classList.remove('hidden');\n            resetBtn.classList.remove('hidden');\n\n            if (success) {\n                msg.innerHTML = '<span class=\"text-emerald-600\"><i class=\"fas fa-check-circle\"></i> Tebrikler! Duayı doğru sıraladınız.</span>';\n                box.classList.remove('border-slate-300', 'bg-slate-100');\n                box.classList.add('border-emerald-500', 'bg-emerald-50');\n            }\n        }\n\n        function resetGame() {\n            initGame();\n        }\n    </script>\n\n    <style>\n        @keyframes bounceShort {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-5px); }\n        }\n        .animate-bounce-short {\n            animation: bounceShort 0.3s ease-in-out;\n        }\n    </style>\n</body>\n</html>"
  },
