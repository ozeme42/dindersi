    "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Rehberin İzinde: Genç Bir Kalbin Yolculuğu</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\" rel=\"stylesheet\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');\n        \n        body {\n            font-family: 'Nunito', sans-serif;\n            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);\n        }\n\n        .card-hover:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 20px rgba(0,0,0,0.1);\n        }\n\n        .game-transition {\n            transition: all 0.3s ease-in-out;\n        }\n\n        .correct-anim {\n            animation: pulse-green 0.5s;\n        }\n\n        .wrong-anim {\n            animation: shake 0.5s;\n        }\n\n        @keyframes pulse-green {\n            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }\n            70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }\n            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }\n        }\n\n        @keyframes shake {\n            0% { transform: translateX(0); }\n            25% { transform: translateX(-5px); }\n            50% { transform: translateX(5px); }\n            75% { transform: translateX(-5px); }\n            100% { transform: translateX(0); }\n        }\n\n        .confetti {\n            position: absolute;\n            width: 10px;\n            height: 10px;\n            background-color: #f00;\n            animation: fall linear forwards;\n        }\n\n        @keyframes fall {\n            to { transform: translateY(100vh) rotate(720deg); }\n        }\n    </style>\n</head>\n<body class=\"min-h-screen text-slate-800 flex flex-col\">\n\n    <!-- Navbar -->\n    <nav class=\"bg-teal-700 text-white p-4 shadow-lg sticky top-0 z-50\">\n        <div class=\"container mx-auto flex justify-between items-center\">\n            <h1 class=\"text-xl md:text-2xl font-bold\"><i class=\"fas fa-compass mr-2\"></i>Rehberin İzinde</h1>\n            <div class=\"text-sm md:text-base bg-teal-800 px-4 py-2 rounded-full font-bold shadow-inner\" id=\"score-display\">\n                Puan: 0\n            </div>\n        </div>\n    </nav>\n\n    <!-- Main Content Area -->\n    <main class=\"flex-grow container mx-auto p-4 flex items-center justify-center\">\n        \n        <!-- MENU SCREEN -->\n        <div id=\"menu-screen\" class=\"w-full max-w-5xl grid grid-cols-1 md:grid-cols-3 gap-8\">\n            <div class=\"col-span-1 md:col-span-3 text-center mb-8\">\n                <h2 class=\"text-3xl md:text-5xl font-extrabold text-teal-800 mb-4\">Genç Bir Kalbin Yolculuğu</h2>\n                <p class=\"text-gray-600 text-lg md:text-xl\">Lütfen başlamak için bir etkinlik seçin:</p>\n            </div>\n\n            <!-- Game Mode 1: Quiz -->\n            <div onclick=\"startGame('quiz')\" class=\"bg-white p-8 rounded-3xl shadow-lg cursor-pointer card-hover border-b-8 border-teal-500 group transition-all\">\n                <div class=\"text-teal-500 text-5xl md:text-7xl mb-6 group-hover:scale-110 transition-transform text-center\">\n                    <i class=\"fas fa-question-circle\"></i>\n                </div>\n                <h3 class=\"text-2xl md:text-3xl font-bold text-center mb-3 text-gray-800\">Liderlik Yolculuğu</h3>\n                <p class=\"text-gray-500 text-center text-base md:text-lg\">Hz. Peygamber ve genç sahabeler hakkında senaryo tabanlı sorular.</p>\n            </div>\n\n            <!-- Game Mode 2: Matching -->\n            <div onclick=\"startGame('match')\" class=\"bg-white p-8 rounded-3xl shadow-lg cursor-pointer card-hover border-b-8 border-orange-500 group transition-all\">\n                <div class=\"text-orange-500 text-5xl md:text-7xl mb-6 group-hover:scale-110 transition-transform text-center\">\n                    <i class=\"fas fa-puzzle-piece\"></i>\n                </div>\n                <h3 class=\"text-2xl md:text-3xl font-bold text-center mb-3 text-gray-800\">Kavram Eşleştirme</h3>\n                <p class=\"text-gray-500 text-center text-base md:text-lg\">İstişare, Tebliğ, Cihat ve Şehadet kavramlarını tanımlarıyla eşleştir.</p>\n            </div>\n\n            <!-- Game Mode 3: Who Am I -->\n            <div onclick=\"startGame('who')\" class=\"bg-white p-8 rounded-3xl shadow-lg cursor-pointer card-hover border-b-8 border-indigo-500 group transition-all\">\n                <div class=\"text-indigo-500 text-5xl md:text-7xl mb-6 group-hover:scale-110 transition-transform text-center\">\n                    <i class=\"fas fa-user-friends\"></i>\n                </div>\n                <h3 class=\"text-2xl md:text-3xl font-bold text-center mb-3 text-gray-800\">Ben Kimim?</h3>\n                <p class=\"text-gray-500 text-center text-base md:text-lg\">İpuçlarından yola çıkarak anlatılan genç sahabeyi bul.</p>\n            </div>\n        </div>\n\n        <!-- QUIZ SCREEN -->\n        <div id=\"quiz-screen\" class=\"hidden w-full max-w-3xl bg-white p-8 md:p-12 rounded-3xl shadow-2xl relative overflow-hidden\">\n            <div class=\"mb-8\">\n                <div class=\"flex justify-between items-center mb-4\">\n                    <span class=\"text-sm md:text-base font-bold text-teal-600 uppercase tracking-wider bg-teal-50 px-3 py-1 rounded-lg\">Soru <span id=\"q-current\">1</span>/<span id=\"q-total\">10</span></span>\n                    <button onclick=\"showMenu()\" class=\"text-gray-400 hover:text-red-500 text-lg transition-colors\"><i class=\"fas fa-times\"></i> Çıkış</button>\n                </div>\n                <div class=\"w-full bg-gray-200 rounded-full h-3 md:h-4\">\n                    <div id=\"progress-bar\" class=\"bg-teal-600 h-3 md:h-4 rounded-full transition-all duration-500\" style=\"width: 0%\"></div>\n                </div>\n            </div>\n\n            <h2 id=\"question-text\" class=\"text-xl md:text-3xl font-bold text-gray-800 mb-8 leading-relaxed\">\n                Soru yükleniyor...\n            </h2>\n\n            <div id=\"options-container\" class=\"space-y-4\">\n                <!-- Options will be injected here -->\n            </div>\n\n            <div id=\"feedback-area\" class=\"hidden mt-8 p-6 rounded-xl bg-blue-50 border-2 border-blue-200\">\n                <p id=\"feedback-text\" class=\"text-blue-900 font-semibold text-lg md:text-xl\"></p>\n                <button onclick=\"nextQuestion()\" class=\"mt-4 bg-teal-600 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-teal-700 transition shadow-md w-full md:w-auto\">Devam Et <i class=\"fas fa-arrow-right ml-2\"></i></button>\n            </div>\n        </div>\n\n        <!-- MATCHING SCREEN -->\n        <div id=\"match-screen\" class=\"hidden w-full max-w-6xl bg-white p-8 md:p-10 rounded-3xl shadow-2xl\">\n            <div class=\"flex justify-between items-center mb-8\">\n                <div>\n                    <h2 class=\"text-3xl md:text-4xl font-bold text-gray-800 mb-2\">Kavramları Eşleştir</h2>\n                    <p class=\"text-gray-600 text-lg\">Soldaki kavramı seç, sonra sağdaki doğru tanımıyla eşleştir.</p>\n                </div>\n                <button onclick=\"showMenu()\" class=\"text-gray-400 hover:text-red-500 text-xl p-2\"><i class=\"fas fa-times\"></i></button>\n            </div>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12\">\n                <div id=\"terms-container\" class=\"space-y-4 md:space-y-6\"></div>\n                <div id=\"defs-container\" class=\"space-y-4 md:space-y-6\"></div>\n            </div>\n            <div id=\"match-feedback\" class=\"mt-8 text-center font-bold h-8 text-xl text-teal-600\"></div>\n        </div>\n\n        <!-- RESULT SCREEN -->\n        <div id=\"result-screen\" class=\"hidden w-full max-w-2xl bg-white p-12 rounded-3xl shadow-2xl text-center\">\n            <div class=\"mb-6 text-7xl md:text-9xl text-yellow-400 drop-shadow-lg\">\n                <i class=\"fas fa-trophy\"></i>\n            </div>\n            <h2 class=\"text-4xl md:text-5xl font-extrabold text-gray-800 mb-4\">Tebrikler!</h2>\n            <p class=\"text-xl md:text-2xl text-gray-600 mb-8\">Liderlik ve sadakat döngüsünü tamamladın.</p>\n            \n            <div class=\"text-5xl md:text-7xl font-bold text-teal-600 mb-10\" id=\"final-score\">0 Puan</div>\n            \n            <p id=\"result-message\" class=\"text-lg md:text-xl text-gray-500 mb-10 italic bg-gray-50 p-4 rounded-xl\">\n                \"Gençler, kendi potansiyellerine ulaşarak birer lidere dönüşür.\"\n            </p>\n\n            <button onclick=\"showMenu()\" class=\"w-full bg-teal-600 text-white py-4 rounded-2xl font-bold text-xl hover:bg-teal-700 transition shadow-lg hover:shadow-xl transform hover:-translate-y-1\">\n                Ana Menüye Dön\n            </button>\n        </div>\n\n    </main>\n\n    <footer class=\"text-center p-6 text-gray-500 text-sm md:text-base font-medium\">\n        &copy; 2024 Rehberin İzinde İnteraktif Öğrenme Platformu\n    </footer>\n\n    <script>\n        // --- DATA SOURCE ---\n        const quizData = [\n            {\n                question: \"Hz. Peygamber, Ebu Mahzure ezanla alay ettiğinde ona nasıl bir tepki vermiştir?\",\n                options: [\n                    \"Onu cezalandırmış ve şehirden uzaklaştırmıştır.\",\n                    \"Ona kızmış ama affetmiştir.\",\n                    \"Sesini fark edip şefkatle ona ezanı öğretmiştir.\",\n                    \"Onu görmezden gelmiştir.\"\n                ],\n                correct: 2,\n                feedback: \"Doğru! Peygamberimiz ceza yerine potansiyeli görmüş, Ebu Mahzure'ye şefkatle yaklaşarak onu kazanmıştır.\"\n            },\n            {\n                question: \"Al-i İmran suresi 159. ayette Hz. Peygamber'in hangi özelliği vurgulanır?\",\n                options: [\n                    \"Çok ibadet etmesi\",\n                    \"Yumuşak huylu ve merhametli olması\",\n                    \"Savaş stratejilerini iyi bilmesi\",\n                    \"Zengin olması\"\n                ],\n                correct: 1,\n                feedback: \"Ayette 'Sen onlara Allah'ın merhameti sayesinde yumuşak davrandın' buyurulmaktadır.\"\n            },\n            {\n                question: \"Mus'ab bin Umeyr'in lakabı nedir ve Medine'deki görevi neydi?\",\n                options: [\n                    \"Allah'ın Aslanı - Komutan\",\n                    \"İslam'ın İlk Öğretmeni - İslam'ı anlatmak\",\n                    \"Seyfullah - Savaşmak\",\n                    \"Tercüman - Kralla konuşmak\"\n                ],\n                correct: 1,\n                feedback: \"Mus'ab bin Umeyr, konforlu hayatını bırakıp Medine'ye 'İlk Öğretmen' olarak gönderilmiştir.\"\n            },\n            {\n                question: \"Hz. Peygamber ordu komutanı olarak atadığında Üsame bin Zeyd kaç yaşındaydı ve bu neyi gösterir?\",\n                options: [\n                    \"40 yaşındaydı - Tecrübeyi\",\n                    \"25 yaşındaydı - Gücü\",\n                    \"18 yaşındaydı - Liyakat ve yeteneğe verilen önemi\",\n                    \"30 yaşındaydı - Sadakati\"\n                ],\n                correct: 2,\n                feedback: \"Henüz 18 yaşında olmasına rağmen liyakati sebebiyle ordu komutanı olmuştur.\"\n            },\n            {\n                question: \"Habeşistan Kralı Necaşi'nin huzurunda Müslümanları savunan genç sahabi kimdir?\",\n                options: [\n                    \"Hz. Ali\",\n                    \"Mus'ab bin Umeyr\",\n                    \"Cafer bin Ebu Talib\",\n                    \"Zeyd bin Harise\"\n                ],\n                correct: 2,\n                feedback: \"Cafer bin Ebu Talib, Necaşi'ye İslam'ın getirdiği ahlaki güzellikleri anlatan etkileyici bir konuşma yapmıştır.\"\n            },\n            {\n                question: \"Uhud Savaşı'nda Hz. Peygamber'e siper olan ve O'nu korumak için cesurca savaşan kadın sahabi kimdir?\",\n                options: [\n                    \"Hz. Aişe\",\n                    \"Hz. Hatice\",\n                    \"Nesîbe binti Ka'b\",\n                    \"Hz. Fatıma\"\n                ],\n                correct: 2,\n                feedback: \"Nesîbe (ra), Uhud'un en zor anlarında Peygamberimizi koruyan kahramanlardandır.\"\n            },\n            {\n                question: \"'Görüş alışverişinde bulunma, fikir alma ve danışma' anlamına gelen kavram hangisidir?\",\n                options: [\n                    \"Tebliğ\",\n                    \"İstişare\",\n                    \"Cihat\",\n                    \"Tevekkül\"\n                ],\n                correct: 1,\n                feedback: \"Hz. Peygamber ashabıyla sık sık istişare ederdi (Örn: Bedir ve Hudeybiye).\"\n            },\n            {\n                question: \"Kab bin Malik (ra) Tebük Seferi'ne mazeretsiz katılmadığında hatasını nasıl telafi etti?\",\n                options: [\n                    \"Yalan söyleyerek\",\n                    \"Şehri terk ederek\",\n                    \"Dürüstçe hatasını kabul edip tövbe ederek\",\n                    \"Öfkelenerek\"\n                ],\n                correct: 2,\n                feedback: \"Kab bin Malik dürüstlüğü seçti ve bu samimiyeti sayesinde tövbesi kabul edildi.\"\n            }\n        ];\n\n        const whoAmIData = [\n            {\n                question: \"Mekke'nin en zengin ailelerinden birinin çocuğuydum. Her şeyi bıraktım. Medine'ye İslam'ı öğretmek için gittim.\",\n                options: [\"Üsame bin Zeyd\", \"Mus'ab bin Umeyr\", \"Cafer bin Ebu Talib\"],\n                correct: 1,\n                feedback: \"Doğru! Ben Mus'ab bin Umeyr'im.\"\n            },\n            {\n                question: \"On sene Peygamberimize hizmet ettim. Bana bir kere bile 'Öf' demedi. Yaptığım bir şey için 'Niye yaptın?' diye azarlamadı.\",\n                options: [\"Enes bin Malik\", \"Ebu Hüreyre\", \"Abdullah bin Mesud\"],\n                correct: 0,\n                feedback: \"Doğru! Ben Enes bin Malik'im.\"\n            },\n            {\n                question: \"Peygamberimiz beni her gördüğünde gülümserdi, beni hiç kapıdan çevirmedi.\",\n                options: [\"Cerir bin Abdullah\", \"Hz. Ali\", \"Hz. Ömer\"],\n                correct: 0,\n                feedback: \"Doğru! Ben Cerir bin Abdullah'ım.\"\n            },\n            {\n                question: \"Bir tartışmada Bilal'e ten rengiyle hakaret ettim. Peygamberimiz 'Sende cahiliye izi var' deyince çok pişman olup özür diledim.\",\n                options: [\"Ebu Leheb\", \"Ebu Zer\", \"Ebu Cehil\"],\n                correct: 1,\n                feedback: \"Doğru! Ben Ebu Zer'im.\"\n            }\n        ];\n\n        const matchData = {\n            terms: [\n                { id: 't1', text: 'İstişare' },\n                { id: 't2', text: 'Tebliğ' },\n                { id: 't3', text: 'Cihat' },\n                { id: 't4', text: 'Şehadet' }\n            ],\n            defs: [\n                { id: 'd1', text: 'Fikir alışverişinde bulunma, danışma.', match: 't1' },\n                { id: 'd2', text: 'Vahyi insanlara eksiksiz bildirme.', match: 't2' },\n                { id: 'd3', text: 'Allah yolunda her türlü gayret ve mücadele.', match: 't3' },\n                { id: 'd4', text: 'Allah\\'ın birliğine tanıklık etmek ve bu uğurda canı feda etmek.', match: 't4' }\n            ]\n        };\n\n        // --- STATE VARIABLES ---\n        let currentMode = '';\n        let currentIndex = 0;\n        let score = 0;\n        let currentQuestions = [];\n        let selectedTerm = null;\n        let matchedPairs = 0;\n\n        // --- DOM ELEMENTS ---\n        const menuScreen = document.getElementById('menu-screen');\n        const quizScreen = document.getElementById('quiz-screen');\n        const matchScreen = document.getElementById('match-screen');\n        const resultScreen = document.getElementById('result-screen');\n        const scoreDisplay = document.getElementById('score-display');\n\n        // --- CORE FUNCTIONS ---\n\n        function showMenu() {\n            menuScreen.classList.remove('hidden');\n            quizScreen.classList.add('hidden');\n            matchScreen.classList.add('hidden');\n            resultScreen.classList.add('hidden');\n            score = 0;\n            updateScore();\n        }\n\n        function updateScore() {\n            scoreDisplay.innerText = `Puan: ${score}`;\n        }\n\n        function startGame(mode) {\n            currentMode = mode;\n            score = 0;\n            currentIndex = 0;\n            updateScore();\n\n            menuScreen.classList.add('hidden');\n            resultScreen.classList.add('hidden');\n\n            if (mode === 'quiz') {\n                currentQuestions = [...quizData]; // Clone array\n                setupQuiz();\n            } else if (mode === 'who') {\n                currentQuestions = [...whoAmIData];\n                setupQuiz();\n            } else if (mode === 'match') {\n                setupMatch();\n            }\n        }\n\n        // --- QUIZ LOGIC (Used for 'Quiz' and 'Who Am I') ---\n\n        function setupQuiz() {\n            quizScreen.classList.remove('hidden');\n            document.getElementById('q-total').innerText = currentQuestions.length;\n            renderQuestion();\n        }\n\n        function renderQuestion() {\n            const q = currentQuestions[currentIndex];\n            document.getElementById('q-current').innerText = currentIndex + 1;\n            document.getElementById('progress-bar').style.width = `${((currentIndex) / currentQuestions.length) * 100}%`;\n            \n            document.getElementById('question-text').innerText = q.question;\n            const optsContainer = document.getElementById('options-container');\n            optsContainer.innerHTML = '';\n            document.getElementById('feedback-area').classList.add('hidden');\n\n            q.options.forEach((opt, idx) => {\n                const btn = document.createElement('button');\n                btn.className = \"w-full text-left p-4 md:p-6 rounded-xl border-2 border-gray-100 hover:border-teal-500 hover:bg-teal-50 transition-all font-semibold text-gray-700 text-base md:text-lg\";\n                btn.innerText = opt;\n                btn.onclick = () => checkAnswer(idx, btn);\n                optsContainer.appendChild(btn);\n            });\n        }\n\n        function checkAnswer(selectedIdx, btnElement) {\n            const q = currentQuestions[currentIndex];\n            const optsContainer = document.getElementById('options-container');\n            \n            // Disable all buttons\n            Array.from(optsContainer.children).forEach(b => b.disabled = true);\n\n            if (selectedIdx === q.correct) {\n                btnElement.classList.remove('border-gray-100');\n                btnElement.classList.add('bg-green-100', 'border-green-500', 'text-green-800', 'correct-anim');\n                btnElement.innerHTML += ' <i class=\"fas fa-check-circle float-right mt-1\"></i>';\n                score += 10;\n                updateScore();\n            } else {\n                btnElement.classList.remove('border-gray-100');\n                btnElement.classList.add('bg-red-100', 'border-red-500', 'text-red-800', 'wrong-anim');\n                btnElement.innerHTML += ' <i class=\"fas fa-times-circle float-right mt-1\"></i>';\n                \n                // Highlight correct answer\n                const correctBtn = optsContainer.children[q.correct];\n                correctBtn.classList.add('bg-green-100', 'border-green-500', 'text-green-800');\n                correctBtn.innerHTML += ' <i class=\"fas fa-check-circle float-right mt-1\"></i>';\n            }\n\n            // Show feedback\n            document.getElementById('feedback-text').innerText = q.feedback;\n            document.getElementById('feedback-area').classList.remove('hidden');\n        }\n\n        function nextQuestion() {\n            currentIndex++;\n            if (currentIndex < currentQuestions.length) {\n                renderQuestion();\n            } else {\n                endGame();\n            }\n        }\n\n        // --- MATCHING GAME LOGIC ---\n\n        function setupMatch() {\n            matchScreen.classList.remove('hidden');\n            const tContainer = document.getElementById('terms-container');\n            const dContainer = document.getElementById('defs-container');\n            tContainer.innerHTML = '';\n            dContainer.innerHTML = '';\n            matchedPairs = 0;\n            selectedTerm = null;\n            document.getElementById('match-feedback').innerText = '';\n\n            // Randomize definitions\n            const shuffledDefs = [...matchData.defs].sort(() => Math.random() - 0.5);\n\n            matchData.terms.forEach(term => {\n                const div = document.createElement('div');\n                div.id = term.id;\n                div.className = \"p-6 md:p-8 bg-teal-100 rounded-2xl cursor-pointer border-2 border-transparent hover:border-teal-400 font-bold text-xl md:text-2xl text-center shadow-sm transition-all hover:shadow-md flex items-center justify-center min-h-[100px] md:min-h-[120px]\";\n                div.innerText = term.text;\n                div.onclick = () => selectTerm(div);\n                tContainer.appendChild(div);\n            });\n\n            shuffledDefs.forEach(def => {\n                const div = document.createElement('div');\n                div.id = def.id;\n                div.dataset.match = def.match; // Store which term it matches\n                div.className = \"p-6 md:p-8 bg-gray-100 rounded-2xl cursor-pointer border-2 border-transparent hover:border-orange-400 text-lg md:text-xl font-medium flex items-center justify-center text-center shadow-sm transition-all hover:shadow-md min-h-[100px] md:min-h-[120px]\";\n                div.innerText = def.text;\n                div.onclick = () => selectDef(div);\n                dContainer.appendChild(div);\n            });\n        }\n\n        function selectTerm(el) {\n            if (el.classList.contains('opacity-50')) return; // Already matched\n            \n            // Deselect previous\n            if (selectedTerm) selectedTerm.classList.remove('bg-teal-500', 'text-white');\n            \n            selectedTerm = el;\n            selectedTerm.classList.add('bg-teal-500', 'text-white');\n            document.getElementById('match-feedback').innerText = \"Tanımı seçiniz...\";\n        }\n\n        function selectDef(el) {\n            if (!selectedTerm) {\n                document.getElementById('match-feedback').innerText = \"Önce sol taraftan bir kavram seçmelisin.\";\n                return;\n            }\n            if (el.classList.contains('opacity-50')) return;\n\n            if (el.dataset.match === selectedTerm.id) {\n                // Correct Match\n                score += 20;\n                updateScore();\n                \n                selectedTerm.classList.remove('bg-teal-500', 'text-white');\n                selectedTerm.classList.add('bg-green-500', 'text-white', 'opacity-50', 'correct-anim');\n                el.classList.add('bg-green-100', 'border-green-500', 'opacity-50', 'correct-anim');\n                \n                selectedTerm = null;\n                matchedPairs++;\n                document.getElementById('match-feedback').innerText = \"Harika! Doğru eşleştirme.\";\n\n                if (matchedPairs === matchData.terms.length) {\n                    setTimeout(endGame, 1000);\n                }\n            } else {\n                // Wrong Match\n                el.classList.add('bg-red-100', 'wrong-anim');\n                setTimeout(() => el.classList.remove('bg-red-100', 'wrong-anim'), 500);\n                document.getElementById('match-feedback').innerText = \"Yanlış eşleştirme, tekrar dene.\";\n            }\n        }\n\n        // --- END GAME ---\n\n        function endGame() {\n            quizScreen.classList.add('hidden');\n            matchScreen.classList.add('hidden');\n            resultScreen.classList.remove('hidden');\n            \n            document.getElementById('final-score').innerText = score + \" Puan\";\n            \n            if (score > 50) {\n                celebrate();\n                document.getElementById('result-message').innerText = \"Mükemmel! Rehberin izini başarıyla takip ettin.\";\n            } else {\n                document.getElementById('result-message').innerText = \"Güzel deneme! Bilgilerini tazeleyip tekrar deneyebilirsin.\";\n            }\n        }\n\n        function celebrate() {\n            for(let i=0; i<50; i++) {\n                const confetti = document.createElement('div');\n                confetti.className = 'confetti';\n                confetti.style.left = Math.random() * 100 + 'vw';\n                confetti.style.animationDuration = Math.random() * 2 + 3 + 's';\n                confetti.style.backgroundColor = ['#ff0', '#f00', '#0f0', '#00f'][Math.floor(Math.random()*4)];\n                document.body.appendChild(confetti);\n                setTimeout(() => confetti.remove(), 5000);\n            }\n        }\n\n    </script>\n</body>\n</html>"
  }
]