  {
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Peygamberlerin Özellikleri ve Görevleri (Responsive)</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@300;400;700&display=swap');\n\n        /* --- GENEL AYARLAR --- */\n        body {\n            margin: 0;\n            padding: 0;\n            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);\n            font-family: 'Roboto', sans-serif;\n            color: #fff;\n            box-sizing: border-box;\n        }\n\n        /* --- MASAÜSTÜ VARSAYILAN (Sabit & Ölçeklenebilir) --- */\n        #main-wrapper {\n            width: 100vw;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden; /* Masaüstünde scroll yok, sığdırma var */\n        }\n\n        .poster-container {\n            /* Sabit Orijinal Boyutlar */\n            width: 1500px;\n            height: 850px;\n            flex-shrink: 0;\n\n            background: rgba(255, 255, 255, 0.05);\n            border: 4px solid #fbbf24;\n            border-radius: 30px;\n            box-shadow: 0 40px 80px rgba(0,0,0,0.7);\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n\n            /* Animasyonlu geçiş */\n            transform-origin: center center;\n            transition: transform 0.2s ease-out;\n        }\n\n        /* Başlık Alanı */\n        .main-header {\n            text-align: center;\n            padding: 30px;\n            border-bottom: 3px solid rgba(251, 191, 36, 0.3);\n            background: rgba(0,0,0,0.2);\n            z-index: 2;\n        }\n        .main-header h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            margin: 0;\n            color: #fff;\n            text-shadow: 0 4px 10px rgba(0,0,0,0.5);\n        }\n        .main-header span { color: #fbbf24; }\n\n        /* İçerik Alanı */\n        .content-wrapper {\n            display: flex;\n            flex: 1;\n            position: relative;\n        }\n\n        /* ORTAK SÜTUN STİLLERİ */\n        .column {\n            flex: 1;\n            padding: 40px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .col-left {\n            border-right: 2px dashed rgba(255, 255, 255, 0.2);\n            background: linear-gradient(180deg, rgba(251, 191, 36, 0.05) 0%, transparent 100%);\n        }\n        \n        .col-right {\n            background: linear-gradient(180deg, rgba(147, 197, 253, 0.05) 0%, transparent 100%);\n        }\n\n        /* Bölüm Başlıkları */\n        .section-title {\n            font-family: 'Playfair Display', serif;\n            font-size: 2.5rem;\n            margin-bottom: 30px;\n            text-align: center;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 15px;\n        }\n        .title-gold { color: #fbbf24; }\n        .title-blue { color: #93c5fd; }\n\n        /* --- TABLO/IZGARA YAPISI --- */\n        .grid-container {\n            display: grid;\n            gap: 20px;\n            height: 100%;\n        }\n        \n        /* Sol Taraf: 2x2 Izgara */\n        .grid-2x2 {\n            grid-template-columns: 1fr 1fr;\n            grid-template-rows: 1fr 1fr;\n        }\n\n        /* Sağ Taraf: 2 Sütunlu Liste */\n        .grid-list {\n            grid-template-columns: 1fr 1fr;\n            grid-auto-rows: min-content;\n        }\n\n        /* KART TASARIMI */\n        .card {\n            background: rgba(15, 23, 42, 0.6);\n            border-radius: 15px;\n            padding: 25px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            transition: transform 0.3s;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.2);\n            position: relative;\n            overflow: hidden;\n        }\n        /* Mobilde hover efekti takılma yapmasın diye sadece masaüstünde kalsın diyebiliriz ama basit tutalım */\n        \n        .card-trait { border-left: 5px solid #fbbf24; }\n        .card-trait h3 { color: #fbbf24; font-size: 1.8rem; margin: 0 0 10px 0; font-family: 'Playfair Display', serif;}\n        \n        .card-duty { border-left: 5px solid #93c5fd; }\n        .card-duty h3 { color: #93c5fd; font-size: 1.6rem; margin: 0 0 10px 0; font-family: 'Playfair Display', serif;}\n\n        .card p {\n            font-size: 1.1rem;\n            line-height: 1.5;\n            color: #e2e8f0;\n            margin: 0;\n        }\n\n        /* Dekoratif Arka Plan */\n        .decoration {\n            position: absolute;\n            font-size: 300px;\n            opacity: 0.05;\n            z-index: 0;\n            pointer-events: none;\n        }\n        .dec-left { bottom: -50px; left: -50px; color: #fbbf24; }\n        .dec-right { top: -50px; right: -50px; color: #93c5fd; }\n\n\n        /* -----------------------------------------------------------\n           MOBİL MODU (Media Query)\n           Ekran 1024px'den darsa (Tablet Dik & Telefon) bu kurallar çalışır.\n        ----------------------------------------------------------- */\n        @media screen and (max-width: 1024px) {\n            #main-wrapper {\n                height: auto;\n                display: block;\n                overflow-y: auto;\n                padding: 10px;\n            }\n\n            .poster-container {\n                width: 100%;\n                height: auto;\n                transform: none !important; /* JS ölçeklemesini iptal et */\n                margin-top: 0;\n                border-width: 2px;\n                box-shadow: none;\n            }\n\n            .main-header {\n                padding: 20px 10px;\n            }\n            .main-header h1 {\n                font-size: 2rem; /* Başlığı küçült */\n                line-height: 1.2;\n            }\n            .main-header span {\n                display: block; /* \"Özellikleri ve Görevleri\" alt satıra geçsin */\n                margin-top: 5px;\n            }\n\n            .content-wrapper {\n                flex-direction: column; /* Yan yana değil alt alta */\n            }\n\n            .column {\n                padding: 20px;\n                width: 100%;\n                box-sizing: border-box;\n            }\n\n            .col-left {\n                border-right: none;\n                border-bottom: 2px dashed rgba(255, 255, 255, 0.2);\n            }\n\n            .section-title {\n                font-size: 1.8rem;\n                margin-bottom: 20px;\n            }\n\n            /* Gridleri Tek Sütuna Düşür */\n            .grid-container {\n                display: flex;\n                flex-direction: column;\n                gap: 15px;\n            }\n\n            .card {\n                padding: 20px;\n                min-height: auto; /* Yükseklik serbest */\n            }\n\n            .card h3 { font-size: 1.4rem; }\n            .card p { font-size: 1rem; }\n\n            /* Süslemeleri gizle */\n            .decoration { display: none; }\n        }\n\n    </style>\n</head>\n<body>\n\n    <div id=\"main-wrapper\">\n        <div class=\"poster-container\" id=\"poster\">\n            <!-- Ana Başlık -->\n            <div class=\"main-header\">\n                <h1>PEYGAMBERLERİN <span>ÖZELLİKLERİ</span> VE <span>GÖREVLERİ</span></h1>\n            </div>\n\n            <div class=\"content-wrapper\">\n                <!-- Dekoratif Arkaplan -->\n                <div class=\"decoration dec-left\">★</div>\n                <div class=\"decoration dec-right\">✦</div>\n\n                <!-- SOL SÜTUN: ÖZELLİKLER (SIFATLAR) -->\n                <div class=\"column col-left\">\n                    <h2 class=\"section-title title-gold\">\n                        <span>✨</span> ÖZELLİKLERİ\n                    </h2>\n                    \n                    <div class=\"grid-container grid-2x2\">\n                        <!-- Sıdk -->\n                        <div class=\"card card-trait\">\n                            <h3>SIDK</h3>\n                            <p>Dürüst ve doğru sözlü olmaktır. Asla yalan söylemezler.</p>\n                        </div>\n                        <!-- Emanet -->\n                        <div class=\"card card-trait\">\n                            <h3>EMANET</h3>\n                            <p>Güvenilir olmaktır. Her konuda emniyet duyulan kişilerdir.</p>\n                        </div>\n                        <!-- İsmet -->\n                        <div class=\"card card-trait\">\n                            <h3>İSMET</h3>\n                            <p>Allah (cc) tarafından her türlü günahtan korunmuş olmaktır.</p>\n                        </div>\n                        <!-- Fetanet -->\n                        <div class=\"card card-trait\">\n                            <h3>FETANET</h3>\n                            <p>Akıllı, zeki ve uyanık olmaktır. Yüksek kavrayış gücüne sahiptirler.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- SAĞ SÜTUN: GÖREVLER -->\n                <div class=\"column col-right\">\n                    <h2 class=\"section-title title-blue\">\n                        <span>📜</span> GÖREVLERİ\n                    </h2>\n\n                    <div class=\"grid-container grid-list\">\n                        <!-- Tebliğ -->\n                        <div class=\"card card-duty\">\n                            <h3>TEBLİĞ</h3>\n                            <p>Vahyi eksiklik ve fazlalık olmadan insanlara bildirmek.</p>\n                        </div>\n                        <!-- Tebyin -->\n                        <div class=\"card card-duty\">\n                            <h3>TEBYİN</h3>\n                            <p>Allah’ın (cc) emir ve yasaklarını insanlara açıklamak.</p>\n                        </div>\n                        <!-- Temsil -->\n                        <div class=\"card card-duty\">\n                            <h3>TEMSİL</h3>\n                            <p>İslam’ı anlama ve yaşama konusunda insanlara örneklik etmek.</p>\n                        </div>\n                        <!-- İnzar -->\n                        <div class=\"card card-duty\">\n                            <h3>İNZAR</h3>\n                            <p>Allah’ın (cc) emirlerine uymayanları uyarmak.</p>\n                        </div>\n                        <!-- Tebşir -->\n                        <div class=\"card card-duty\">\n                            <h3>TEBŞİR</h3>\n                            <p>Allah’ın (cc) emirlerine uyanları müjdelemek.</p>\n                        </div>\n                        <!-- Tezkiye -->\n                        <div class=\"card card-duty\">\n                            <h3>TEZKİYE</h3>\n                            <p>İnsanların kötü huylardan uzaklaşmalarını sağlamak.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- MASAÜSTÜ İÇİN ÖLÇEKLEME SCRİPTİ -->\n    <script>\n        function fitPoster() {\n            // Sadece masaüstü modunda çalış (Genişlik > 1024px)\n            if (window.innerWidth > 1024) {\n                const poster = document.getElementById('poster');\n                const winWidth = window.innerWidth;\n                const winHeight = window.innerHeight;\n                \n                // Orijinal boyutlar (Kenar payları dahil)\n                const targetWidth = 1540; \n                const targetHeight = 890;\n\n                // Ölçek oranını hesapla\n                const scale = Math.min(winWidth / targetWidth, winHeight / targetHeight);\n                \n                // Uygula\n                poster.style.transform = `scale(${scale})`;\n            } else {\n                // Mobildeysek ölçeklemeyi temizle\n                document.getElementById('poster').style.transform = 'none';\n            }\n        }\n\n        // Yüklenince ve yeniden boyutlandırılınca çalıştır\n        window.addEventListener('load', fitPoster);\n        window.addEventListener('resize', fitPoster);\n    </script>\n\n</body>\n</html>",
