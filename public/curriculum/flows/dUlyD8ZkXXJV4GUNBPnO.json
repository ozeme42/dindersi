  {
    "type": "content",
    "content": "<ul><li>Fetanet</li><li>İnzar</li><li>Nübüvvet</li><li>Emanet</li><li>Tezkiye</li><li>Resul</li><li>Mucize</li><li>Nebi</li><li>Tebliğ</li><li>İsmet</li><li>Peygamber</li><li>Vahiy</li><li>Risalet</li><li>Tebşir</li><li>Tebyin</li><li>Sıdk</li><li>Temsil</li><li>Tevhid</li></ul>",
