    "topicId": "E2aSkPn1Md3Hzk5HN0Pw",
    "courseId": "r5TWTCIlp018sP37lPL3",
    "content": {
      "definition": "İsrailoğulları’ndandır, kendisine İncil gönderilmiştir. Annesi Hz. Meryem’dir. Mucize olarak babasız dünyaya gelişi Meryem suresinde anlatılmıştır.",
      "term": "Hz.İsa"
    },
    "createdAt": "2025-09-21T11:18:31.162Z"
  },
