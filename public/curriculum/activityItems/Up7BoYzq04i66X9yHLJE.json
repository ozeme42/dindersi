[{"id":"0zjMb7ZKsu9DtE2tZ3bt","type":"definition","content":{"term":"Taharet","definition":"Dinen pis kabul edilen şeyleri su veya temizleyici başka şeylerle temizleme."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:03:21.330Z"},{"id":"1egXWTmBurdYqb6Dn4pg","type":"concept","content":{"text":"Maddi Temizlik"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:01:59.889Z"},{"id":"26wQDzljkSa09jdR84zs","type":"concept","content":{"text":"Manevi Temizlik"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:01:59.889Z"},{"id":"4t73WL4i0XMsHeSANTg8","type":"sentence","content":{"text":"Elbise temizliği, namaz gibi ibadetler için bir ön şarttır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:01:59.889Z"},{"id":"5RC8GtKPeimb4dV0DJOA","type":"sentence","content":{"text":"Ağız ve diş temizliği, beden temizliği, elbise temizliği ve çevre temizliği önemlidir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:03:21.330Z"},{"id":"6g27oR2yr8wzwB3PSM1a","type":"sentence","content":{"text":"Temizlik, hem fiziksel hem de ruhsal sağlığımız için önemlidir ve İslam'da imanın yarısı olarak kabul edilir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:01:59.889Z"},{"id":"7LIkPFYuJrIi78QVCfOZ","type":"sentence","content":{"text":"Peygamberimiz, temizliğe büyük önem vermiş ve bunu hem sözleriyle hem de uygulamalarıyla göstermiştir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"Up7BoYzq04i66X9yHLJE","createdAt":"2025-07-09T04:01:59.889Z"},{"id":"80gX8pD7ZTU6kdCdKqJ3","type":"definition","content":