[{"id":"08ZR1Lr9GUkLFpJupbDR","type":"sentence","content":{"text":"Su kabına üflememek, kabın ağzını kapalı tutmak ve ikram edilen yiyeceği kontrol etmek temizliğe verilen önemi gösterir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"8btCxzEBU12CD7xrX74i","type":"sentence","content":{"text":"Peygamber Efendimiz ayakta yemek yemeyi uygun görmemiştir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"9MYPkiXriweR3aznKSSK","type":"sentence","content":{"text":"İslam'da helal ve temiz olan yiyeceklerin tüketilmesi önemlidir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"9vC8DA7cqG8gsqafNO4k","type":"sentence","content":{"text":"Yemeklerden önce ve sonra ellerin yıkanması, besmele çekmek ve şükretmek önemlidir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"Abm0G4TUgfA8hrG1SOjp","type":"concept","content":{"text":"Sofra Adabı"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"BYJij0yqO4WXSdh4Yyd6","type":"concept","content":{"text":"Helal"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"BqFxSWToxZOUDuj01Fnj","type":"concept","content":{"text":"İsraf"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"CrfJpJ7BSRD6knXFbxC0","type":"sentence","content":{"text":"Peygamberimiz yeme içme konusunda önemli ilkeler belirlemiştir ve Müslümanlar bu konuda O'nu örnek alırlar."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"ENloYsDlTMJiQc8pRxD4","type":"definition","content":{"term":"İsraf","definition":"Sahip olunan nimetlerin gereksiz yere harcanmasına ne denir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"KEjZS7TPdrmzULk1x9h3","type":"concept","content":{"text":"Tevazu"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"Lfebp7jVXT6hrAyVnHFe","type":"definition","content":{"term":"Rızık","definition":"Allah'ın verdiği yiyecek, içecek ve diğer tüm nimetler için kullanılan kelime nedir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"PFKnrp4CmR5ZE8KfHKwX","type":"sentence","content":{"text":"Peygamberimiz ikram edilen yemeği asla eleştirmemiş, sofra sahibine saygılı davranmıştır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"b1t4tfZzLWLcYsYWfmgP","type":"sentence","content":{"text":"Helal yiyecek, meşru yollarla kazanılmış ve dinen yasaklanmamış olan yiyecektir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"f0PCCcUiPW8MJSRihbJR","type":"definition","content":{"term":"Helal","definition":"Dinen yenilmesine izin verilen yiyecek ve içeceklere ne denir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"hz4lmEhTnplalv6i5zGB","type":"sentence","content":{"text":"Peygamberimiz, yemeğin israf edilmemesini ve tabağın temiz bırakılmasını tavsiye etmiştir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"iO6qYlpT6Wy4eukdTmag","type":"sentence","content":{"text":"Aşırı yemekten kaçınmak ve midenin bir kısmını boş bırakmak sağlıklı beslenmenin bir parçasıdır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"kO0WPqO2rrZ8xLVLnWwF","type":"sentence","content":{"text":"Sağ elle yemek yemek, tabağın kendi önümüzdeki kısmından yemek ve suyu üç yudumda içmek sofra adabındandır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"kkyrqCqi84s7QxGL85Kk","type":"concept","content":{"text":"Besmele"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"lIbtafxpSNuvHHFbKDoW","type":"definition","content":{"term":"Bereket","definition":"Allah'ın verdiği nimetlerin çoğalması ve verimli olması anlamına gelen kelime nedir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"ob9BXMy6cYVdOmw3tCmm","type":"definition","content":{"term":"Sofra Adabı","definition":"Yemek yerken uyulması gereken kurallar nelerdir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"tNDBNvvPubGLkGht13b1","type":"definition","content":{"term":"Tevazu","definition":"Alçakgönüllülük ve gösterişsizlik olarak tanımlanan davranış şekli nedir?"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId":"B9ZrNo6WzlfdvpyRvYun","createdAt":"2025-07-09T04:04:51.120Z"},{"id":"vTtCvUVRzjJFtQXpwJeF","type":"concept","content":{"text":"Bereket"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"KXaDVYOgeUiDEerxQ7jR","topicId"