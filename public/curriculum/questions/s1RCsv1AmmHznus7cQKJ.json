[{"id":"13wiH6EW8NmidQwtdY6J","text":"Yüzündeki gülümseme ve tebessüm ile insanların gönlüne huzur veren peygamber kimdir?","type":"Çoktan Seçmeli","difficulty":"Kolay","options":["Hz. Musa","Hz. İsa","Hz. Muhammed","Hz. Davut"],"correctAnswer":"Hz. Muhammed","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"4GIZZF0yFEFbUGWPLDpJ","text":"Peygamberimizin hadislerinde, küçüklerimize merhamet etmeyen, büyüklerimize ne göstermeyenlerin bizden olmadığı belirtilmiştir?","type":"Çoktan Seçmeli","difficulty":"Kolay","options":["Şefkat","Saygı","İlgi","Destek"],"correctAnswer":"Saygı","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"4ZZY3nNSyBaNKdda4zlC","text":"Selamlaşmak, insanlar arasındaki bağı zayıflatır.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"5PbyMRz8jGrw0FEsCzFk","text":"Hz. Hatice, Peygamberimize destek olurken onun ___ hakkına riayet etmesini, doğru konuşmasını ve fakiri doyurmasını örnek göstermiştir.","type":"Boşluk Doldurma","difficulty":"Orta","options":["komşu","yetim","akraba","misafir"],"correctAnswer":"akraba","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"6Pgc7j3PfassVnWQ1Ih7","text":"Peygamber Efendimiz, insanlarla iletişim kurarken her zaman sevgi ve ___ çerçevesinde hareket etmiştir.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["hoşgörü","saygı","şefkat","merhamet"],"correctAnswer":"saygı","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"8Bh3oR5S5UbUzNFDbJux","text":"Hz. Peygamber, malının üçte ikisini sadaka olarak vermek isteyen Sad bin Ebu Vakkas'a, mirasçılarını ___ bırakmanın daha hayırlı olduğunu belirtmiştir.","type":"Boşluk Doldurma","difficulty":"Zor","options":["mutlu","güvende","zengin","varlıklı"],"correctAnswer":"zengin","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"8le9U69SNlO3GrjcT97F","text":"Hz. Peygamber, akrabalık bağlarını koruyan kişilerin rızkının çoğalacağını ve ömrünün uzayacağını belirtmiştir. Bu durum İslam'da hangi kavramla ifade edilir?","type":"Çoktan Seçmeli","difficulty":"Orta","options":["Vefa","Sılayırahim","Sadakat","İhsan"],"correctAnswer":"Sılayırahim","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"B8Yg9n3gMdeMfre0ZfqE","text":"Kur'an-ı Kerim, Allah'ın adaleti, iyilik yapmayı ve ___ yardım etmeyi emrettiğini, hayâsızlığı, kötülüğü ve zorbalığı ise yasakladığını bildirir.","type":"Boşluk Doldurma","difficulty":"Zor","options":["komşuya","yetime","akrabaya","fakire"],"correctAnswer":"akrabaya","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"BuOjx1S1o6O2FMR9AzFt","text":"Sılayırahim, anne baba başta olmak üzere tüm akrabalar arasında güzel ilişki kurma, onları ziyaret etme ve onlara maddi manevi ___ bulunmadır.","type":"Boşluk Doldurma","difficulty":"Orta","options":["destekte","ikramda","yardımda","bağışta"],"correctAnswer":"yardımda","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"HsLDZUn2085eJ2LF9UyA","text":"Hz. Peygamber, Medine’ye hicret ettikten sonra Mekke’ye asla geri dönmemiş ve Medineli Müslümanlara vefa borcunu ödemiştir.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"I72Dkm5lf3WsEq5WgEVP","text":"Peygamber Efendimiz, emanete riayet etmeyen veya ahde vefa göstermeyenin imanının eksik olduğunu belirtmiştir.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"ImBZxqJKIF2i1MOAjCAp","text":"Hz. Peygamber’in \"O da bir insan değil mi?\" sözü, kim olursa olsun tüm insanlara ___ gösterilmesi gerektiğini vurgular.","type":"Boşluk Doldurma","difficulty":"Orta","options":["sevgi","şefkat","saygı","yardım"],"correctAnswer":"saygı","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"JSPvLFpo4RABm0ArPPTJ","text":"Sadaka verirken yoksula verilen sadakanın bir, akrabaya verilen sadakanın ise iki sevabı olduğu belirtilmiştir. İkinci sevap, hangi davranışı kapsar?","type":"Çoktan Seçmeli","difficulty":"Orta","options":["İkramda bulunma","Misafir ağırlama","Akrabayı koruyup gözetme","Teşekkür etme"],"correctAnswer":"Akrabayı koruyup gözetme","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"KGDpEBL8KogNabKuw3je","text":"Peygamber Efendimiz, rızkının çoğalmasını ve ömrünün uzamasını isteyen kişiye akrabalarını kollayıp gözetmesini tavsiye etmiştir.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"Pn1jKOMoWZNmjZwtvuqy","text":"Akrabalık bağlarını korumak ve onlara iyi davranmak, Yüce Allah'ın ___ kazanmak için bir vesiledir.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["yardımını","sevgisini","rahmetini","rızasını"],"correctAnswer":"rızasını","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"QD5AX3uK1Esu2gju7MKT","text":"Ebu Talha'nın en sevdiği hurma bahçesi \"Beyrahâ\"yı Allah yolunda sadaka olarak bağışlaması üzerine, Peygamberimiz onu ne şekilde değerlendirmesini tavsiye etmiştir?","type":"Çoktan Seçmeli","difficulty":"Zor","options":["Fakirlere dağıtmasını","Akrabaları arasında taksim etmesini","Mescide vakfetmesini","Yetimlere vermesini"],"correctAnswer":"Akrabaları arasında taksim etmesini","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"TfdwBjWxBfCRe0fVIcCa","text":"Hz. Hatice, Peygamberimizi teselli ederken onun akraba hakkına riayet etmediğini söylemiştir.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"03lmGqXTa8ejb174SiHt","topicId":"s1RCsv1AmmHznus7cQKJ","topicName":"1. Peygamberimizin Toplumsal İlişkileri","topic":"1. Peygamberimizin Toplumsal İlişkileri","createdAt":"2026-01-02T20:40:16.160Z"},{"id":"UFwG1PK71dv4XrReE9Q2","text":"Peygamber Efendimiz’in Mekke fethinden sonra Medine’ye dönmesi, zor zamanında kendisine kucak açan Medinelilere karşı bir ___ örneğidir.","type":"Boşluk Doldurma","difficulty":"Orta","options":["şükran","minnet","vefa","sevgi"],"corre