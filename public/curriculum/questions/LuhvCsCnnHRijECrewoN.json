a","uyarı","söz"],"correctAnswer":"dua","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"ARSRniTfx324ZswltLyy","topicId":"LuhvCsCnnHRijECrewoN","topicName":"1. Peygamberimizin Allah'a Bağlılığı","topic":"1. Peygamberimizin Allah'a Bağlılığı","createdAt":"2026-01-02T20:36:19.226Z"},{"id":"vFHO9SQIbl3xJmPltsTB","text":"Peygamber Efendimiz (sav) sıkıntıya düştüğünde insanlar yerine sadece Rabb'inden yardım dilemiştir.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"ARSRniTfx324ZswltLyy","topicId":"LuhvCsCnnHRijECrewoN","topicName":"1. Peygamberimizin Allah'a Bağlılığı","topic":"1. Peygamberimizin Allah'a Bağlılığı","createdAt":"2026-01-02T20:36:19.226Z"}]