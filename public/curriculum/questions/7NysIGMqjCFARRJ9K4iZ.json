sCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"7ueZQRez8i6RXcxsSb7J","text":"\"Ey çarşı-pazar halkı! Sizi engelleyen şey nedir? Resulullah'ın mirası orada dağıtılırken siz burada duruyorsunuz!\" sözüyle insanları mescide yönlendiren ve asıl mirasın ilim olduğunu açıklayan sahabi _______ idi.","type":"Boşluk Doldurma","difficulty":"Zor","options":["Ebu Hüreyre","Hz. Ali","Muaz bin Cebel","İbni Abbas"],"correctAnswer":"Ebu Hüreyre","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"909pWTwE1csJV9fDILww","text":"Allah yolunda savaşarak ölenlere \"şehit\" denilmesinin temel nedeni, onların Yüce Allah'ın varlığı ve birliği yönündeki şehadetlerini _______ feda ederek göstermeleridir.","type":"Boşluk Doldurma","difficulty":"Zor","options":["canlarını","mallarını","zamanlarını","bilgilerini"],"correctAnswer":"canlarını","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"9uxfRwxdn1dNHpULEAZI","text":"Hz. Ali'nin ifadesine göre, sahabelerin Hz. Peygamber'e olan sevgisi aşağıdakilerden hangisinden daha üstündü?","type":"Çoktan Seçmeli","difficulty":"Kolay","options":["Bütün mal varlıklarından","yalnızca çocuklarından","sadece babalarından","hiçbiri"],"correctAnswer":"Bütün mal varlıklarından","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"AqAFQicN6a9iGVIMSgDj","text":"Peygamberimizin peygamberlik görevini yerine getirdiği döneme _______ denir.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["Asrısaadet","Fetret","Cahiliye","Hilafet"],"correctAnswer":"Asrısaadet","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"BiyzmsBdGXXqGegv4Snb","text":"Cihadın sadece savaş meydanlarında gerçekleştiği inancı, genç sahabiler arasında yaygındı.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"DRvwXv4owySIuyTGSKqH","text":"\"Kim içtenlikle Allah'tan şehit olmayı dilerse yatağında bile ölse Allah onu şehitlerin makamlarına ulaştırır.\" hadisi, niyetin ve samimiyetin önemini vurgular.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"FTXAUL1XGWXwhnvLG9J2","text":"Kur'an-ı Kerim'i anlayıp hayatımıza uygulayabilmemiz için Hz. Peygamber'in sözleri ve _______ örnek alınmalıdır.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["davranışları","rüyaları","şiirleri","hikayeleri"],"correctAnswer":"davranışları","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"GymDQn1b1lYQglsb1d6q","text":"Ebu Hüreyre'nin \"Hz. Muhammed'in asıl mirası ilimdir.\" ifadesiyle, maddi mirasın manevi mirastan daha önemli olduğunu kastetmiştir.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"HIR9vhnOl4fD59wbTKx2","text":"\"Şehadet\" kavramının anlamlarından biri aşağıdakilerden hangisidir?","type":"Çoktan Seçmeli","difficulty":"Orta","options":["Allah'ın birliğini ve Hz. Muhammed'in O'nun kulu ve elçisi olduğunu dile getirmek","Bir malı bir başkasına devretmek","Sadece savaş meydanında bulunmak","Ticaret yapmak."],"correctAnswer":"Allah'ın birliğini ve Hz. Muhammed'in O'nun kulu ve elçisi olduğunu dile getirmek","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"IgsMt40dJaDbj0x3TuVs","text":"Hz. Peygamber'den sonra da bilgi ve zekâsıyla insanları yönlendiren ve Kur'an'ın çevirmeni anlamına gelen \"Tercümânü'l Kur'ân\" olarak anılan sahabi _______ idi.","type":"Boşluk Doldurma","difficulty":"Orta","options":["İbni Abbas","Muaz bin Cebel","Ebu Hüreyre","Abdullah bin Amr"],"correctAnswer":"İbni Abbas","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"JuggqTKnogZouXtErW0h","text":"İbni Abbas, Kur'an'ı çeviren anlamına gelen \"Tercümânü'l Kur'ân\" olarak anılmıştır.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"Lxq1PPFlAK3jh1E3eN72","text":"Ezan, Müslümanları namaza çağırmak için boru çalınarak belirlenmiştir.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"NntRh52oG5IaMrEuIjRJ","text":"Hz. Peygamber, Kur'an ayetlerini sadece okumakla kalmamış, aynı zamanda hayatında uygulamıştır.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"O8iyFsS5bgxx0S97bN7c","text":"Hz. Peygamber, genç sahabilere görev verirken onların yeteneklerini dikkate almıştır.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"OQ7Ks9V0xD7DvXUWE9GK","text":"Hz. Peygamber'in genç sahabilere görev verirken dikkat ettiği en önemli husus nedir?","type":"Çoktan Seçmeli","difficulty":"Kolay","options":["Onların kişilik özelliklerini ve yeteneklerini bilmek","Onların yaşça büyük olmaları","Onların ailelerinin zengin olması","Onların toplumsal konumları."],"correctAnswer":"Onların kişilik özelliklerini ve yeteneklerini bilmek","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"OhrPaLEdgswrd4GkHKz7","text":"Hz. Ali, sahabelerin Hz. Peygamber'i kendilerinden daha az sevdiğini belirtmiştir.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"ReirU36m6IaXuRLJDQh5","text":"Peygamberlerin, Allah'ın kendilerine indirmiş olduğu vahiyleri insanlara eksiksiz olarak bildirmesine _______ denir.","type":"Boşluk Doldurma","difficulty":"Orta","options":["tebliğ","tefekkür","tevekkül","teşbih"],"correctAnswer":"tebliğ","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"U0HZl0EaGjLQwHwtDOyU","text":"Hz. Peygamber, \"Kıyamet gününde insanların bana en yakın olanı üzerime en çok _______ okuyanıdır.\" buyurmuştur.","type":"Boşluk Doldurma","difficulty":"Orta","options":["salatüselam","dua","ayet","hadis"],"correctAnswer":"salatüselam","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"UD7NQGE3tfK0CSfkIMUf","text":"Hz. Peygamber'e en yakın olmak isteyenlerin, ona en çok salatüselam okuması gerekmektedir.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"UxoDfwFonPaxRrRS0DYy","text":"Hz. Peygamber'in, \"Asıl cihat, kişinin kendi _______ (kötü arzu ve istekleriyle) olandır.\" hadisi, cihadın hangi yönünü vurgular?","type":"Boşluk Doldurma","difficulty":"Zor","options":["nefsiyle","düşmanıyla","ülkesiyle","malıyla"],"correctAnswer":"nefsiyle","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"WXZnWAyM0WYcCQ6ZOypw","text":"Müslümanların namaza çağrılması için Hz. Peygamber tarafından görevlendirilen ilk müezzin _______ idi.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["Hz. Bilal","Hz. Ebubekir","Hz. Ömer","Hz. Osman"],"correctAnswer":"Hz. Bilal","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"XJVAB5832R823TmbQBVd","text":"Tebliğ, insanları hakka davet etmek ve İslam'ın güzelliklerini anlatmak gibi önemli bir cihat yöntemidir.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"Xj7e8mX8KBXrRrbS0iyD","text":"\"Şehadet\" kavramı sadece tanıklık etmek anlamına gelir, Allah yolunda savaşarak ölmekle bir ilgisi yoktur.","type":"Doğru/Yanlış","difficulty":"Orta","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"XwXDZzXUY4utPejHrF97","text":"Urve bin Mesud, Hz. Peygamber'in ashabının ona duyduğu saygıdan etkilenerek Müslüman olmuştur.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"YLXnVuI0D2Q9SLuDJMu4","text":"Cihadın yalnızca savaş meydanlarında gerçekleşmediğini belirten hadis-i şerife göre, \"Asıl cihat\" ne ile yapılır?","type":"Çoktan Seçmeli","difficulty":"Orta","options":["Kişinin kendi nefsiyle (kötü arzu ve istekleriyle)","Yüksek binalar inşa ederek","Sadece zenginlik biriktirerek","Başkalarını sürekli eleştirerek."],"correctAnswer":"Kişinin kendi nefsiyle (kötü arzu ve istekleriyle)","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"ZpDte8CeG9pWKYfJrUj6","text":"\"Kim içtenlikle Allah'tan şehit olmayı dilerse yatağında bile ölse Allah onu şehitlerin makamlarına ulaştırır.\" hadisi, aşağıdakilerden hangisini en iyi açıklar?","type":"Çoktan Seçmeli","difficulty":"Zor","options":["Niyetin ve samimi arzunun önemini","Sadece savaşta ölenlerin şehit sayılacağını","Herkesin yatağında öleceğini","Şehitliğin sadece zorla elde edileceğini."],"correctAnswer":"Niyetin ve samimi arzunun önemini","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"bBpyHYDpqo6DQXlnFa6N","text":"\"Kim, kalbiyle tasdik ederek Yüce Allah'tan başka ilah olmadığına ve Hz. Muhammed'in Allah'ın Resulü olduğuna şehadet ederse Allah ona _______ haram kılar.\" buyuran hadis, hangi kavramın önemini vurgular?","type":"Boşluk Doldurma","difficulty":"Zor","options":["cehennemi","cenneti","dünyayı","zenginliği"],"correctAnswer":"cehennemi","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"bc8DtpvdzvyYqLWDNZYh","text":"İbni Abbas'ın \"Tercümânü'l Kur'ân\" olarak anılmasının temel sebebi nedir?","type":"Çoktan Seçmeli","difficulty":"Orta","options":["Kur'an'ı en iyi açıklayan ve yorumlayan kişi olması","Kur'an'ı en hızlı okuyan kişi olması","Kur'an'ı en güzel yazan kişi olması","Kur'an'ı en çok ezberleyen kişi olması."],"correctAnswer":"Kur'an'ı en iyi açıklayan ve yorumlayan kişi olması","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"cmOM3FLNhNect6tZiYXx","text":"Asrısaadet, Hz. Muhammed'in peygamberlik görevini yerine getirdiği dönemdir.","type":"Doğru/Yanlış","difficulty":"Kolay","options":[],"correctAnswer":"Doğru","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"ek0Kq1tjlAVN2jZn7LDk","text":"Urve bin Mesud'un, Hz. Peygamber'in ashabının ona gösterdiği saygının krallara gösterilen saygıdan bile üstün olduğunu gözlemledikten sonra Müslüman olması, neyin bir göstergesidir?","type":"Çoktan Seçmeli","difficulty":"Zor","options":["Hz. Peygamber'in şahsiyetinin ve sahabeler arasındaki güçlü bağın","Sadece kralların örnek alınması gerektiğini düşündüğünün","Savaşın ne kadar önemli olduğunun","Ticaretin siyasetten üstün olduğunun."],"correctAnswer":"Hz. Peygamber'in şahsiyetinin ve sahabeler arasındaki güçlü bağın","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"fQm0ohqUz8mJIUBedV2E","text":"Ebu Hüreyre'nin, Peygamberimizin vefatından sonra Medine pazarına gidip insanları mescide yönlendirerek asıl mirasın ilim, Kur'an ve namaz olduğunu anlatması, sahabenin Hz. Peygamber'e olan vefa ve sadakatini nasıl bir yolla gösterdiğini ifade eder?","type":"Çoktan Seçmeli","difficulty":"Zor","options":["Manevi mirasına sahip çıkarak","Maddi mirasını dağıtarak","Yeni bir lider seçerek","Ticari faaliyetlerini artırarak."],"correctAnswer":"Manevi mirasına sahip çıkarak","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"hwnuMzAhsxGQPF36UIHd","text":"Kur'an-ı Kerim'deki \"Namazı kılın, zekâtı verin.\" gibi emirlerin nasıl uygulanacağını Müslümanlara öğreten kimdir?","type":"Çoktan Seçmeli","difficulty":"Kolay","options":["Hz. Peygamber","Hz. Ebubekir","Hz. Ömer","İbni Abbas"],"correctAnswer":"Hz. Peygamber","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"jzgkhiB3JVUWk2Birlg8","text":"Urve bin Mesud'un aktarımına göre sahabe, Hz. Muhammed'e (sav) duyduğu saygı ve sevgiyi, onun yanında seslerini _______ ve emirlerini hemen yerine getirerek göstermişlerdir.","type":"Boşluk Doldurma","difficulty":"Zor","options":["alçaltarak","yükselterek","sorarak","tekrarlayarak"],"correctAnswer":"alçaltarak","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"l6PoFOdlKc3RjnGzPqcB","text":"Peygamberimizin Muaz bin Cebel'e seslenirken üç kez \"Ey Muaz!\" demesi, onun dikkatini dağıtmak amacıyla yapılmıştır.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"qdqVE3OwutkaEiNkNkTA","text":"\"Şehadet\" kavramının şartlarından biri, şehadet getirecek kişinin kesinlikle zengin olmasıdır.","type":"Doğru/Yanlış","difficulty":"Zor","options":[],"correctAnswer":"Yanlış","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"rSZF74HvYGKfYgOUrvp9","text":"Allah'ın (cc) birliğini ve Hz. Muhammed'in (sav) O'nun kulu ve elçisi olduğunu dile getirmeye _______ denir.","type":"Boşluk Doldurma","difficulty":"Orta","options":["şehadet","zekât","hicret","cihat"],"correctAnswer":"şehadet","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"srIKhZdh6IChBsNt80Z7","text":"Hz. Peygamber'in genç sahabilerin kişilik özelliklerini iyi bildiği ve onlara uygun görevler vermesi, onların _______ olmaları için önemli bir teşvik olmuştur.","type":"Boşluk Doldurma","difficulty":"Orta","options":["başarılı","zengin","ünlü","güçlü"],"correctAnswer":"başarılı","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"tQjPOQuJcxIQah8FDaBz","text":"Hz. Muhammed (sav)'in asıl mirası, mal ve mülk değil, _______, namaz ve ilim gibi manevi değerlerdir.","type":"Boşluk Doldurma","difficulty":"Kolay","options":["Kur'an","kılıç","deve","para"],"correctAnswer":"Kur'an","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"},{"id":"u9wjgWuNY3gc8fASjbbd","text":"Tebliğ faaliyetlerinin, cihadın önemli bir yöntemi olarak görülmesinin sebebi nedir?","type":"Çoktan Seçmeli","difficulty":"Zor","options":["İnsanları hakka davet etmek ve İslam'ın güzelliklerini anlatmak olması","Sadece savaş yaparak gerçekleşmesi","Ekonomik faydalar sağlaması","Siyasi güç elde etmek için kullanılması."],"correctAnswer":"İnsanları hakka davet etmek ve İslam'ın güzelliklerini anlatmak olması","classId":"2bn7xp3tBzOZZG6kHyXP","className":"6","courseId":"e6sa39FUi02TyzJpvQ89","unitId":"t9HH1JF2D3UIsCnmUkWa","topicId":"7NysIGMqjCFARRJ9K4iZ","topicName":"2. Gençlerin Dünyasında Peygamberimiz","topic":"2. Gençlerin Dünyasında Peygamberimiz","createdAt":"2026-01-02T20:32:59.816Z"}]