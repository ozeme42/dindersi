[{"id":"0bhFcIjMk7SLUPGo8deg","type":"concept","content":{"text":"İslam"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"4Ba4LYtIyqZ733PDgA6N","type":"sentence","content":{"text":"Hz. Ali, Hz. Zeyd bin Harise ve Hz. Enes bin Malik, Peygamberimizin yanında yetişen önemli çocuk sahabelerdendir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"6WZjokzBvtEHmOrK4BNB","type":"definition","content":{"term":"Tevazu","definition":"Kişinin kendi değerini olduğundan aşağı göstermesi, alçakgönüllülük."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"7kpYB91RbOXd65DAOWqb","type":"definition","content":{"term":"Hz. Ali","definition":"Beş yaşından itibaren Peygamberimizin evinde yaşamaya başlayan çocuk sahabe."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"7m3aNLMoxmFvMP80Iwpl","type":"concept","content":{"text":"Sahabi"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"8BBRNmRKVaLieXJKXTv8","type":"concept","content":{"text":"Kabile"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"8YtGdyTz83otif60hlLI","type":"concept","content":{"text":"Hicret"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"D8UyVOvVWhzcBIzWORK4","type":"sentence","content":{"text":"Peygamberimiz, çocuklara sevgi, şefkat ve merhametle yaklaşmıştır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"DixfVo7kt1BLRONs05xs","type":"definition","content":{"term":"Hz. Zeyd","definition":"Köle iken Peygamberimiz tarafından özgürlüğüne kavuşturulan ilk Müslüman çocuk sahabe."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"Ep5S9qBV6nV57caq92SO","type":"definition","content":{"term":"Saygı","definition":"Bir kişiye veya şeye karşı duyulan değer ve önem verme."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"GB9eicaoKMm17ymV23uL","type":"concept","content":{"text":"Kureyş"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"HW6j85pN35LTdq6fhsAF","type":"sentence","content":{"text":"Peygamberimizin yanında yetişen çocuklar, Müslümanlar için örnek teşkil etmektedir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"KdnjfwOV81OwkOBXv5YO","type":"definition","content":{"term":"Hz. Enes","definition":"Peygamberimizin küçük hizmetkarı olarak bilinen çocuk sahabe."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"M1MlCLYUtfmqKAKeUBkT","type":"definition","content":{"term":"Merhamet","definition":"Acıma, şefkat ve yardım duygularıyla dolu olmak."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"MtWYb7D7twQTVYyNqfR2","type":"sentence","content":{"text":"Asrısaadet dönemi, Hz. Muhammed'in yaşadığı ve İslam'ın yayılmaya başladığı dönemdir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"OWKtELyatdSzpJr9pfwO","type":"definition","content":{"term":"Şefkat","definition":"Başkasının acılarına karşı duyulan üzüntü ve yardım etme isteği."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"R838wMBzIwJkefhMkknN","type":"definition","content":{"term":"Asrısaadet","definition":"Hz. Muhammed'in yaşadığı dönem, mutluluk çağı."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"S4P72YqVIfy9xofOHA0U","type":"sentence","content":{"text":"Çocuk sahabiler, Peygamberimizi örnek alarak yaşamışlardır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"VxkVfV0LSTwLSK9awRgQ","type":"sentence","content":{"text":"Hz. Zeyd bin Harise, Peygamberimiz tarafından hürriyetine kavuşturulan ilk köledir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"WC5Mc3fsYFRYuhhVfTAF","type":"concept","content":{"text":"Vahiy"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"XTTOy1kp8nV7AzIuv7yt","type":"concept","content":{"text":"Halife"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"c1vmjWAlqwrTiWezltGc","type":"definition","content":{"term":"Sevgi","definition":"Bir kişiye veya şeye karşı duyulan derin ilgi ve bağlılık."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:27.685Z"},{"id":"fceAAFtEqFLlBZWs9iD4","type":"sentence","content":{"text":"Bu ünite, Peygamberimizin çocuklarla olan iletişimini ve onların Peygamberimizi nasıl rehber edindiklerini anlatmaktadır."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"nt4o4Cpg49Y5tFzqQDo5","type":"sentence","content":{"text":"Hz. Enes bin Malik, Peygamberimize on yıl hizmet etmiştir ve \"Peygamberin küçük hizmetkarı\" olarak bilinir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"nupy4SUYNymSHbZP4k0P","type":"sentence","content":{"text":"Hz. Peygamber, çocukların eğitimine ve ahlaklı yetişmesine önem vermiştir."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"oau0oKGNVfubB9rgyr1u","type":"concept","content":{"text":"Hadis"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"ozF38YRzaxqsa09R12Vr","type":"sentence","content":{"text":"Hz. Ali, Peygamberimize iman eden ilk çocuktur."},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"uRut2iIW0BemamZQl9zf","type":"concept","content":{"text":"Asrısaadet"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"},{"id":"xbGQR5PaBoOwj0QRSJf1","type":"concept","content":{"text":"Şehit"},"courseId":"OgnmTvY8rxVpEIP45iq4","unitId":"cUF2X2vchdqDFkcWMNkj","topicId":"W0oWMb2NmbPD9loOa99m","createdAt":"2025-07-09T03:59:06.832Z"}]