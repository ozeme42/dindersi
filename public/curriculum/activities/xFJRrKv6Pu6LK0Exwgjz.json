      "_nanoseconds": 581000000
    }
  },
  {
    "id": "95T7Z3lr7pzfIwpn7NZL",
    "type": "categorization",
    "topicId": "xFJRrKv6Pu6LK0Exwgjz",
    "unitId": "HaG39Z2i3AIE1XQznLZw",
    "content": {
      "items": [
        {
          "category": "Orucu Bozan Durumlar",
          "text": "Oruçlu olduğunu bilerek bir şeyler yemek, içmek."
        },
        {
          "category": "Orucu Bozan Durumlar",
          "text": "Güneşin battığını zannederek iftar etmek."
        },
        {
          "category": "Orucu Bozan Durumlar",
          "text": "Ağza giren yağmur veya karı isteyerek yutmak."
        },
        {
          "text": "Kendi isteğiyle ağız dolusu kusmak.",
          "category": "Orucu Bozan Durumlar"
        },
        {
          "category": "Orucu Bozmayan Durumlar",
          "text": "Oruçlu olduğunu unutarak bir şey yemek, içmek."
        },
        {
          "text": "Suyu yutmadan ağzı çalkalamak, burna su çekmek.",
          "category": "Orucu Bozmayan Durumlar"
        },
        {
          "text": "Banyo yapmak.",
          "category": "Orucu Bozmayan Durumlar"
        },
        {
          "text": "Koku sürmek.",
          "category": "Orucu Bozmayan Durumlar"
        }
      ],
      "definition": "",
      "term": "",
      "categories": [
        "Orucu Bozan Durumlar",
