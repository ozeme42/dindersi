      "title": "Felak Suresi",
      "definition": "",
      "categories": [],
      "text": "",
      "items": [
        "Bismillâhirraḥmânirraḥîm",
        "Ḳul eûzü birabbil felaḳ",
        "Min şerri mâ ḫalaḳ",
        "Ve min şerri ğâsiḳin iẕâ veḳab",
        "Ve min şerrin neffâsâti fil uḳad",
        "Ve min şerri ḥâsidin iẕâ ḥased"
      ],
      "term": ""
    },
    "createdAt": {
      "_seconds": 1758534058,
      "_nanoseconds": 981000000
