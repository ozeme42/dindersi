  },
  {
    "id": "iO6qYlpT6Wy4eukdTmag",
    "type": "sentence",
    "content": {
      "text": "Aşırı yemekten kaçınmak ve midenin bir kısmını boş bırakmak sağlıklı beslenmenin bir parçasıdır."
    },
    "courseId": "OgnmTvY8rxVpEIP45iq4",
    "unitId": "KXaDVYOgeUiDEerxQ7jR",
    "topicId": "B9ZrNo6WzlfdvpyRvYun",
