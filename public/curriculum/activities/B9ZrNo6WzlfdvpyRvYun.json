  {
    "id": "hz4lmEhTnplalv6i5zGB",
    "type": "sentence",
    "content": {
      "text": "Peygamberimiz, yemeğin israf edilmemesini ve tabağın temiz bırakılmasını tavsiye etmiştir."
    },
    "courseId": "OgnmTvY8rxVpEIP45iq4",
    "unitId": "KXaDVYOgeUiDEerxQ7jR",
    "topicId": "B9ZrNo6WzlfdvpyRvYun",
