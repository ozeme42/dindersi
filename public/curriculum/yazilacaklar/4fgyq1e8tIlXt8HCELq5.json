{"notes":[],"conceptDefinitions":[{"concept":"Bereket","definition":"Bolluk, feyiz ve artış demektir."},{"concept":"Kelimeişehadet","definition":"İslam'ın temel esaslarından biridir."},{"concept":"Salih Kullar","definition":"Tahiyyat duasında selam gönderilen Allah’ın iyi kulları."},{"concept":"Selam","definition":"Esenlik, ikram ve hürmet anlamlarına gelir."},{"concept":"Rahmet","definition":"Allah'ın merhameti ve acımasıdır."},{"concept":"Hadis","definition":"Peygamberimizin sözleri ve uygulamalarıdır."},{"concept":"Kelime-i Şehadet (Sözü)","definition":"\"Eşhedü en lâ ilâhe illallah ve eşhedü enne Muhammeden abdühü ve resûlüh\" cümlesidir."},{"concept":"Namaz","definition":"Müslümanların günde beş vakit yaptığı ibadettir."},{"concept":"Tahiyyat","definition":"Namazlarda otururken okunan bir ibadettir."},{"concept":"Ashab","definition":"Peygamberimizin arkadaşlarıdır."},{"concept":"Dua","definition":"Allah'tan yardım dileme, yalvarma eylemidir."}]}