rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is a teacher
    function isTeacher(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role in ['teacher', 'superadmin'];
    }

    // Default catch-all: Deny all reads and writes by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // Extra Pages (Herkese Açık)
    match /extraPages/{pageId} {
      allow read: if true;
      allow write: if isTeacher(request.auth.uid);
    }

    // Users Collection
    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId || isTeacher(request.auth.uid);
      allow update: if request.auth.uid == userId || isTeacher(request.auth.uid);
      allow delete: if isTeacher(request.auth.uid);

      // Student-specific progress subcollection
      match /progress/{courseId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      // Question Bank Progress
      match /questionBankProgress/{courseId} {
        allow read, write: if request.auth.uid == userId || isTeacher(request.auth.uid);
      }

      // Review Items
      match /reviewItems/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Public content that anyone can read
    match /classes/{classId} {
      allow read: if true;
      allow write: if isTeacher(request.auth.uid);
    }
    
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isTeacher(request.auth.uid);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isTeacher(request.auth.uid);

      match /units/{unitId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);

        match /topics/{topicId} {
          allow read: if true;
          allow write: if isTeacher(request.auth.uid);
        }
      }
    }
    
    // Questions and Activity Items
    match /questions/{questionId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    match /examQuestions/{questionId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    match /activityItems/{itemId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    // Score Events
    match /scoreEvents/{eventId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if isTeacher(request.auth.uid);
    }
    
    // Assignments
    match /assignments/{assignmentId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    // Game settings and Global settings
    match /settings/{docId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }

    match /announcements/{annId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    // Archive
    match /archivedSeasons/{seasonId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }

    // Image Library
    match /imageLibrary/{imageId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
    
    match /imageFolders/{folderId} {
        allow read: if true;
        allow write: if isTeacher(request.auth.uid);
    }
  }
}
